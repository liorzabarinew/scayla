---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import InstallCtaPair from '../components/InstallCtaPair.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import AnswerViewer from '../components/AnswerViewer.astro';

const title = 'איך להופיע ב-Gemini · קידום · Scayla';
const description =
  'איך להופיע ב-Gemini של גוגל ובסקירות ה-AI בחיפוש: המנוע מחובר לנוכחות שכבר יש לכם בגוגל · Scayla מודדת ומחזקת אותה.';

const canonicalPath = '/gemini-seo';

const faq = [
  {
    q: 'מה הקשר בין Gemini לחיפוש של גוגל?',
    a: 'Gemini הוא מודל ה-AI של גוגל, ואותה טכנולוגיה מזינה גם את סקירות ה-AI שמופיעות מעל תוצאות החיפוש. מי שכבר מקודם טוב בגוגל מתחיל צעד לפני האחרים ב-Gemini, כי גוגל כבר סורק ומבין את החנות. זה יתרון שאין לכם מול מנועים אחרים.',
  },
  {
    q: 'איך להופיע בסקירות ה-AI של גוגל?',
    a: 'סקירת ה-AI לוקחת תוכן שגוגל כבר סורק ומרכיבה ממנו תשובה. צריך עמודים ברורים עם תשובה ישירה, סכמות תקינות ו-FAQ שגוגל מזהה. Scayla מחוברת ל-Google Search Console שלכם, אז היא רואה על אילו שאילתות אתם כבר קרובים · ובונה בדיוק את התוכן שדוחף אתכם לתוך הסקירה.',
  },
  {
    q: 'צריך קידום נפרד ל-Gemini ולגוגל הרגיל?',
    a: 'לא. אותה עבודה משרתת את שניהם. תוכן טוב, סכמות ומבנה ברור מזיזים אתכם גם בתוצאות הרגילות וגם בסקירת ה-AI. Scayla עושה את שתי המשימות במקביל, ומודדת כל אחת בנפרד כדי שתדעו איפה אתם מרוויחים.',
  },
  {
    q: 'איך יודעים אם Gemini מזכיר את החנות שלנו?',
    a: 'Scayla מריצה את שאלות הקטגוריה שלכם מול Gemini בעברית ובודקת אם אתם בתשובה או שהמתחרה תפס את המקום. את זה משווים זו לצד זו מול ChatGPT, ומודדים כל שבוע · לא ניחוש חד-פעמי.',
  },
];

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'איך להופיע ב-Gemini של גוגל · קידום חנות שופיפיי',
  description,
  inLanguage: 'he',
  mainEntityOfPage: `https://scayla.co.il${canonicalPath}`,
  author: { '@type': 'Person', name: 'נוי קייטל', url: 'https://scayla.co.il/experts/noy-keitel' },
  publisher: { '@type': 'Organization', name: 'Scayla', url: 'https://scayla.co.il/' },
};
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={[{ name: 'הופעה ב-Gemini', path: canonicalPath }]}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} slot="head" />

  <section class="svc-hero">
    <div class="narrow center">
      <span class="eyebrow">קידום ל-Gemini</span>
      <h1>איך להופיע ב-Gemini · המנוע שכבר מכיר את החנות שלכם מגוגל</h1>
      <p class="lede">
        Gemini הוא ה-AI של גוגל, ואותה טכנולוגיה מזינה את סקירות ה-AI מעל תוצאות החיפוש.
        המשמעות: הנוכחות שכבר בניתם בגוגל היא נקודת הפתיחה שלכם. Scayla מחברת את זה
        ל-Search Console שלכם, מודדת איפה אתם עומדים ודוחפת אתכם פנימה.
      </p>
      <InstallCtaPair center variant="hero" />
      <p class="cta-note">אבחון נראות ב-Gemini חינם · מחובר ל-Google Search Console</p>
    </div>
  </section>

  <section class="svc-body alt-bg">
    <div class="wrap">
      <div class="sh">
        <span class="eyebrow">למה Gemini שונה מהשאר</span>
        <h2>המנוע היחיד שמחובר לנכס שכבר יש לכם · החיפוש בגוגל</h2>
        <p>
          ChatGPT ו-Perplexity מתחילים אתכם מאפס. Gemini לא. גוגל כבר סורק את החנות, כבר
          יודע על אילו מילים אתם מדורגים, וכבר מציג אתכם למישהו. Gemini וסקירת ה-AI בונים
          על אותו בסיס · אז כל שיפור אורגני עובד כאן פעמיים.
        </p>
      </div>
      <div class="stat-row">
        <div class="stat card fade-up">
          <div class="stat-n">×2</div>
          <p>כל תיקון אורגני עובד גם בתוצאות הרגילות וגם בסקירת ה-AI · אותה עבודה, שני מקומות.</p>
        </div>
        <div class="stat card fade-up">
          <div class="stat-n">GSC</div>
          <p>Scayla מחוברת ל-Google Search Console שלכם, אז היא רואה בדיוק על אילו שאילתות אתם כבר קרובים לסקירה.</p>
        </div>
        <div class="stat card fade-up">
          <div class="stat-n num">1</div>
          <p>סקירת AI אחת מעל התוצאות · מי שבתוכה נקרא ראשון, לפני עשרת הקישורים הכחולים.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="svc-demo">
    <div class="wrap">
      <div class="sh">
        <span class="eyebrow">ככה זה נראה</span>
        <h2>שאלת קונה · סקירת ה-AI של גוגל, לפני ואחרי</h2>
        <p>Scayla מציגה את תשובת Gemini על הקטגוריה שלכם, עם השם שלכם מודגש · או חסר.</p>
      </div>
      <div class="engines">
        <div class="engine-panel card fade-up">
          <AnswerViewer
            question="איזו חנות מומלצת לביגוד ספורט לנשים?"
            engine="Gemini"
            gapText="<b>נעדרים מהתשובה.</b> אתם מדורגים בגוגל אבל לא בסקירה · Scayla סוגרת את הפער."
          >
            לביגוד ספורט לנשים בולטות <span class="hl-red">אקטיב ליידי</span> ו
            <span class="hl-red">פיט סטייל</span>, עם מבחר מידות ומשלוח מהיר.
          </AnswerViewer>
        </div>
        <div class="engine-panel card fade-up">
          <AnswerViewer
            question="איזו חנות מומלצת לביגוד ספורט לנשים?"
            engine="Gemini"
            presentText="<b>אתם בתשובה.</b> הדירוג בגוגל הפך גם לנוכחות בסקירת ה-AI."
          >
            בין המומלצות: <span class="hl-grn">החנות שלכם</span> עם בדים נושמים ומדריך
            מידות מפורט, וגם <span class="hl-red">אקטיב ליידי</span>.
          </AnswerViewer>
        </div>
      </div>
      <p class="svc-note center">
        התשובות כאן להמחשה. באפליקציה תראו את הנתונים האמיתיים על החנות, ואיך הם מתחברים
        ל<a href="/seo-shopify">קידום האורגני שלכם בגוגל</a>.
      </p>
    </div>
  </section>

  <section class="svc-body alt-bg">
    <div class="wrap">
      <div class="sh">
        <span class="eyebrow">איך Scayla עוזרת</span>
        <h2>שלושה מהלכים שהופכים דירוג בגוגל לנוכחות ב-Gemini</h2>
      </div>
      <div class="bgrid three">
        <div class="b card fade-up">
          <h3>קוראת את ה-Search Console שלכם</h3>
          <p>Scayla מחוברת ל-GSC ורואה על אילו שאילתות אתם כבר בעמוד 1 אבל עדיין מחוץ לסקירה · אלה ההזדמנויות הכי מהירות.</p>
        </div>
        <div class="b card fade-up">
          <h3>בונה תוכן שגוגל שולף לסקירה</h3>
          <p>תשובות ישירות, טבלאות ו-FAQ במבנה שסקירת ה-AI אוהבת לצטט. מפורסם רק באישורכם, בעברית תקנית.</p>
        </div>
        <div class="b card fade-up">
          <h3>מתקנת סכמות ושברים</h3>
          <p>Product, FAQ ו-301 לעמודי 404 · אותם תיקונים משפרים גם את הדירוג הרגיל וגם את הסיכוי להיכנס לסקירה.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="svc-guide">
    <div class="narrow">
      <div class="sh">
        <span class="eyebrow">מדריך מהיר</span>
        <h2>ארבעה צעדים להופעה ב-Gemini</h2>
      </div>
      <ol class="guide">
        <li class="card fade-up">
          <span class="gn num">1</span>
          <div>
            <h3>התחילו מהמילים שבהן אתם כבר קרובים</h3>
            <p>ב-Search Console חפשו שאילתות שבהן אתם במקומות 3 עד 10. אלה המילים שהכי קל להפוך לנוכחות בסקירת ה-AI.</p>
          </div>
        </li>
        <li class="card fade-up">
          <span class="gn num">2</span>
          <div>
            <h3>ענו על השאלה ישירות בראש העמוד</h3>
            <p>סקירת ה-AI שולפת תשובה קצרה וברורה. פסקה ראשונה שעונה בדיוק על השאלה עדיפה על מבוא ארוך.</p>
          </div>
        </li>
        <li class="card fade-up">
          <span class="gn num">3</span>
          <div>
            <h3>הוסיפו סכמות שגוגל כבר קורא</h3>
            <p>Product, FAQPage ו-Organization נותנים לגוגל מבנה ברור. בלעדיהם המנוע מנחש · ולרוב בוחר במתחרה שכן סימן.</p>
          </div>
        </li>
        <li class="card fade-up">
          <span class="gn num">4</span>
          <div>
            <h3>עקבו אחרי הסקירה, לא רק אחרי הדירוג</h3>
            <p>אפשר להיות ראשון בתוצאות ולהיעדר מהסקירה שמעליהן. מדדו את שניהם בנפרד כדי לדעת איפה יש עוד מה לתקן.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <section class="svc-faq">
    <div class="narrow">
      <div class="sh"><span class="eyebrow">שאלות נפוצות</span><h2>הופעה ב-Gemini · תשובות מהירות</h2></div>
      <FaqAccordion items={faq} schema={true} />
    </div>
  </section>

  <section class="svc-links alt-bg">
    <div class="wrap">
      <div class="sh"><span class="eyebrow">להמשיך מכאן</span><h2>אותה שיטה · מנועים אחרים</h2></div>
      <div class="lgrid">
        <a class="lcard card fade-up" href="/chatgpt-seo"><b>הופעה ב-ChatGPT</b><small>המנוע עם הכי הרבה קונים ששואלים בישראל</small></a>
        <a class="lcard card fade-up" href="/perplexity-seo"><b>הופעה ב-Perplexity</b><small>המנוע שמצרף מקורות עם קישור · ציטוט שהופך לתנועה</small></a>
        <a class="lcard card fade-up" href="/claude-seo"><b>הופעה ב-Claude</b><small>קהל מקצועי, מחקר לעומק · פחות רעש, יותר כוונה</small></a>
        <a class="lcard card fade-up" href="/ai-visibility"><b>נראות ב-ChatGPT וב-Gemini</b><small>שני המנועים זה לצד זה, עם המותג שלכם מודגש או חסר</small></a>
        <a class="lcard card fade-up" href="/geo"><b>אופטימיזציה למנועי AI · GEO</b><small>העיקרון שמאחורי כל המנועים · מדידה, אבחון ופעולה</small></a>
        <a class="lcard card fade-up" href="/"><b>Scayla · לעמוד הבית</b><small>נראות ב-Google וב-AI, אוטומטית, מתוך החנות שלכם</small></a>
      </div>
    </div>
  </section>

  <section class="svc-cta">
    <div class="wrap">
      <CtaBand
        title="הדירוג שלכם בגוגל שווה יותר · תנו לו להיכנס גם לסקירת ה-AI."
        body="התקינו את Scayla, חברו את Search Console, ותראו אילו שאילתות כבר קרובות לסקירה של Gemini · תוך דקות."
      />
    </div>
  </section>
</BaseLayout>

<style>
  .svc-hero { padding-block-end: 16px; }
  .cta-note { font-size: 13px; color: var(--sc-disabled); margin-block-start: 14px; }
  .alt-bg { background: var(--sc-card); }
  :global([data-theme='dark']) .alt-bg { background: #17141d; }

  .stat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  @media (max-width: 820px) { .stat-row { grid-template-columns: 1fr; } }
  .stat { padding: 24px; background: var(--sc-paper); }
  .stat-n { font-size: 40px; font-weight: 800; color: var(--sc-accent-text); letter-spacing: -.02em; line-height: 1; margin-block-end: 10px; }
  .stat p { font-size: 14.5px; }

  .engines { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 820px) { .engines { grid-template-columns: 1fr; } }
  .engine-panel { padding: 14px; border-radius: 18px; }

  .bgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  @media (max-width: 820px) { .bgrid { grid-template-columns: 1fr; } }
  .b { padding: 24px; background: var(--sc-paper); }
  .b h3 { margin-block-end: 6px; font-size: 17px; }
  .b p { font-size: 14.5px; }

  .guide { list-style: none; margin: 0; padding: 0; display: grid; gap: 12px; }
  .guide li { display: flex; gap: 16px; align-items: flex-start; padding: 20px 22px; }
  .gn {
    flex: none; inline-size: 34px; block-size: 34px; border-radius: 10px;
    background: var(--sc-wash); color: var(--sc-accent-text);
    display: grid; place-items: center; font-size: 16px; font-weight: 800;
  }
  .guide h3 { font-size: 16.5px; margin-block-end: 4px; }
  .guide p { font-size: 14.5px; }

  .lgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  @media (max-width: 820px) { .lgrid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .lgrid { grid-template-columns: 1fr; } }
  .lcard { display: flex; flex-direction: column; gap: 5px; padding: 18px 20px; color: var(--sc-ink); transition: transform var(--sc-fast) var(--sc-ease), border-color 200ms, box-shadow 200ms; }
  .lcard:hover { color: var(--sc-ink); transform: translateY(-2px); border-color: var(--sc-soft); box-shadow: var(--sc-sh-lift); }
  .lcard b { font-size: 15.5px; font-weight: 800; letter-spacing: -.01em; }
  .lcard small { font-size: 13px; color: var(--sc-muted); font-weight: 500; line-height: 1.5; }

  .svc-note { margin-block-start: 26px; font-size: 15px; max-inline-size: 62ch; margin-inline: auto; }
  .svc-cta { padding-block-end: clamp(24px, 4vw, 48px); }
</style>
