---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="העמוד לא נמצא · Scayla"
  description="העמוד שחיפשתם לא נמצא."
  noIndex={true}
>
  <section class="nf">
    <div class="narrow center">
      <p class="code num" aria-hidden="true">404</p>
      <h1>העמוד הזה לא בתשובה.</h1>
      <p class="lede">בדיוק בשביל פערים כאלה בנינו מתקן 404 · אבל את העמוד הזה פשוט אין.</p>
      <div class="row">
        <a href="/" class="btn btn-solid">לעמוד הבית</a>
        <a href="/magazine" class="btn btn-ghost">למגזין</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { min-block-size: 52vh; display: grid; align-content: center; }
  .code {
    font-size: clamp(60px, 10vw, 96px); font-weight: 800; line-height: 1;
    background: var(--sc-grad);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  h1 { margin-block-start: 10px; font-size: clamp(24px, 4vw, 34px); }
  .row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-block-start: 28px; }
</style>
