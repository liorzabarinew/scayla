<script>
  // ── /quizz · לוגיקת השאלון ──────────────────────────────────────────────
  // 1. פלטפורמה שאינה Shopify → דילוג ישיר למצב הדחייה (אין טעם למלא את השאר)
  // 2. ולידציה שאומרת מה לתקן, לא "שדה לא תקין"
  // 3. שליחה ל-/api/quizz → Google Sheet (ליאור + נוי) + פינג טלגרם

  const form = document.getElementById('quizz-form') as HTMLFormElement | null;
  const done = document.getElementById('quizz-done');
  const nope = document.getElementById('quizz-nope');
  const head = document.getElementById('form-head');
  const back = document.getElementById('quizz-back');
  const submit = document.getElementById('quizz-submit') as HTMLButtonElement | null;
  const summary = document.getElementById('e-summary');
  const platform = document.getElementById('platform') as HTMLSelectElement | null;

  if (form && done && nope && head && submit && summary && platform) {
    const show = (el: HTMLElement | null) => el && el.removeAttribute('hidden');
    const hide = (el: HTMLElement | null) => el && el.setAttribute('hidden', '');

    // ── 1. פלטפורמה ≠ Shopify → מצב דחייה ──
    const gate = () => {
      const v = platform.value;
      if (v && v !== 'Shopify') {
        hide(form); hide(head); hide(done); show(nope);
        nope.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    };
    platform.addEventListener('change', gate);
    back?.addEventListener('click', () => {
      platform.value = '';
      hide(nope); show(head); show(form);
      platform.focus();
    });

    // ── 2. ולידציה ──
    const REQ_TEXT: Record<string, string> = {
      store: 'כתבו את שם החנות וכתובת האתר.',
      what: 'כתבו בקצרה מה החנות מוכרת ולמי.',
      nm: 'כתבו את שמכם המלא.',
    };
    const REQ_RADIO: Record<string, string> = {
      age: 'בחרו כמה זמן החנות באוויר.',
      traffic: 'בחרו כמה מבקרים מגיעים לחנות בחודש.',
      seo: 'בחרו מה קורה אצלכם היום עם קידום אורגני.',
      gsc: 'בחרו אם יש לכם Search Console מחובר.',
      ga4: 'בחרו אם יש לכם Google Analytics 4 מחובר.',
      inst: 'בחרו אם תוכלו להתקין אפליקציה בחנות.',
      apr: 'בחרו מי יאשר את התוכן וכמה מהר.',
      cmt: 'בחרו אם השיחה החודשית והפידבק מתאימים לכם.',
    };

    // טלפון ישראלי · נייד 05X, קווי 0X, ושירותים 07X. מקבל +972 ומפרידים.
    const okPhone = (raw: string) => {
      const d = raw.replace(/[\s\-().]/g, '').replace(/^\+972/, '0');
      return /^0(5\d{8}|7\d{8}|[23489]\d{7})$/.test(d);
    };
    const okEmail = (raw: string) => /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(raw.trim());

    const setErr = (key: string, msg: string) => {
      const el = document.getElementById('e-' + key);
      const field = el?.closest('.f');
      if (el) { el.textContent = msg; el.removeAttribute('hidden'); }
      field?.classList.add('bad');
    };
    const clearErr = (key: string) => {
      const el = document.getElementById('e-' + key);
      const field = el?.closest('.f');
      if (el) { el.setAttribute('hidden', ''); el.textContent = ''; }
      field?.classList.remove('bad');
    };

    const validate = () => {
      const fd = new FormData(form);
      const bad: string[] = [];
      const all = [...Object.keys(REQ_TEXT), ...Object.keys(REQ_RADIO), 'platform', 'ph', 'em'];
      all.forEach(clearErr);

      for (const [k, msg] of Object.entries(REQ_TEXT)) {
        if (!String(fd.get(k) || '').trim()) { setErr(k, msg); bad.push(k); }
      }
      for (const [k, msg] of Object.entries(REQ_RADIO)) {
        if (!fd.get(k)) { setErr(k, msg); bad.push(k); }
      }
      if (!fd.get('platform')) { setErr('platform', 'בחרו על איזו פלטפורמה החנות בנויה.'); bad.push('platform'); }

      const ph = String(fd.get('ph') || '').trim();
      if (!ph) { setErr('ph', 'כתבו מספר טלפון.'); bad.push('ph'); }
      else if (!okPhone(ph)) { setErr('ph', 'המספר לא נראה תקין · טלפון ישראלי, למשל 050-0000000.'); bad.push('ph'); }

      const em = String(fd.get('em') || '').trim();
      if (!em) { setErr('em', 'כתבו כתובת מייל.'); bad.push('em'); }
      else if (!okEmail(em)) { setErr('em', 'המייל לא נראה תקין · בדקו את הכתובת, למשל you@store.co.il.'); bad.push('em'); }

      return bad;
    };

    // ── 3. שליחה ──
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hide(summary);

      const bad = validate();
      if (bad.length) {
        summary.textContent = `חסרים ${bad.length} שדות · השלימו את המסומנים באדום ונסו שוב.`;
        show(summary);
        const first = document.getElementById('e-' + bad[0])?.closest('.f');
        first?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        (first?.querySelector('input, select, textarea') as HTMLElement | null)?.focus();
        return;
      }

      submit.setAttribute('aria-busy', 'true');
      submit.textContent = 'שולח...';
      try {
        const payload = Object.fromEntries(new FormData(form).entries());
        const res = await fetch('/api/quizz', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error('bad status ' + res.status);
        hide(form); hide(head); show(done);
        done.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } catch {
        summary.textContent = 'השליחה נכשלה · בדקו את החיבור ונסו שוב. אם זה חוזר, כתבו לנו דרך עמוד צרו קשר.';
        show(summary);
        submit.removeAttribute('aria-busy');
        submit.textContent = 'שליחת השאלון';
      }
    });
  }
</script>
