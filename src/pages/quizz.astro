---
/**
 * /quizz · עמוד נחיתה + שאלון התאמה לפיילוט חמש החנויות.
 *
 * הכניסה לעמוד היא מקישור ישיר (פוסט אורגני) · הוא לא יושב בתפריט העליון.
 * noIndex: הפיילוט מוגבל לחמישה מקומות ולזמן קצוב · אין סיבה שיתחרה באתר בגוגל.
 *
 * מדיניות Shopify (דרישה 1.3.1): אסור לתת הטבה בתמורה לביקורת. לכן אין בעמוד
 * הזה שום אזכור של ביקורת או דירוג · התמורה היחידה שמבוקשת היא פידבק פנימי.
 * זה מכוון. בקשת ביקורת תגיע רק דרך ה-Reviews API בתוך האפליקציה.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'פיילוט · חמש חנויות שופיפיי מקבלות את Scayla חינם · Scayla';
const description =
  'אנחנו מחפשים חמש חנויות שופיפיי שירוצו על Scayla המלאה שלושה חודשים, בליווי אנשי SEO ו-GEO. שאלון התאמה קצר · תשובה תוך יומיים.';
---

<BaseLayout title={title} description={description} noIndex>
  <!-- ═══ HERO ═══ -->
  <header class="hero">
    <div class="hero-in">
      <div>
        <span class="seats"><i class="lv-dot" aria-hidden="true"></i>פיילוט · <span class="num">5</span> מקומות</span>
        <h1>
          חמש חנויות שופיפיי<br />
          מקבלות את Scayla<br />
          <span class="grad-word">חינם. שלושה חודשים.</span>
        </h1>
      </div>

      <div class="hero-side">
        <p class="sub">
          אנחנו רגע לפני העלייה לחנות האפליקציות של Shopify · ומחפשים חמש חנויות
          שירוצו על המערכת המלאה, עם ליווי צמוד של אנשי SEO ו-GEO.
          <strong>כל מה שאנחנו מבקשים בתמורה זה פידבק כן</strong>, שנשאר אצלנו פנימית.
        </p>
        <div class="cta-pair">
          <a class="btn btn-hero btn-gold" href="#form">למילוי שאלון ההתאמה</a>
        </div>
        <div class="proof">
          <div class="stat">
            <b class="num">7</b>
            <span>קייס סטאדיז עד היום</span>
          </div>
          <div class="stat">
            <b class="num">220%</b>
            <span>עלייה ממוצעת בתנועה אורגנית</span>
          </div>
          <div class="stat">
            <b class="num">₪0</b>
            <span>מדיה ממומנת</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ═══ מה בפיילוט ═══ -->
  <section class="alt-bg">
    <div class="wrap">
      <div class="sh">
        <span class="eyebrow">מה בפיילוט</span>
        <h2>המערכת המלאה · לא גרסה מוקטנת</h2>
        <p>אתם מקבלים את כל מה שלקוח משלם מקבל · ואנחנו יושבים על זה איתכם.</p>
      </div>

      <div class="panels">
        <div class="panel card">
          <div class="panel-h">
            <span class="panel-ic" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg>
            </span>
            <h3>אתם מקבלים</h3>
          </div>
          <ul class="rows">
            <li><i class="mk y" aria-hidden="true">✓</i><span>שלושה חודשים של Scayla במלואה · כל התפקידים פעילים</span></li>
            <li><i class="mk y" aria-hidden="true">✓</i><span>ליווי צמוד של אנשי SEO ו-GEO · לא רק תוכנה</span></li>
            <li><i class="mk y" aria-hidden="true">✓</i><span>תוכן שנכתב לגוגל ולמנועי ה-AI · אחרי שני סבבי בקרה</span></li>
            <li><i class="mk y" aria-hidden="true">✓</i><span>תיקונים טכניים בחנות · בלי שורת קוד מהמפתח שלכם</span></li>
            <li><i class="mk y" aria-hidden="true">✓</i><span>אישור שלכם על כל שינוי · שום דבר לא עולה לבד</span></li>
          </ul>
        </div>

        <div class="panel card">
          <div class="panel-h">
            <span class="panel-ic" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M4 20l4.5-1L18 9.5a2.1 2.1 0 0 0-3-3L5.5 16z"></path></svg>
            </span>
            <h3>אנחנו מבקשים</h3>
          </div>
          <ul class="rows">
            <li><i class="mk y" aria-hidden="true">✓</i><span>שיחה חודשית של חצי שעה · פעם בחודש, זה הכל</span></li>
            <li><i class="mk y" aria-hidden="true">✓</i><span>פידבק כן · כולל מה שלא עובד. זה כל הרעיון</span></li>
            <li><i class="mk y" aria-hidden="true">✓</i><span>גישה ל-Search Console ול-GA4 · אחרת אין ממה למדוד</span></li>
            <li><i class="mk y" aria-hidden="true">✓</i><span>מישהו אצלכם שמאשר תוכן תוך יום או יומיים</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ התאמה ═══ -->
  <section>
    <div class="wrap">
      <div class="sh">
        <span class="eyebrow">לפני שממלאים</span>
        <h2>למי הפיילוט מתאים · ולמי פחות</h2>
        <p>עדיף לומר את זה עכשיו מאשר לבזבז לכם חודש. אנחנו בוחרים לפי התאמה · לא לפי מי הגיב ראשון.</p>
      </div>

      <div class="panels">
        <div class="panel card">
          <div class="panel-h">
            <span class="panel-ic" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M8.5 12.5l2.5 2.5 4.5-5"></path></svg>
            </span>
            <h3>מתאים</h3>
          </div>
          <ul class="rows">
            <li><i class="mk y" aria-hidden="true">✓</i><span>חנות שופיפיי שבאוויר לפחות שנה</span></li>
            <li><i class="mk y" aria-hidden="true">✓</i><span>יש כבר תנועה · גם צנועה. צריך בסיס למדוד ממנו</span></li>
            <li><i class="mk y" aria-hidden="true">✓</i><span>בעלי החנות מעורבים · ויכולים לאשר מהר</span></li>
            <li><i class="mk y" aria-hidden="true">✓</i><span>משלמים היום לסוכנות · או לא נוגעים בקידום אורגני בכלל</span></li>
          </ul>
        </div>

        <div class="panel card">
          <div class="panel-h">
            <span class="panel-ic" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M9 9l6 6M15 9l-6 6"></path></svg>
            </span>
            <h3>פחות מתאים</h3>
          </div>
          <ul class="rows">
            <li><i class="mk n" aria-hidden="true">✕</i><span>כל פלטפורמה שאינה שופיפיי · בשלב הזה לא נוכל</span></li>
            <li><i class="mk n" aria-hidden="true">✕</i><span>חנות חדשה מאוד · מתחת לשלושה חודשים</span></li>
            <li><i class="mk n" aria-hidden="true">✕</i><span>ריברנד, דומיין חדש או מעבר פלטפורמה בחודשים הקרובים</span></li>
            <li><i class="mk n" aria-hidden="true">✕</i><span>אף אחד לא פנוי לאשר תוכן · המערכת תיתקע ושנינו נפסיד</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ הטופס ═══ -->
  <section id="form" class="alt-bg">
    <div class="form-wrap">
      <div class="sh" id="form-head">
        <span class="eyebrow">שאלון התאמה</span>
        <h2>שלוש דקות · ותשובה תוך יומיים</h2>
        <p>כן או לא, בלי להשאיר אתכם באוויר. כל מה שתכתבו נשאר אצלנו.</p>
      </div>

      <form class="form" id="quizz-form" novalidate>
        <fieldset class="fs">
          <legend>החנות</legend>

          <div class="f">
            <label for="store">שם החנות וכתובת האתר <span class="req">חובה</span></label>
            <input id="store" name="store" type="text" placeholder="פנינה קוסמטיקס · pnina-shop.co.il" dir="auto" autocomplete="organization" />
            <p class="err" id="e-store" role="alert" hidden></p>
          </div>

          <div class="f">
            <label for="platform">על איזו פלטפורמה החנות בנויה? <span class="req">חובה</span></label>
            <select id="platform" name="platform">
              <option value="">בחרו</option>
              <option value="Shopify">Shopify</option>
              <option value="WooCommerce">WooCommerce</option>
              <option value="Wix">Wix</option>
              <option value="Magento">Magento</option>
              <option value="אחר">אחר</option>
            </select>
            <span class="hint">הפיילוט פתוח לחנויות שופיפיי בלבד בשלב הזה.</span>
            <p class="err" id="e-platform" role="alert" hidden></p>
          </div>

          <div class="f">
            <label for="what">מה החנות מוכרת · ולמי? <span class="req">חובה</span></label>
            <textarea id="what" name="what" placeholder="שתי שורות מספיקות"></textarea>
            <p class="err" id="e-what" role="alert" hidden></p>
          </div>

          <div class="f">
            <span class="q" id="q-age">כמה זמן החנות באוויר? <span class="req">חובה</span></span>
            <div class="opts" role="radiogroup" aria-labelledby="q-age">
              <input type="radio" id="age1" name="age" value="פחות מ-3 חודשים" /><label for="age1">פחות מ-<span class="num">3</span> חודשים</label>
              <input type="radio" id="age2" name="age" value="3 עד 12 חודשים" /><label for="age2"><span class="num">3</span> עד <span class="num">12</span> חודשים</label>
              <input type="radio" id="age3" name="age" value="1 עד 3 שנים" /><label for="age3"><span class="num">1</span> עד <span class="num">3</span> שנים</label>
              <input type="radio" id="age4" name="age" value="מעל 3 שנים" /><label for="age4">מעל <span class="num">3</span> שנים</label>
            </div>
            <p class="err" id="e-age" role="alert" hidden></p>
          </div>

          <div class="f">
            <span class="q" id="q-traffic">כמה מבקרים בחודש מגיעים לחנות היום, בערך? <span class="req">חובה</span></span>
            <div class="opts" role="radiogroup" aria-labelledby="q-traffic">
              <input type="radio" id="t1" name="traffic" value="עד 500" /><label for="t1">עד <span class="num">500</span></label>
              <input type="radio" id="t2" name="traffic" value="500 עד 2,000" /><label for="t2"><span class="num">500</span> עד <span class="num">2,000</span></label>
              <input type="radio" id="t3" name="traffic" value="2,000 עד 10,000" /><label for="t3"><span class="num">2,000</span> עד <span class="num">10,000</span></label>
              <input type="radio" id="t4" name="traffic" value="מעל 10,000" /><label for="t4">מעל <span class="num">10,000</span></label>
              <input type="radio" id="t5" name="traffic" value="לא יודעים" /><label for="t5">לא יודעים</label>
            </div>
            <p class="err" id="e-traffic" role="alert" hidden></p>
          </div>

          <div class="f">
            <span class="q" id="q-chg">מתוכנן שינוי גדול בחנות בשלושת החודשים הקרובים?</span>
            <div class="opts" role="radiogroup" aria-labelledby="q-chg">
              <input type="radio" id="c1" name="chg" value="לא" /><label for="c1">לא</label>
              <input type="radio" id="c2" name="chg" value="מעבר פלטפורמה" /><label for="c2">מעבר פלטפורמה</label>
              <input type="radio" id="c3" name="chg" value="ריברנד או דומיין חדש" /><label for="c3">ריברנד או דומיין חדש</label>
              <input type="radio" id="c4" name="chg" value="שינוי גדול בקטלוג" /><label for="c4">שינוי גדול בקטלוג</label>
            </div>
          </div>
        </fieldset>

        <fieldset class="fs">
          <legend>איפה אתם היום</legend>

          <div class="f">
            <span class="q" id="q-seo">מה קורה אצלכם היום עם קידום אורגני? <span class="req">חובה</span></span>
            <div class="opts" role="radiogroup" aria-labelledby="q-seo">
              <input type="radio" id="s1" name="seo" value="לא נוגעים בזה" /><label for="s1">לא נוגעים בזה</label>
              <input type="radio" id="s2" name="seo" value="משהו לבד מדי פעם" /><label for="s2">משהו לבד מדי פעם</label>
              <input type="radio" id="s3" name="seo" value="פרילנסר" /><label for="s3">פרילנסר</label>
              <input type="radio" id="s4" name="seo" value="סוכנות" /><label for="s4">סוכנות</label>
              <input type="radio" id="s5" name="seo" value="מומחה SEO פנימי" /><label for="s5">מומחה SEO פנימי</label>
            </div>
            <p class="err" id="e-seo" role="alert" hidden></p>
          </div>

          <div class="f">
            <span class="q" id="q-bud">כמה אתם משלמים על זה בחודש היום?</span>
            <div class="opts" role="radiogroup" aria-labelledby="q-bud">
              <input type="radio" id="b1" name="bud" value="₪0" /><label for="b1"><span class="num">₪0</span></label>
              <input type="radio" id="b2" name="bud" value="עד ₪1,500" /><label for="b2">עד <span class="num">₪1,500</span></label>
              <input type="radio" id="b3" name="bud" value="₪1,500 עד ₪4,000" /><label for="b3"><span class="num">₪1,500</span> עד <span class="num">₪4,000</span></label>
              <input type="radio" id="b4" name="bud" value="₪4,000 עד ₪10,000" /><label for="b4"><span class="num">₪4,000</span> עד <span class="num">₪10,000</span></label>
              <input type="radio" id="b5" name="bud" value="מעל ₪10,000" /><label for="b5">מעל <span class="num">₪10,000</span></label>
            </div>
          </div>

          <div class="f">
            <label for="pain">מה הכי מתסכל אתכם בנושא הזה?</label>
            <textarea id="pain" name="pain" placeholder="תכתבו בגלוי · זה עוזר לנו יותר מכל דבר אחר"></textarea>
          </div>
        </fieldset>

        <fieldset class="fs hot">
          <legend>גישה וקצב</legend>

          <div class="note">
            <span class="note-ic" aria-hidden="true">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 8v5M12 16.5v.01"></path></svg>
            </span>
            <span>
              <b>החלק שקובע אם הפיילוט יצליח.</b>
              בלי גישה לנתונים אין ממה למדוד · ובלי מישהו שמאשר, המערכת עוצרת. עדיף שנדע עכשיו.
            </span>
          </div>

          <div class="f">
            <span class="q" id="q-gsc">יש לכם Google Search Console מחובר לחנות? <span class="req">חובה</span></span>
            <div class="opts" role="radiogroup" aria-labelledby="q-gsc">
              <input type="radio" id="g1" name="gsc" value="כן · ואנחנו יכולים לתת הרשאה" /><label for="g1">כן · ואנחנו יכולים לתת הרשאה</label>
              <input type="radio" id="g2" name="gsc" value="כן · אבל ההרשאה אצל מישהו אחר" /><label for="g2">כן · אבל ההרשאה אצל מישהו אחר</label>
              <input type="radio" id="g3" name="gsc" value="לא" /><label for="g3">לא</label>
              <input type="radio" id="g4" name="gsc" value="לא יודעים" /><label for="g4">לא יודעים</label>
            </div>
            <p class="err" id="e-gsc" role="alert" hidden></p>
          </div>

          <div class="f">
            <span class="q" id="q-ga4">יש לכם Google Analytics 4 מחובר לחנות? <span class="req">חובה</span></span>
            <div class="opts" role="radiogroup" aria-labelledby="q-ga4">
              <input type="radio" id="a1" name="ga4" value="כן · ואנחנו יכולים לתת הרשאה" /><label for="a1">כן · ואנחנו יכולים לתת הרשאה</label>
              <input type="radio" id="a2" name="ga4" value="כן · אבל ההרשאה אצל מישהו אחר" /><label for="a2">כן · אבל ההרשאה אצל מישהו אחר</label>
              <input type="radio" id="a3" name="ga4" value="לא" /><label for="a3">לא</label>
              <input type="radio" id="a4" name="ga4" value="לא יודעים" /><label for="a4">לא יודעים</label>
            </div>
            <p class="err" id="e-ga4" role="alert" hidden></p>
          </div>

          <div class="f">
            <span class="q" id="q-inst">תוכלו להתקין אפליקציה בחנות ולתת לה הרשאות? <span class="req">חובה</span></span>
            <div class="opts" role="radiogroup" aria-labelledby="q-inst">
              <input type="radio" id="i1" name="inst" value="כן · אנחנו בעלי החנות" /><label for="i1">כן · אנחנו בעלי החנות</label>
              <input type="radio" id="i2" name="inst" value="כן · דרך המפתח שלנו" /><label for="i2">כן · דרך המפתח שלנו</label>
              <input type="radio" id="i3" name="inst" value="לא בטוחים" /><label for="i3">לא בטוחים</label>
            </div>
            <p class="err" id="e-inst" role="alert" hidden></p>
          </div>

          <div class="f">
            <span class="q" id="q-apr">מי יאשר את התוכן והשינויים · וכמה מהר? <span class="req">חובה</span></span>
            <div class="opts" role="radiogroup" aria-labelledby="q-apr">
              <input type="radio" id="p1" name="apr" value="אני · תוך יום או יומיים" /><label for="p1">אני · תוך יום או יומיים</label>
              <input type="radio" id="p2" name="apr" value="אני · אבל זה יכול לקחת שבוע" /><label for="p2">אני · אבל זה יכול לקחת שבוע</label>
              <input type="radio" id="p3" name="apr" value="מישהו אחר בצוות" /><label for="p3">מישהו אחר בצוות</label>
              <input type="radio" id="p4" name="apr" value="עוד לא יודעים" /><label for="p4">עוד לא יודעים</label>
            </div>
            <p class="err" id="e-apr" role="alert" hidden></p>
          </div>
        </fieldset>

        <fieldset class="fs">
          <legend>התחייבות ופרטים</legend>

          <div class="f">
            <span class="q" id="q-cmt">הפיילוט כולל שיחה חודשית של חצי שעה ופידבק כן. מתאים? <span class="req">חובה</span></span>
            <div class="opts" role="radiogroup" aria-labelledby="q-cmt">
              <input type="radio" id="k1" name="cmt" value="כן" /><label for="k1">כן</label>
