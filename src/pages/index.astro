       top and the header merges with it — no solid strip above the hero. */
    margin-block-start: calc(-1 * var(--sc-header-h, 64px));
    padding-block-start: calc(clamp(52px, 7vw, 104px) + var(--sc-header-h, 64px));
    padding-block-end: clamp(40px, 6vw, 80px);
    overflow-x: clip;
    /* stronger Picktime-style light gradient surface · color lives in the CANVAS, not a blob behind text */
    background:
      radial-gradient(1100px 700px at 82% -14%, rgba(139, 118, 242, .32), transparent 62%),
      radial-gradient(860px 620px at -8% 34%, rgba(85, 70, 214, .13), transparent 55%),
      linear-gradient(180deg, #e9e4fa 0%, var(--sc-paper) 82%);
  }
  :global([data-theme='dark']) .hero {
    background:
      radial-gradient(1100px 700px at 82% -14%, rgba(139, 118, 242, .2), transparent 62%),
      radial-gradient(860px 620px at -8% 34%, rgba(85, 70, 214, .14), transparent 55%),
      linear-gradient(180deg, #221c3a 0%, var(--sc-paper) 82%);
  }
  .hero-in {
    max-inline-size: 1200px; margin-inline: auto;
    padding-inline: clamp(18px, 5vw, 48px);
    display: grid;
    grid-template-columns: minmax(0, 6.4fr) minmax(0, 5.6fr);
    gap: clamp(24px, 4vw, 56px);
    align-items: end;
  }
  /* hero install/demo pair sits SIDE-BY-SIDE like the final section (same-size
     buttons, differ only by fill); stacks only on small mobile (handled in the
     component's own ≤480px rule). */
  /* 560, not 481: below this the two 232px buttons don't fit side-by-side, so let
     them wrap/stack instead of getting clipped by the hero's overflow-x:clip. */
  @media (min-width: 560px) {
    .hero-side :global(.cta-pair) { flex-wrap: nowrap; }
  }
  .hero h1 {
    font-size: clamp(38px, 6.2vw, 68px);
    font-weight: 900;
    line-height: 1.04;
    letter-spacing: -.025em;
  }
  /* the payoff line · the brand gradient carries the "automatic, today" promise */
  .grad-word {
    background: var(--sc-grad); -webkit-background-clip: text; background-clip: text;
    color: transparent; -webkit-text-fill-color: transparent;
  }
  .hero-side { padding-block-end: 10px; }
  .sub { font-size: clamp(16px, 1.8vw, 19px); color: var(--sc-mv); margin-block-end: 20px; max-inline-size: 44ch; }
  .sub strong { color: var(--sc-ink); font-weight: 700; }

  /* ═══ SHOWCASE · dedicated, centered, near-full-width dashboard ═══ */
  .showcase {
    position: relative;
    padding-block: clamp(48px, 7vw, 104px);
    /* soft continuation of the hero wash so the section feels intentional */
    background: linear-gradient(180deg, var(--sc-paper) 0%, var(--sc-paper) 100%);
    overflow-x: clip;
  }
  /* stage · centered, large; the tilt is balanced around the center */
  .stage {
    max-inline-size: 1240px; margin-inline: auto;
    padding-inline: clamp(18px, 5vw, 56px);
    position: relative;
    z-index: 2;
    /* leave room for the escaping live-answer card + tilt without clipping */
    padding-block-end: clamp(40px, 6vw, 96px);
  }
  .tilt-wrap {
    position: relative;
    /* much larger · near full container width, with breathing room, centered */
    max-inline-size: 1080px;
    margin-inline: auto;
    transform: translateY(var(--py, 0));
  }
  .tilt {
    /* balanced tilt · symmetric origin so it reads centered, not drifting */
    transform: perspective(2000px) rotateX(6deg) rotateY(-6deg) rotate(.5deg);
    transform-origin: 50% 30%;
    border-radius: 19px;
    box-shadow:
      0 2px 4px rgba(29, 29, 31, .06),
      0 28px 56px -26px rgba(33, 28, 134, .4),
      0 72px 140px -54px rgba(29, 29, 31, .4);
    transition: transform 420ms var(--sc-ease);
  }
  .tilt-wrap:hover .tilt { transform: perspective(2000px) rotateX(3deg) rotateY(-3deg) rotate(.25deg); }
  @media (prefers-reduced-motion: reduce) { .tilt, .tilt-wrap:hover .tilt { transform: perspective(2000px) rotateX(6deg) rotateY(-6deg) rotate(.5deg); } }
  /* the dashboard itself scales up inside the larger stage */
  .tilt :global(.dm) { font-size: 1.06em; }

  /* floating live answer · escapes the frame */
  .live {
