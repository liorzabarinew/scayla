  .wr-line { font-size: 13px; line-height: 1.65; color: var(--sc-muted); }
  /* the typing hint · a soft blinking caret at the end of the line */
  .wr-caret {
    display: inline-block; inline-size: 2px; block-size: .95em;
    margin-inline-start: 2px; vertical-align: text-bottom;
