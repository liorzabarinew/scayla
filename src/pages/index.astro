<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const hasIO = 'IntersectionObserver' in window;

  /* ── dashboard "loads" on scroll · gauge arc + staggered count-ups ──
     The numbers count UP from 0 to illustrate results rising. Springy ease-out,
     staggered. Reduced-motion / no-IO → final values shown immediately. */
  const dm = document.querySelector<HTMLElement>('.dm');
  if (dm) {
    const gnum = dm.querySelector<HTMLElement>('[data-dm-gauge-num]');
    // every other rising number in the mockup (visits, analysis %, ▲+6, +18%)
    const dmCounts = Array.from(dm.querySelectorAll<HTMLElement>('[data-dm-count]'));
    const fmt = (el: HTMLElement, v: number) =>
      el.hasAttribute('data-group') ? v.toLocaleString('en-US') : String(v);
    // near-target start so a counter caught mid-scroll never shows a big "0"
    const nearStart = (to: number) => Math.max(0, Math.min(to - 1, Math.round(to * 0.62)));

    const animateCount = (el: HTMLElement, from: number, to: number, dur: number, delay: number) => {
      const t0 = performance.now() + delay;
      const tick = (t: number) => {
        if (t < t0) { requestAnimationFrame(tick); return; }
        const p = Math.min(1, (t - t0) / dur);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = fmt(el, Math.round(from + (to - from) * eased));
        if (p < 1) requestAnimationFrame(tick);
        else el.textContent = fmt(el, to);
      };
      requestAnimationFrame(tick);
    };

    if (reduce || !hasIO) {
      dm.classList.add('in');
      // final values already in the DOM · nothing to reset
    } else {
      // rewind to near-target start values (never 0)
      const gTarget = Number(dm.querySelector<HTMLElement>('[data-dm-gauge]')?.dataset.target || '34');
      if (gnum) gnum.textContent = String(nearStart(gTarget));
      dmCounts.forEach((el) => { el.textContent = fmt(el, nearStart(Number(el.dataset.to || '0'))); });

      let done = false;
      const settle = () => {
        done = true;
        if (gnum) gnum.textContent = String(gTarget);
        dmCounts.forEach((el) => { el.textContent = fmt(el, Number(el.dataset.to || '0')); });
        dm.classList.add('in');
      };

      const io = new IntersectionObserver((es) => {
        es.forEach((e) => {
          if (!e.isIntersecting || done) return;
          done = true;
          io.disconnect();
          window.clearTimeout(fallbackT);
          dm.classList.add('in'); // fires arc + progress bar (CSS)

          // gauge headline · near-target → 34 over 1300ms (matches the arc)
          if (gnum) {
            const gFrom = nearStart(gTarget);
            const t0 = performance.now();
            const tick = (t: number) => {
              const p = Math.min(1, (t - t0) / 1300);
              gnum.textContent = String(Math.round(gFrom + (gTarget - gFrom) * (1 - Math.pow(1 - p, 3))));
              if (p < 1) requestAnimationFrame(tick);
              else gnum.textContent = String(gTarget);
            };
            requestAnimationFrame(tick);
          }

          // the rest · staggered so results appear to rise one after another
          dmCounts.forEach((el, i) => {
            const to = Number(el.dataset.to || '0');
            animateCount(el, nearStart(to), to, 1100, 220 + i * 160);
          });
        });
      }, { threshold: 0.2 });
      io.observe(dm);
      // guaranteed settle-to-final if the observer never fires
      const fallbackT = window.setTimeout(() => { if (!done) { io.disconnect(); settle(); } }, 4000);
    }
  }

  /* ── subtle hero parallax · transform only, rAF-throttled ── */
  const par = document.querySelector<HTMLElement>('[data-parallax]');
  if (par && !reduce) {
    let raf = 0;
    const onScroll = () => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        raf = 0;
        const y = Math.min(window.scrollY, 700);
        par.style.setProperty('--py', `${y * -0.045}px`);
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  /* ── rotating question word ──
     The width is always fitted to the CURRENT word (so the glued "?" hugs it);
     the rotation itself runs only when motion is allowed. */
  const rot = document.querySelector<HTMLElement>('[data-rot]');
  if (rot) {
    const words = Array.from(rot.querySelectorAll('b'));
    let i = 0;
    const fit = () => rot.style.setProperty('--rw', `${words[i].offsetWidth}px`);
    rot.classList.add('managed');
    fit();
    window.addEventListener('resize', fit, { passive: true });
    if (!reduce) {
      setInterval(() => {
        words[i].classList.remove('on');
        i = (i + 1) % words.length;
        words[i].classList.add('on');
        fit();
      }, 2600);
    }
  }

  /* ── THE CLIMB · your store overtakes מתחרה שתיים, then מתחרה אחד ──
     HTML ships the FINAL 1st-place state (no-JS + reduced-motion safe).
     With motion: rewind to the start grid, fill bars on scroll-into-view,
     then two staggered overtakes (transform swaps + count-up + bar growth). */
  const climb = document.querySelector<HTMLElement>('[data-climb]');
  if (climb) {
    const rows = Array.from(climb.querySelectorAll<HTMLElement>('.rb'));
    const selfRow = climb.querySelector<HTMLElement>('.rb.self');
    const W = 2.4; // pct → bar-width scale
    const setPct = (row: HTMLElement, pct: number) =>
      row.style.setProperty('--pct', `${(pct * W).toFixed(1)}%`);

    if (reduce || !hasIO || !selfRow) {
      climb.classList.add('go', 'crowned');
    } else {
      // rewind to the start state
      rows.forEach((r) => {
        r.style.setProperty('--slot', r.dataset.startSlot || '0');
        setPct(r, Number(r.dataset.startPct || '0'));
        const v = r.querySelector('[data-val]');
        if (v) v.textContent = r.dataset.startPct || '0';
      });

      const selfVal = selfRow.querySelector<HTMLElement>('[data-val]');
      const countTo = (from: number, to: number, dur = 560) => {
        const t0 = performance.now();
        const tick = (t: number) => {
          const p = Math.min(1, (t - t0) / dur);
          if (selfVal) selfVal.textContent = String(Math.round(from + (to - from) * (1 - Math.pow(1 - p, 3))));
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };

      const bySlot = (s: string) => rows.find((r) => r.dataset.startSlot === s);
      const comp1 = bySlot('0');
      const comp2 = bySlot('1');
      const mid = 25;
      const fin = Number(selfRow.dataset.finalPct || '34');

      const io = new IntersectionObserver((es) => {
        es.forEach((e) => {
          if (!e.isIntersecting) return;
          io.disconnect();
          climb.classList.add('go'); // bars fill, staggered by lane

          window.setTimeout(() => { // overtake #1 · past מתחרה שתיים
            selfRow.style.setProperty('--d', '0ms');
            selfRow.style.setProperty('--slot', '1');
            comp2?.style.setProperty('--slot', '2');
            setPct(selfRow, mid);
            countTo(Number(selfRow.dataset.startPct || '12'), mid);
          }, 1350);

          window.setTimeout(() => { // overtake #2 · past מתחרה אחד → מקום 1
            selfRow.style.setProperty('--slot', '0');
            comp1?.style.setProperty('--slot', '1');
            setPct(selfRow, fin);
            countTo(mid, fin);
            window.setTimeout(() => climb.classList.add('crowned'), 640);
          }, 2500);
        });
      }, { threshold: 0.45 });
      io.observe(climb);
    }
  }

  /* ── count-ups (race stat + proof cell) ──
     The FINAL value already ships in the HTML (resting / no-JS state is never "0").
     With motion: rewind only to a near-target start (~62% of target, min target-3)
     so a counter caught mid-scroll never shows a big "0", then animate the last
     stretch on scroll-in. A guaranteed settle-to-final fallback covers the case
     where the IntersectionObserver never fires. */
  const counters = document.querySelectorAll<HTMLElement>('[data-count]');
  const runCount = (el: HTMLElement, from: number, target: number) => {
    const t0 = performance.now();
    const tick = (t: number) => {
      const p = Math.min(1, (t - t0) / 900);
      el.textContent = String(Math.round(from + (target - from) * (1 - Math.pow(1 - p, 3))));
      if (p < 1) requestAnimationFrame(tick);
      else el.textContent = String(target);
    };
    requestAnimationFrame(tick);
  };
  counters.forEach((el) => {
    const target = Number(el.dataset.count || '0');
    if (reduce || !hasIO) { el.textContent = String(target); return; }
    // start near the target, never at 0
    const from = Math.max(0, Math.min(target - 1, Math.round(target * 0.62)));
    el.textContent = String(from);
    let done = false;
    const settle = () => { done = true; el.textContent = String(target); };
    const io = new IntersectionObserver((es) => {
      es.forEach((e) => {
        if (!e.isIntersecting || done) return;
        done = true;
        io.disconnect();
        window.clearTimeout(fallbackT);
        runCount(el, from, target);
      });
    }, { threshold: 0.2 });
    io.observe(el);
    // guaranteed settle-to-final if the observer never fires (e.g. never scrolled into view fully)
    const fallbackT = window.setTimeout(() => { if (!done) { io.disconnect(); settle(); } }, 4000);
  });
</script>

<style>
  .fine { font-size: 13px; color: var(--sc-disabled); margin-block-start: 16px; }

  /* ═══ HERO ═══ */
