  .wr-skel i { display: block; block-size: 7px; border-radius: 999px; background: var(--sc-div); inline-size: var(--w, 80%); }
  .wr-b { font-size: 11.5px; font-weight: 700; color: var(--sc-pos-deep); margin-block-start: 11px; padding-block-start: 10px; border-block-start: 1px solid var(--sc-div); }

  @media (max-width: 900px) {
    .hero-in { grid-template-columns: 1fr; align-items: start; }
