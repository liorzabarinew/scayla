---
/**
 * ═══ Homepage · "The Answer Engine" (v2-bold, promoted to canonical /) ═══
 * Editorial-tech, daring layout, Apple-clean components:
 * · strong (but light) Picktime-style gradient hero surface
 * · giant editorial headline, offset to the inline-start · not centered
 * · the REAL dashboard tilted in 3D perspective, OVERLAPPING into the next section
 * · a floating live-AI-answer card (brand green / absent red) escaping the mockup
 * · a diagonal-cut full-bleed gradient band with an ANIMATED RANKING CLIMB ·
 *   "החנות שלכם" rises 3 → 1 on scroll (reduced-motion → final state)
 * · an unequal bento for the specialized team ("עשרות עובדים") + a rotated sharp "ticket"
 * · soft gold (--accent-gold) = the warm complementary accent: primary CTA, "בקרוב"/live badges
 *   (green = positive only, red = negative only · gold is decorative-safe and distinct from both)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import DashboardMock from '../components/DashboardMock.astro';
import InstallCtaPair from '../components/InstallCtaPair.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import { homeFaq } from '../data/faq';

// Meta per Noy (question 3): title ≤60 chars, description ≤130 chars
const title = 'קידום אורגני בגוגל ובמנועי AI לחנויות · Scayla';
const description =
  'מודדים אם ChatGPT מצטט את החנות שלכם, משווים למתחרים בעברית, וסוגרים את הפער אוטומטית. 14 יום ניסיון.';

// Schema per Noy (question 9): Organization + WebSite (with SearchAction) on home.
// SoftwareApplication + the 3 Offers live on /pricing. FAQPage lives on /faq.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://scayla.co.il/#org',
      name: 'Scayla',
      url: 'https://scayla.co.il',
      logo: 'https://scayla.co.il/favicon.svg',
      founder: [
        { '@type': 'Person', name: 'ליאור צברי' },
        { '@type': 'Person', name: 'נוי קייטל' },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://scayla.co.il/#website',
      name: 'Scayla',
      url: 'https://scayla.co.il',
      inLanguage: 'he',
      publisher: { '@id': 'https://scayla.co.il/#org' },
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: 'https://scayla.co.il/magazine?q={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};

const rotWords = ['נעלי ריצה', 'מנורות לסלון', 'שמלת ערב', 'מזון לכלבים', 'מתנה ללידה'];

// the ranking climb · DOM order = FINAL ranking (no-JS / reduced-motion state).
// JS rewinds to startSlot/startPct, then plays the overtake on scroll-into-view.
// bar width = pct · 2.4 so the leader nearly fills the track.
const board = [
  { name: 'החנות שלכם', self: true, finalPct: 34, startPct: 12, startSlot: 2, slot: 0 },
  { name: 'מתחרה אחד', self: false, finalPct: 29, startPct: 29, startSlot: 0, slot: 1 },
  { name: 'מתחרה שתיים', self: false, finalPct: 22, startPct: 22, startSlot: 1, slot: 2 },
];

// the specialized team · beyond the three featured workers (no "סוכן" anywhere)
const team = [
  { name: 'מומחה SEO', desc: 'מילות מפתח שמנצחות בגוגל', icon: 'seo' },
  { name: 'QA', desc: 'כל שינוי נבדק לפני שהוא עולה', icon: 'qa' },
  { name: 'הגהה', desc: 'אפס שגיאות כתיב ופיסוק', icon: 'proof' },
  { name: 'עורך לשוני', desc: 'עברית תקנית, משפט אחר משפט', icon: 'editor' },
  { name: 'אנליסט נתונים', desc: 'הופך נתונים להחלטות', icon: 'data' },
  { name: 'עיצוב', desc: 'כל עמוד נראה מותג', icon: 'design' },
  { name: 'חווית משתמש', desc: 'מסע קנייה חלק שממיר', icon: 'ux' },
];
---

<BaseLayout title={title} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- ═══ HERO · gradient surface, editorial type, tilted overlapping product ═══ -->
  <section class="hero">
    <div class="hero-in">
      <h1>
        הקידום האורגני<br />
        של החנות שלכם.<br />
        <span class="grad-word">אוטומטי. מהיום.</span>
      </h1>
      <div class="hero-side">
        <p class="sub" dir="rtl">
          Scayla מתחברת לאתר שלכם בקליק, לומדת את החנות לעומק, ומקדמת אתכם גם
          בגוגל וגם במנועי AI. בלי סוכנות יקרה, בלי צורך במומחים, <strong>ובעד
          <span class="num">80%</span> פחות מריטיינר ממוצע.</strong>
        </p>
        <InstallCtaPair gold />
      </div>
    </div>

  </section>

  <!-- ═══ SHOWCASE · the REAL dashboard · its own generous section, centered & large ═══ -->
  <section class="showcase" aria-label="הדשבורד של Scayla">
    <div class="stage">
      <div class="tilt-wrap fade-up" data-parallax>
        <div class="tilt">
          <DashboardMock />
        </div>
        <!-- floating live answer · green = you exist, red = the gap -->
        <aside class="live" aria-label="דוגמה לתשובת AI חיה">
          <p class="live-top"><span class="lv-dot" aria-hidden="true"></span>תשובה חיה · Gemini</p>
          <p class="live-q">"איפה הכי כדאי לקנות מנורות מעוצבות?"</p>
          <p class="live-a">אפשרות מצוינת היא <span class="hl-grn">החנות שלכם</span>, עם מדריכי קנייה מפורטים ודירוגים גבוהים, וגם <span class="hl-red">מתחרה אחד</span> עם מבחר דומה.</p>
          <p class="live-b">Scayla שמה אתכם בתשובה · ועוקבת שתישארו</p>
        </aside>
        <!-- floating content-writer card · the machine writing an article, live -->
        <aside class="writer" aria-label="דוגמה לכתיבת מאמר אוטומטית">
          <p class="wr-top">
            <span class="wr-ic" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 20l4.5-1L18 9.5a2.1 2.1 0 0 0-3-3L5.5 16z"/><path d="M14 6.5l3 3"/></svg>
            </span>
            כותבת התוכן · עובדת עכשיו<span class="lv-dot" aria-hidden="true"></span>
          </p>
          <p class="wr-t">כותבת מאמר · "המדריך המלא למנורות לסלון"</p>
          <p class="wr-line">בוחרים גובה תלייה לפי פינת האוכל, ומתאימים גוון אור לסלון<span class="wr-caret" aria-hidden="true"></span></p>
          <span class="wr-skel" aria-hidden="true"><i style="--w:84%"></i><i style="--w:58%"></i></span>
          <p class="wr-b">הטיוטה תחכה לאישור שלכם · לא עולה בלעדיכם</p>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══ THE QUESTION · editorial rotating marquee ═══ -->
  <section id="how" class="q-sec">
    <div class="wrap q-grid">
      <div class="q-text">
        <p class="q-kicker fade-up">כל קנייה מתחילה היום באותו משפט</p>
        <p class="q-line fade-up" aria-live="off">
          "איפה הכי כדאי לקנות
          <span class="q-tail"><span class="rot" data-rot>
            {rotWords.map((w, i) => <b class:list={[{ on: i === 0 }]}>{w}</b>)}
          </span><span class="qm">?"</span></span>
        </p>
        <p class="q-intro fade-up">
          Scayla לא רק בודקת אם אתם מופיעים בתשובה · היא גם עושה את העבודה שתכניס
          אתכם אליה. כותבת לכם מאמר, משנה כותרות, מתקנת עמודים ועוד · הכל בעברית של
          הקונים שלכם, והכל מחכה לאישור שלכם. לא סתם מכונת סריקה · גם הכוח שמזיז.
        </p>
      </div>
      <div class="q-foot fade-up">
        <div class="engines" role="list" aria-label="מנועי ה-AI הנמדדים">
          <p class="eng-lead">המנועים שאנחנו מודדים</p>
          <span class="eng is-live" role="listitem">
            <span class="eng-logo" aria-hidden="true">
              {/* brand logos — replace with official assets before launch */}
              {/* OpenAI / ChatGPT mark */}
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.28 9.82a5.98 5.98 0 0 0-.52-4.91 6.05 6.05 0 0 0-6.51-2.9A6 6 0 0 0 4.98 4.18a5.98 5.98 0 0 0-3.99 2.9 6.05 6.05 0 0 0 .74 7.1 5.98 5.98 0 0 0 .51 4.91 6.05 6.05 0 0 0 6.52 2.9A5.98 5.98 0 0 0 13.26 24a6.06 6.06 0 0 0 5.77-4.2 5.99 5.99 0 0 0 4-2.9 6.06 6.06 0 0 0-.75-7.08Zm-9.02 12.6a4.48 4.48 0 0 1-2.88-1.04l.14-.08 4.78-2.76a.79.79 0 0 0 .39-.68v-6.74l2.02 1.17a.07.07 0 0 1 .04.05v5.58a4.5 4.5 0 0 1-4.49 4.49ZM3.6 18.3a4.47 4.47 0 0 1-.54-3.01l.14.08 4.78 2.76c.24.14.54.14.78 0l5.84-3.37v2.33a.08.08 0 0 1-.03.06L9.74 20a4.5 4.5 0 0 1-6.14-1.65ZM2.34 7.9a4.48 4.48 0 0 1 2.34-1.97v5.68c0 .28.15.54.39.68l5.83 3.36-2.02 1.17a.08.08 0 0 1-.07 0l-4.83-2.79A4.5 4.5 0 0 1 2.34 7.9Zm16.6 3.86-5.84-3.37 2.02-1.16a.08.08 0 0 1 .07 0l4.83 2.78a4.49 4.49 0 0 1-.68 8.1v-5.67a.79.79 0 0 0-.4-.68Zm2.01-3.02-.14-.09-4.77-2.78a.78.78 0 0 0-.79 0L9.42 9.24V6.9a.07.07 0 0 1 .03-.06l4.83-2.79a4.5 4.5 0 0 1 6.68 4.66ZM8.32 12.87 6.3 11.7a.08.08 0 0 1-.04-.06V6.07a4.5 4.5 0 0 1 7.37-3.45l-.14.08L8.71 5.46a.79.79 0 0 0-.4.68l.01 6.73Zm1.1-2.36 2.6-1.5 2.6 1.5v3l-2.6 1.5-2.6-1.5v-3Z"/></svg>
            </span>
            <span class="eng-nm">ChatGPT</span>
            <i class="live-dot" aria-hidden="true"></i>
            <span class="eng-state live-txt">מנוטר</span>
          </span>
          <span class="eng is-live" role="listitem">
            <span class="eng-logo" aria-hidden="true">
              {/* brand logos — replace with official assets before launch */}
              {/* Google Gemini spark */}
              <svg viewBox="0 0 24 24" fill="url(#gemGrad)" aria-hidden="true"><defs><linearGradient id="gemGrad" x1="2" y1="20" x2="22" y2="4" gradientUnits="userSpaceOnUse"><stop stop-color="#1C7DFF"/><stop offset="0.52" stop-color="#7B5CFF"/><stop offset="1" stop-color="#D96570"/></linearGradient></defs><path d="M12 0c.34 4.42 1.72 7.62 4.13 9.87C18.38 12.28 21.58 13.66 24 12c-4.42.34-7.62 1.72-9.87 4.13C11.72 18.38 10.34 21.58 12 24c-.34-4.42-1.72-7.62-4.13-9.87C5.62 11.72 2.42 10.34 0 12c4.42-.34 7.62-1.72 9.87-4.13C12.28 5.62 13.66 2.42 12 0Z"/></svg>
            </span>
            <span class="eng-nm">Gemini</span>
            <i class="live-dot" aria-hidden="true"></i>
            <span class="eng-state live-txt">מנוטר</span>
          </span>
          <span class="eng soon" role="listitem">
            <span class="eng-logo" aria-hidden="true">
              {/* brand logos — replace with official assets before launch */}
              {/* Anthropic / Claude mark */}
              <svg viewBox="0 0 24 24" fill="#D97757" aria-hidden="true"><path d="M4.7 15.9 9 13.5l.07-.2-.07-.12H8.8l-.68-.04-2.32-.06-2.01-.08-1.95-.11-.49-.11L1.4 12l.05-.3.41-.28.59.05 1.3.09 1.95.13 1.42.09 2.1.21h.33l.05-.13-.11-.08-.09-.08-2-1.36-2.17-1.43-1.14-.83-.61-.42-.31-.39-.13-.86.56-.61.75.05.19.06 1.29.53.98.76 1.28.94.9.66.1.08.05-.03.02-.02-.05-.09-.42-.75-1.42-2.46-1.51-2.5-.67-1.08-.18-.65a3.1 3.1 0 0 1-.11-.77l.64-.86L4 .28l.83.11.35.3.51 1.18 1.86 4.09 1.46 3.16.42.85.23.79.08.24h.15v-.14l.12-1.62.22-1.98.22-2.55.07-.72.36-.86.71-.47.56.27.46.66-.06.42-.28 1.8-.53 2.75-.35 1.84h.2l.24-.23.96-1.27 1.62-2.02.71-.8.84-.9.53-.42h1l.75 1.1-.34 1.14-1.04 1.32-.87 1.12-1.24 1.67-.78 1.34.07.11.19-.02 2.83-.6 1.53-.28 1.83-.32.83.4.09.39-.33.8-1.95.48-2.29.46-3.42.8-.04.03.05.06 1.53.14.66.04h1.61l3 .22.79.52.47.63-.08.48-1.21.62-1.63-.39-3.8-.9-1.31-.33h-.18v.11l1.09 1.06 2 1.8 2.5 2.33.13.58-.32.46-.34-.05-2.2-1.65-.84-.75-1.92-1.61h-.13v.17l.44.65 2.34 3.52.12 1.08-.17.35-.6.22-.67-.13-1.37-1.93-1.42-2.17-1.14-1.95-.14.08-.68 7.28-.32.37-.73.28-.61-.46-.32-.75.32-1.48.39-1.93.32-1.53.28-1.9.17-.63-.01-.04-.14.01-1.43 1.96-2.17 2.94-1.72 1.83-.41.17-.71-.37.07-.66.4-.58 2.36-3 1.42-1.86.92-1.07-.01-.16h-.05L6.25 18.6l-1.55.2-.66-.62.08-1.02.31-.33 2.6-1.78Z"/></svg>
            </span>
            <span class="eng-nm">Claude</span>
            <span class="soon-tag">בקרוב</span>
          </span>
          <span class="eng soon" role="listitem">
            <span class="eng-logo" aria-hidden="true">
              {/* brand logos — replace with official assets before launch */}
              {/* Perplexity mark */}
              <svg viewBox="0 0 24 24" fill="none" stroke="#20808D" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3.2 19 8v8l-7 4.8L5 16V8l7-4.8Z"/><path d="M12 3.2v17.6M5 8l7 4.8L19 8M5 16l7-4.8 7 4.8"/></svg>
            </span>
            <span class="eng-nm">Perplexity</span>
            <span class="soon-tag">בקרוב</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ THE CLIMB · diagonal full-bleed gradient, your store rises 3 → 1 ═══ -->
  <section class="race-sec">
    <div class="wrap race-grid">
      <div class="race-copy">
        <p class="r-kicker">מרוץ נתח-הקול</p>
        <h2>על כל שאלה יש מרוץ.<br />Scayla מביאה אתכם ראשונים.</h2>
        <p class="r-sub">
          כשקונה שואל "איפה כדאי לקנות", גוגל וה-AI בוחרים שם אחד או שניים · וכל
          השאר נשארים בחוץ. זה מה שקורה, וזה בדיוק מה ש-Scayla פותרת: היא מודדת
          איפה אתם מול המתחרים האמיתיים שלכם, ואז מטפסת אתכם לראש · שאלה אחר שאלה.
        </p>
        <div class="r-stat">
          <span class="r-num num"><b data-count="34">34</b>%</span>
          <span class="r-lbl">מהתשובות כבר מזכירות אתכם · <b class="num">▲ +6</b> מאז ההתקנה</span>
        </div>
      </div>

      <div class="climb" data-climb>
        <div class="lanes" aria-hidden="true">
          <span class="num">1</span><span class="num">2</span><span class="num">3</span>
        </div>
        <ol class="board">
          {board.map((r) => (
            <li
              class:list={['rb', { self: r.self }]}
              style={`--slot:${r.slot}; --pct:${(r.finalPct * 2.4).toFixed(1)}%; --d:${r.startSlot * 140}ms`}
              data-start-slot={r.startSlot}
              data-start-pct={r.startPct}
              data-final-pct={r.finalPct}
            >
              <span class="rb-name">
                <span class="rb-nm">{r.name}{r.self && <em>אתם</em>}</span>
                {r.self && (
                  <span class="rank-badge">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                    מקום <b class="num">1</b>
                  </span>
                )}
              </span>
              <span class="rb-track"><i></i></span>
              <span class="rb-val num"><b data-val>{r.finalPct}</b>%</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- ═══ THE MACHINE · unequal bento ═══ -->
  <section id="features" class="bento-sec">
    <div class="wrap">
      <div class="b-head fade-up">
        <p class="q-kicker">המכונה</p>
        <h2 class="b-big"><span class="tens">תכירו</span> את הצוות<br />שלא ישן.</h2>
        <p class="b-sub b-lead">בודק, מתקן, מעדכן · הכל מסביב לשעון.</p>
        <p class="b-sub b-choice">אתם בוחרים · לתת לצוות לעבוד עצמאית, או לאשר כל פעולה לפני שהיא יוצאת.</p>
      </div>

      <div class="bento">
        <!-- content writer · the big cell -->
        <article class="cell cell-writer fade-up">
          <div class="c-top">
            <span class="c-ic" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20l4.5-1L18 9.5a2.1 2.1 0 0 0-3-3L5.5 16z"/><path d="M14 6.5l3 3"/></svg>
            </span>
            <h3>כותב התוכן</h3>
          </div>
          <p class="c-p">מאמרים ו-FAQ מבוססי מחקר, בעברית תקנית שה-AI אוהב לצטט · בדיוק בשאלות שבהן נעדרתם.</p>
          <div class="draft" aria-hidden="true">
            <p class="d-t">מדריך בחירת נעלי ריצה 2026</p>
            <span class="d-l" style="--w:96%"></span>
            <span class="d-l" style="--w:88%"></span>
            <span class="d-l" style="--w:71%"></span>
            <span class="d-badge">טיוטה מוכנה · ממתינה לאישור</span>
          </div>
        </article>

        <!-- researcher -->
        <article class="cell cell-research fade-up">
          <div class="c-top">
            <span class="c-ic" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="6.5"/><path d="M20 20l-4.2-4.2"/></svg>
            </span>
            <h3>החוקרת</h3>
          </div>
          <p class="c-p">סורקת תשובות AI ודירוגי גוגל ומזהה איפה המתחרים לוקחים לכם קונים.</p>
          <p class="c-out"><b class="num">8</b> מילות מפתח צעד מעמוד 1</p>
        </article>

        <!-- technical · the rotated sharp ticket -->
        <article class="cell cell-tech fade-up">
          <div class="c-top">
            <span class="c-ic" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 6.5a3.5 3.5 0 0 0-4.9 4.2L4 16.3V20h3.7l5.6-5.6a3.5 3.5 0 0 0 4.2-4.9l-2.5 2.5-2.1-2.1z"/></svg>
            </span>
            <h3>טכני</h3>
          </div>
          <p class="c-p">סכמות, מטא ותיקוני 301 · בלי שתגעו בקוד.</p>
          <p class="c-out fix"><b class="num">5</b> תיקוני 404 מוכנים <span class="ok" aria-hidden="true">✓</span></p>
        </article>

        <!-- the rest of the team · seven more specialists -->
        <article class="cell cell-team fade-up">
          <p class="tm-k">ועוד בצוות · כל אחד מומחה בתחום אחד</p>
          <div class="tm-grid">
            {team.map((t) => (
              <div class="tm">
                <span class="tm-ic" aria-hidden="true">
                  {t.icon === 'seo' && (
