---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import { authorMap } from '../../data/experts';
import { clusterPath } from '../../content.config';

export async function getStaticPaths() {
  const posts = await getCollection('magazine', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const fmt = new Intl.DateTimeFormat('he-IL', { day: 'numeric', month: 'long', year: 'numeric' });

// Table of contents · top-level H2 headings only (silo-friendly, not too deep).
const toc = headings.filter((h) => h.depth === 2);

// Byline · resolve author name → expert profile (name, role, url, bioShort).
const author = post.data.author ? authorMap[post.data.author] : undefined;

// ── Hero header · full-width gradient cover band with the title composed over it. ──
// Now the DEFAULT for every article. Cover art lives at /covers/<slug>.webp (generated
// by the content machine); if it is missing, the band falls back to a deep-indigo ground.
const useHero = true;
const heroCover = post.data.coverImage || `/covers/${post.id}.webp`;

// Key takeaways · explicit frontmatter, else derive from the first H2 headings.
const takeaways =
  post.data.takeaways && post.data.takeaways.length > 0
    ? post.data.takeaways
    : toc.slice(0, 3).map((h) => h.text);

// Related · same cluster first (silo internal linking), then newest · up to 3 cards.
const related = (await getCollection('magazine', ({ data }) => !data.draft))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => {
    const sameA = a.data.cluster === post.data.cluster ? 1 : 0;
    const sameB = b.data.cluster === post.data.cluster ? 1 : 0;
    if (sameA !== sameB) return sameB - sameA;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 3);

const postUrl = new URL(`/magazine/${post.id}`, Astro.site).href;
const clusterUrl = clusterPath(post.data.cluster);

// Article schema · Person author (E-E-A-T) when set, else the Organization.
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  inLanguage: 'he',
  articleSection: post.data.cluster,
  ...(post.data.coverImage && { image: new URL(post.data.coverImage, Astro.site).href }),
  author: author
    ? { '@type': 'Person', name: author.name, url: new URL(author.url, Astro.site).href }
    : { '@type': 'Organization', name: 'Scayla', url: 'https://scayla.co.il/' },
  publisher: { '@type': 'Organization', name: 'Scayla', url: 'https://scayla.co.il/' },
  mainEntityOfPage: postUrl,
};

// Share targets · WhatsApp / X / LinkedIn (copy-link is client-side).
const enc = encodeURIComponent;
const shareText = post.data.title;
const share = {
  whatsapp: `https://wa.me/?text=${enc(`${shareText} · ${postUrl}`)}`,
  x: `https://twitter.com/intent/tweet?text=${enc(shareText)}&url=${enc(postUrl)}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${enc(postUrl)}`,
};
---

<BaseLayout
  title={`${post.data.title} · Scayla`}
  description={post.data.description}
  ogType="article"
  ogImage={heroCover}
  ogImageAlt={post.data.title}
  ogImageWidth={1600}
  ogImageHeight={760}
  breadcrumbs={[
    { name: 'בלוג', path: '/magazine' },
    { name: post.data.cluster, path: clusterUrl },
    { name: post.data.title, path: `/magazine/${post.id}` },
  ]}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleLd)} />

  <div class="progress" aria-hidden="true"><span class="progress-bar" id="reading-progress"></span></div>

  <article class={`post ${useHero ? 'has-hero' : ''}`}>
    {useHero ? (
      <header class="hero" style={`--hero-img:url('${heroCover}')`}>
        <div class="hero-art" aria-hidden="true"></div>
        <div class="hero-inner wrap">
          <nav class="hero-crumbs" aria-label="פירורי לחם">
            <a href="/magazine">בלוג</a>
            <span aria-hidden="true">‹</span>
            <a href={clusterUrl}>{post.data.cluster}</a>
          </nav>
          <div class="hero-foot">
            <a class="hero-pill" href={clusterUrl}>{post.data.cluster}</a>
            <h1>{post.data.title}</h1>
            <div class="hero-meta">
              <time datetime={post.data.pubDate.toISOString()}>{fmt.format(post.data.pubDate)}</time>
              {post.data.updatedDate && (
                <>
                  <span aria-hidden="true">·</span>
                  <span>עודכן <time datetime={post.data.updatedDate.toISOString()}>{fmt.format(post.data.updatedDate)}</time></span>
                </>
              )}
              <span aria-hidden="true">·</span>
              <span><span class="num">{post.data.readingMinutes}</span> דקות קריאה</span>
            </div>
            {author && (
              <a class="hero-byline" href={author.url} aria-label={`המחבר · ${author.name}`}>
                <span class="by-av" aria-hidden="true">{author.initial}</span>
                <span class="by-txt">
                  <span class="by-name">{author.name}</span>
                  <span class="by-role">{author.role}</span>
                </span>
              </a>
            )}
          </div>
        </div>
      </header>
    ) : (
      <>
        <header class="post-head">
          <div class="narrow center">
            <nav class="crumbs" aria-label="פירורי לחם">
              <a href="/magazine">בלוג</a>
              <span aria-hidden="true">‹</span>
              <a href={clusterUrl}>{post.data.cluster}</a>
            </nav>
            <h1>{post.data.title}</h1>
            <div class="meta">
              <time datetime={post.data.pubDate.toISOString()}>{fmt.format(post.data.pubDate)}</time>
              {post.data.updatedDate && (
                <>
                  <span aria-hidden="true">·</span>
                  <span>עודכן <time datetime={post.data.updatedDate.toISOString()}>{fmt.format(post.data.updatedDate)}</time></span>
                </>
              )}
              <span aria-hidden="true">·</span>
              <span><span class="num">{post.data.readingMinutes}</span> דקות קריאה</span>
              {post.data.demo && <span class="demo-tag">פוסט דמו</span>}
            </div>

            {author && (
              <a class="byline" href={author.url} aria-label={`המחבר · ${author.name}`}>
                <span class="by-av" aria-hidden="true">{author.initial}</span>
                <span class="by-txt">
                  <span class="by-name">{author.name}</span>
                  <span class="by-role">{author.role}</span>
                </span>
              </a>
            )}
          </div>
        </header>

        {post.data.coverImage ? (
          <div class="cover narrow">
            <img src={post.data.coverImage} alt={post.data.title} width="1200" height="630" loading="eager" />
          </div>
        ) : (
          <div class="cover narrow">
            <div class="cover-ph" aria-hidden="true">
              <span class="cover-cat">{post.data.cluster}</span>
            </div>
          </div>
        )}
      </>
    )}

    <div class="layout narrow">
      {toc.length > 1 && (
        <details class="toc" open>
          <summary>
            <span>תוכן העניינים</span>
            <span class="toc-marker" aria-hidden="true"></span>
          </summary>
          <nav aria-label="תוכן העניינים">
            <ol>
              {toc.map((h) => (
                <li><a href={`#${h.slug}`}>{h.text}</a></li>
              ))}
            </ol>
          </nav>
        </details>
      )}

      <div class="content">
        {takeaways.length > 0 && (
          <aside class="takeaways" aria-label="מה תלמדו">
            <h2>מה תלמדו</h2>
            <ul>
              {takeaways.map((t) => <li>{t}</li>)}
            </ul>
          </aside>
        )}

        <div class="prose">
          <Content />
        </div>

        <div class="share" aria-label="שיתוף">
          <span class="share-label">שיתוף:</span>
          <a class="sh-btn" href={share.whatsapp} target="_blank" rel="noopener" aria-label="שיתוף בוואטסאפ">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.5A10 10 0 1 0 12 2Zm0 18.2a8.2 8.2 0 0 1-4.2-1.2l-.3-.2-2.9.9.9-2.8-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.5-6.1c-.2-.1-1.5-.7-1.7-.8s-.4-.1-.5.1-.6.8-.8 1-.3.2-.5.1a6.7 6.7 0 0 1-2-1.2 7.4 7.4 0 0 1-1.4-1.7c-.1-.2 0-.4.1-.5l.4-.4.2-.4a.5.5 0 0 0 0-.4l-.8-1.9c-.2-.5-.4-.4-.5-.4h-.5a.9.9 0 0 0-.7.3 2.8 2.8 0 0 0-.9 2.1 4.9 4.9 0 0 0 1 2.6 11 11 0 0 0 4.3 3.8c2 .8 2 .5 2.4.5a2.5 2.5 0 0 0 1.6-1.1 2 2 0 0 0 .1-1.1c0-.1-.2-.2-.4-.3Z"/></svg>
          </a>
          <a class="sh-btn" href={share.x} target="_blank" rel="noopener" aria-label="שיתוף ב-X">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.9 2h3.3l-7.2 8.3L23.5 22h-6.6l-5.2-6.8L5.7 22H2.4l7.7-8.8L1.5 2h6.8l4.7 6.2L18.9 2Zm-1.2 18h1.8L7.1 3.9H5.2L17.7 20Z"/></svg>
          </a>
          <a class="sh-btn" href={share.linkedin} target="_blank" rel="noopener" aria-label="שיתוף בלינקדאין">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.9 8.5v12H3V8.5h3.9ZM5 2.5A2.3 2.3 0 1 1 5 7a2.3 2.3 0 0 1 0-4.5ZM21 20.5h-3.9v-6c0-1.5 0-3.3-2-3.3s-2.3 1.6-2.3 3.2v6.1H8.9V8.5h3.7v1.6h.1a4 4 0 0 1 3.6-2c3.9 0 4.6 2.6 4.6 5.9v6.5Z"/></svg>
          </a>
          <button class="sh-btn copy" id="copy-link" type="button" aria-label="העתקת קישור">
            <svg class="ic-copy" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <span class="copy-txt">העתקת קישור</span>
          </button>
          <span class="copy-ok" id="copy-ok" role="status" aria-live="polite" hidden>הקישור הועתק ✓</span>
        </div>

        {post.data.faq && post.data.faq.length > 0 && (
          <section class="post-faq" aria-label="שאלות נפוצות">
            <h2>שאלות נפוצות</h2>
            <FaqAccordion items={post.data.faq} schema={true} />
          </section>
        )}
      </div>
    </div>

    {related.length > 0 && (
      <aside class="related" aria-label="פוסטים נוספים">
        <div class="wrap">
          <h2>עוד מהמגזין</h2>
          <div class="rgrid">
            {related.map((r) => (
              <a class={`rcard card ${r.data.cluster === post.data.cluster ? 'same' : ''}`} href={`/magazine/${r.id}`}>
                <span class="rcat">{r.data.cluster}</span>
                <h3>{r.data.title}</h3>
                <span class="rmeta"><span class="num">{r.data.readingMinutes}</span> דקות קריאה</span>
              </a>
            ))}
          </div>
        </div>
      </aside>
    )}

    <section class="post-cta">
      <div class="wrap">
        <CtaBand
          title="תוכן כזה · כתוב אוטומטית עבור החנות שלכם."
          body="מכונת התוכן של Scayla מייצרת מאמרים שמכוונים לשאלות שהקונים שלכם שואלים את ה-AI. אתם רק מאשרים."
        />
      </div>
    </section>
  </article>
</BaseLayout>

<script define:vars={{ postUrl }}>
  // Reading progress · transform/scaleX only (compositor-friendly), reduced-motion aware.
  const bar = document.getElementById('reading-progress');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (bar) {
    let ticking = false;
    const update = () => {
      const doc = document.documentElement;
      const max = doc.scrollHeight - doc.clientHeight;
      const p = max > 0 ? Math.min(1, Math.max(0, doc.scrollTop / max)) : 0;
      bar.style.transform = `scaleX(${p})`;
      ticking = false;
    };
    const onScroll = () => {
      if (!ticking) {
        if (reduce) update();
        else requestAnimationFrame(update);
        ticking = true;
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }

  // Copy-link · Clipboard API with a small confirmation.
  const copyBtn = document.getElementById('copy-link');
  const copyOk = document.getElementById('copy-ok');
  if (copyBtn && copyOk) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(postUrl);
      } catch (e) {
        const t = document.createElement('textarea');
        t.value = postUrl; t.style.position = 'fixed'; t.style.opacity = '0';
        document.body.appendChild(t); t.select();
        try { document.execCommand('copy'); } catch (_) {}
        document.body.removeChild(t);
      }
      copyOk.hidden = false;
      copyBtn.classList.add('done');
      setTimeout(() => { copyOk.hidden = true; copyBtn.classList.remove('done'); }, 2200);
    });
  }
</script>

<style>
  /* Reading progress bar · fixed top, scaleX transform only */
  .progress {
    position: fixed; inset-block-start: 0; inset-inline: 0; block-size: 3px;
    background: transparent; z-index: 60; pointer-events: none;
  }
  .progress-bar {
    display: block; block-size: 100%; inline-size: 100%;
    background: var(--sc-grad);
    transform: scaleX(0); transform-origin: right center; /* RTL: fills from the start edge */
    will-change: transform;
  }

  .post-head { padding-block: clamp(36px, 6vw, 60px) 8px; }
  .crumbs {
    display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;
    font-size: 13px; color: var(--sc-muted); margin-block-end: 18px;
  }
  .crumbs a { color: var(--sc-muted); }
  .crumbs a:hover { color: var(--sc-accent-text); }
  .post-head h1 { font-size: clamp(26px, 4.4vw, 40px); }
  .meta {
    display: flex; align-items: center; gap: 8px; justify-content: center; flex-wrap: wrap;
    font-size: 13.5px; color: var(--sc-disabled); margin-block-start: 16px;
  }
  .demo-tag {
    font-size: 11px; font-weight: 800; color: var(--sc-mv);
    background: var(--sc-wash); border: 1px solid var(--sc-soft);
    border-radius: var(--sc-r-pill); padding: 2px 10px;
  }

  /* Author byline */
  .byline {
    display: inline-flex; align-items: center; gap: 11px;
    margin-block-start: 20px; padding: 7px 16px 7px 8px;
    background: var(--sc-card); border: 1px solid var(--sc-hair);
    border-radius: var(--sc-r-pill); color: inherit;
    transition: border-color var(--sc-fast), transform var(--sc-fast) var(--sc-ease);
  }
  .byline:hover { border-color: var(--sc-soft); transform: translateY(-1px); }
  .by-av {
    inline-size: 36px; block-size: 36px; flex: none; border-radius: 50%;
    background: var(--sc-grad); color: #fff; font-weight: 800; font-size: 16px;
    display: grid; place-items: center;
  }
  .by-txt { display: grid; text-align: start; line-height: 1.3; }
  .by-name { font-size: 14px; font-weight: 700; color: var(--sc-ink); }
  .by-role { font-size: 12px; color: var(--sc-accent-text); font-weight: 600; }

  /* Cover */
  .cover { margin-block: clamp(20px, 3vw, 30px) 4px; }
  .cover img {
    inline-size: 100%; aspect-ratio: 1200 / 630; object-fit: cover;
    border-radius: var(--sc-r-hero); border: 1px solid var(--sc-hair);
  }
  .cover-ph {
    aspect-ratio: 1200 / 500; border-radius: var(--sc-r-hero);
    background:
      radial-gradient(500px 300px at 82% -30%, rgba(139, 118, 242, .5), transparent 62%),
      var(--sc-grad-rich);
    display: flex; align-items: flex-end; padding: 22px;
  }
  .cover-cat {
    background: rgba(255, 255, 255, .92); color: var(--sc-accent);
    font-size: 12px; font-weight: 800; border-radius: var(--sc-r-pill); padding: 5px 14px;
  }

  /* ═══ Hero header · full-width gradient cover band, title composed over it ═══ */
  .hero {
    position: relative;
    /* full-bleed edge-to-edge (parent #main has no width cap, but be robust anyway) */
    min-block-size: clamp(340px, 42vw, 480px);
    display: flex;
    background: #17123a;               /* deep indigo fallback under the art */
    overflow: hidden;
    isolation: isolate;
  }
  .hero-art {
    position: absolute; inset: 0; z-index: -1;
    background-image: var(--hero-img);
    background-size: cover;
    background-position: center;
  }
  /* contrast scrims · darken the text side (right, RTL) + the bottom, keep the art visible on the left */
  .hero-art::after {
    content: ''; position: absolute; inset: 0;
    background:
      linear-gradient(to left, rgba(15, 11, 38, .82) 0%, rgba(15, 11, 38, .35) 46%, transparent 74%),
      linear-gradient(to top, rgba(15, 11, 38, .78) 0%, transparent 46%);
  }
  .hero-inner {
    inline-size: 100%;
    display: flex; flex-direction: column; justify-content: space-between;
    padding-block: clamp(22px, 3.5vw, 34px) clamp(26px, 4vw, 40px);
  }
  .hero-crumbs {
    display: flex; gap: 8px; flex-wrap: wrap;
    font-size: 13px; color: rgba(255, 255, 255, .72);
  }
  .hero-crumbs a { color: rgba(255, 255, 255, .82); text-decoration: none; }
  .hero-crumbs a:hover { color: #fff; text-decoration: underline; text-underline-offset: 3px; }
  .hero-foot { max-inline-size: 40rem; }
  .hero-pill {
    display: inline-block; text-decoration: none;
    background: rgba(255, 255, 255, .14); color: #fff;
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, .22);
    font-size: 12.5px; font-weight: 700; letter-spacing: .01em;
    border-radius: var(--sc-r-pill); padding: 5px 14px; margin-block-end: 16px;
    transition: background var(--sc-fast);
  }
  .hero-pill:hover { background: rgba(255, 255, 255, .24); }
  .hero h1 {
    color: #fff; font-size: clamp(28px, 4.4vw, 48px); font-weight: 800;
    letter-spacing: -.022em; line-height: 1.12; margin: 0; text-wrap: balance;
    text-shadow: 0 2px 24px rgba(10, 7, 30, .45);
  }
  .hero-meta {
    display: flex; align-items: center; gap: 9px; flex-wrap: wrap;
    margin-block-start: 18px; font-size: 13.5px; color: rgba(255, 255, 255, .8);
  }
  .hero-meta .num { font-variant-numeric: tabular-nums; }
  .hero-byline {
    display: inline-flex; align-items: center; gap: 11px; text-decoration: none;
    margin-block-start: 20px; padding: 7px 16px 7px 8px;
    background: rgba(255, 255, 255, .1); border: 1px solid rgba(255, 255, 255, .2);
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    border-radius: var(--sc-r-pill); color: inherit;
    transition: background var(--sc-fast), transform var(--sc-fast) var(--sc-ease);
  }
  .hero-byline:hover { background: rgba(255, 255, 255, .18); transform: translateY(-1px); }
  .hero-byline .by-av {
    inline-size: 36px; block-size: 36px; flex: none; border-radius: 50%;
    background: var(--sc-grad); color: #fff; font-weight: 800; font-size: 16px;
    display: grid; place-items: center;
  }
  .hero-byline .by-txt { display: grid; text-align: start; line-height: 1.3; }
  .hero-byline .by-name { font-size: 14px; font-weight: 700; color: #fff; }
  .hero-byline .by-role { font-size: 12px; color: rgba(255, 255, 255, .78); font-weight: 600; }
  /* the reading column sits a touch higher under a hero (no big top gap) */
  .post.has-hero .layout { margin-block-start: clamp(28px, 4vw, 44px); }
  @media (max-width: 640px) {
    .hero { min-block-size: clamp(300px, 78vw, 400px); }
    .hero-art { background-position: 30% center; }
    .hero-art::after {
      background:
        linear-gradient(to top, rgba(15, 11, 38, .9) 0%, rgba(15, 11, 38, .35) 55%, rgba(15, 11, 38, .2) 100%);
    }
    .hero-foot { max-inline-size: none; }
  }

  /* Two-column layout · sticky TOC ≥1024px, stacked below */
  .layout { display: block; }
  @media (min-width: 1024px) {
    .layout {
      display: grid; grid-template-columns: 230px 1fr; gap: 40px;
      align-items: start; max-inline-size: 940px;
    }
    .toc {
      position: sticky; inset-block-start: 84px;
      max-block-size: calc(100vh - 120px); overflow: auto;
    }
  }

  /* TOC · <details> collapsible on mobile, open list on desktop */
  .toc {
    background: var(--sc-card); border: 1px solid var(--sc-hair);
    border-radius: 14px; padding: 6px 4px; margin-block: 20px 8px;
  }
  .toc summary {
    padding: 12px 16px; font-weight: 700; font-size: 14px; color: var(--sc-ink);
    cursor: pointer; list-style: none; display: flex; align-items: center; gap: 10px;
  }
  .toc summary::-webkit-details-marker { display: none; }
  .toc-marker { margin-inline-start: auto; inline-size: 12px; block-size: 12px; position: relative; flex: none; }
  .toc-marker::before, .toc-marker::after {
    content: ''; position: absolute; background: var(--sc-accent-text); border-radius: 2px;
