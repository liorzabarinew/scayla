---
/**
 * /scan · ממשק, לא עמוד נחיתה.
 *
 * שלושה מסכים שמחליפים זה את זה · המשתמש לא גולל כדי למצוא מצב:
 *   1. הפיץ' + כתובת החנות   2. המכונה עובדת (+ מייל)   3. התוצאות
 * בלי סקשנים שיווקיים מתחת. אם הכלי הוא העיקר · הכלי מקבל את המסך.
 * ראה [[lior-layout-dont-cram-center]] · לא לדחוס לעמודה צרה באמצע.
 *
 * מחליף את /check, שהוא הדגמה חזיתית (DemoWidget.astro:10 · "NO fetch/XHR/API").
 * שם המספרים קשיחים וזהים לכל מבקר. כאן הם נמדדים · ולכן אין תג "הדגמה",
 * ולכן אסור שיופיע פה מספר שלא נמדד.
 *
 * המנוע לא מוזכר · מדברים על "ה-AI". פרט מימוש, לא מסר (ליאור).
 * מדיניות Shopify 1.3.1: אפס אזכור של ביקורת או דירוג. מכוון.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'בדיקת נראות ב-AI · האם ה-AI מזכיר את החנות שלכם? · Scayla';
const description =
  'הכניסו את כתובת החנות ונבדוק בפועל, על שאלות קונה אמיתיות, אם ה-AI מזכיר אתכם או את המתחרים. הציון חינם ובלי פרטים · ואחריו נכתוב לכם שני מאמרים מלאים לחנות.';

const TURNSTILE_SITE_KEY = '0x4AAAAAAD3uTcm7n0TsX_1I';
const C = +(2 * Math.PI * 84).toFixed(2);
---

<BaseLayout title={title} description={description} noIndex>
  <div class="app">
    <!-- ═══════════ מסך 1 · הפיץ' + הכתובת ═══════════ -->
    <section class="screen" id="screen-idle">
      <div class="s1-grid">
        <div class="s1-pitch">
          <span class="eyebrow">בדיקה חינם</span>
          <h1>נראה לכם מה <span class="nobr">ה-<span class="grad-word">AI</span></span> אומר עליכם<br />ואז נסגור את הפער</h1>
          <p class="lede">
            נכניס את החנות שלכם לשאלות שקונים באמת שואלים את ה-AI, ונראה בשחור על גבי לבן
            אם אתם מופיעים או שהמתחרים מופיעים במקומכם. <strong>ואז נכתוב לכם שני מאמרים
            מלאים, בחינם</strong>, בדיוק על הפערים שנמצאו.
          </p>
          <ol class="journey">
            <li><span class="j-n num">1</span>סורקים את החנות והבלוג</li>
            <li><span class="j-n num">2</span>שואלים את ה-AI ומודדים ציון</li>
            <li><span class="j-n num">3</span>כותבים לכם <span class="num">2</span> מאמרים</li>
          </ol>
        </div>

        <form class="card s1-form" id="form-idle">
          <div class="f">
            <label for="store">כתובת החנות <span class="req">חובה</span></label>
            <input id="store" name="store" type="text" dir="ltr" inputmode="url"
                   autocomplete="url" placeholder="example.co.il" />
            <p class="err" id="e-store" role="alert" hidden></p>
          </div>
          <div class="f">
            <label for="blog">כתובת הבלוג</label>
            <input id="blog" name="blog" type="text" dir="ltr" inputmode="url" placeholder="example.co.il/blog" />
            <span class="hint">אם יש לכם בלוג · נסרוק גם אותו. לא חובה.</span>
          </div>

          <div class="hp" aria-hidden="true">
            <label for="company-website">אל תמלאו שדה זה</label>
            <input id="company-website" name="company_website" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <p class="err summary" id="e-summary" role="alert" hidden></p>
          <button class="btn btn-hero btn-gold" type="submit" id="go">קדימה, בואו נראה</button>
          <div class="ts-slot" id="ts-slot" data-sitekey={TURNSTILE_SITE_KEY}></div>
          <p class="fine">הציון חינם ובלי להשאיר פרטים · בלי כרטיס אשראי, בלי התקנה.</p>
        </form>
      </div>
    </section>

    <!-- ═══════════ מסך 2 · המכונה עובדת ═══════════ -->
    <section class="screen" id="screen-run" hidden aria-live="polite">
      <!-- הירוק ראשון ובולט · אנחנו צריכים מיילים, זה לא הערת שוליים -->
      <form class="card mailbox" id="form-mail">
        <div class="mail-copy">
          <h2>זה לוקח בערך <span class="num">16</span> דקות</h2>
          <p>אפשר להישאר ולראות את זה קורה · או להשאיר מייל, לסגור את החלון, ולקבל קישור כשהכל מוכן.</p>
        </div>
        <div class="mail-fields">
          <div class="f">
            <label for="gname">שם</label>
            <input id="gname" name="gname" type="text" dir="auto" autocomplete="name" placeholder="השם שלכם" />
          </div>
          <div class="f">
            <label for="email">מייל</label>
            <input id="email" name="email" type="email" dir="ltr" autocomplete="email" placeholder="you@store.co.il" />
            <p class="err" id="e-email" role="alert" hidden></p>
          </div>
          <button class="btn btn-gold" type="submit" id="go-mail">עדכנו אותי במייל</button>
        </div>
        <p class="err summary" id="e-mail" role="alert" hidden></p>
      </form>

      <div class="card mailbox saved" id="mail-ok" hidden>
        <span class="mk-ok" aria-hidden="true">✓</span>
        <p>נשלח קישור לעמוד הזה ל-<b class="num" dir="ltr" id="mail-shown">…</b> ברגע שהכל מוכן. אפשר לסגור את החלון.</p>
      </div>

      <!-- המכונה · ממש מתחת לירוק -->
      <div class="card run-main">
        <div class="run-top">
          <div class="orb" aria-hidden="true"><i></i><i></i><i></i></div>
          <div class="run-id">
            <h2>Scayla עובדת על <b id="run-host" dir="ltr">…</b></h2>
            <p class="run-now" id="run-now">מתחילים</p>
          </div>
          <div class="run-clock">
            <b class="num" id="run-elapsed">0:00</b>
            <small>רץ כבר</small>
          </div>
        </div>
        <ol class="log" id="run-log"></ol>
      </div>

      <div class="card score-mini" id="score-mini" hidden>
        <span class="eyebrow">הציון שלכם · כבר מוכן</span>
        <div class="mini-row">
          <div class="dm-gauge" id="gauge">
            <svg viewBox="0 0 200 200" aria-hidden="true">
              <defs><linearGradient id="scGrad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#5546d6" /><stop offset="1" stop-color="#8b76f2" />
              </linearGradient></defs>
              <circle cx="100" cy="100" r="84" fill="none" stroke="var(--sc-div)" stroke-width="15" />
              <circle class="dm-arc" id="gauge-arc" cx="100" cy="100" r="84" fill="none"
                      stroke="url(#scGrad)" stroke-width="15" stroke-linecap="round"
                      stroke-dasharray={C} stroke-dashoffset={C} transform="rotate(-90 100 100)" />
            </svg>
            <span class="dm-gauge-c">
              <b class="num"><i id="gauge-num">0</i><em class="pct">%</em></b>
              <small>נראות ב-AI</small>
            </span>
          </div>
          <div class="mini-txt">
            <span class="band" id="score-band">…</span>
            <p class="mini-sub" id="mini-sub"></p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════ מסך 3 · התוצאות ═══════════ -->
    <section class="screen" id="screen-done" hidden>
      <div class="done-head">
        <h2>הנה מה שה-AI אומר עליכם · ומה שכתבנו לכם</h2>
        <p class="verdict" id="verdict" hidden></p>
      </div>

      <!-- הציון · רוחב מלא, לא נדחק לצד -->
      <div class="card score-full">
        <div class="score-row">
          <div class="dm-gauge" id="gauge2">
            <svg viewBox="0 0 200 200" aria-hidden="true">
              <defs><linearGradient id="scGrad2" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#5546d6" /><stop offset="1" stop-color="#8b76f2" />
              </linearGradient></defs>
              <circle cx="100" cy="100" r="84" fill="none" stroke="var(--sc-div)" stroke-width="15" />
              <circle class="dm-arc" id="gauge-arc2" cx="100" cy="100" r="84" fill="none"
                      stroke="url(#scGrad2)" stroke-width="15" stroke-linecap="round"
                      stroke-dasharray={C} stroke-dashoffset={C} transform="rotate(-90 100 100)" />
            </svg>
            <span class="dm-gauge-c">
              <b class="num"><i id="gauge-num2">0</i><em class="pct">%</em></b>
              <small>נראות ב-AI</small>
            </span>
          </div>
          <div class="score-txt">
            <p class="score-line">אתם מופיעים ב-<b class="num" id="score-pct">0%</b> מהתשובות</p>
            <span class="band" id="score-band2">…</span>
            <p class="score-sub">
              שאלנו את ה-AI <span class="num" id="q-total">0</span> שאלות קונה שנגזרו מהחנות שלכם ·
              הופעתם ב-<span class="num" id="q-hit">0</span> מהן. כל השאלות למטה.
            </p>
          </div>
        </div>
        <p class="method">
          הציון נמדד עכשיו, על שאלות שנגזרו מהאתר שלכם · לא על שאלות כלליות. זו תמונת רגע.
          בתוך Scayla המדידה רצה <b>כל שבוע על קבוצה קבועה</b> של שאלות, כך שאפשר להשוות
          שבוע לשבוע ולראות אם אתם עולים או יורדים.
        </p>
      </div>

      <!-- השאלות · ריבועים, לא גלילה אינסופית. הלקוח רואה את העבודה. -->
      <h3 class="sec-t">אלה השאלות ששאלנו · ומה קרה בכל אחת</h3>
      <div class="q-grid" id="answers"></div>

      <h3 class="sec-t">שני המאמרים שכתבנו לכם</h3>
      <div class="art-grid" id="arts"></div>

      <div class="card end cta-end">
        <h2>רוצים שזה יקרה כל שבוע, לבד?</h2>
        <p>מה שראיתם כאן זו תמונת רגע אחת. בתוך Scayla המדידה רצה כל שבוע, והמכונה כותבת ומתקנת בלי שתבקשו.</p>
        <div class="cta-pair center">
          <a class="btn btn-hero btn-gold" href="https://calendly.com/lior-mrmake/30min">קבעו דמו</a>
          <a class="btn btn-hero btn-ghost" href="/pricing">למחירון</a>
        </div>
      </div>
    </section>

    <!-- קורא המאמר · שכבה מלאה, לא ניווט החוצה -->
    <div class="reader" id="reader" hidden>
      <div class="reader-bar">
        <button class="reader-x" type="button" id="reader-close" aria-label="סגירה">✕</button>
        <p class="reader-meta" id="reader-meta"></p>
      </div>
      <article class="reader-body">
        <h1 id="reader-t"></h1>
        <div class="prose" id="reader-md"></div>
        <div id="reader-src"></div>
      </article>
    </div>

    <!-- ═══════════ תקלה ═══════════ -->
    <section class="screen" id="screen-error" hidden>
      <div class="card end">
        <span class="end-ic bad" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 8v5M12 16.5v.01"></path></svg>
        </span>
        <h2 id="err-t">משהו לא עבד</h2>
        <p id="err-p">נסו שוב בעוד כמה דקות.</p>
        <button class="back" type="button" id="err-back">חזרה לבדיקה</button>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* ═══ המעטפת · הכלי מקבל את המסך ═══ */
  .app {
    min-block-size: calc(100dvh - var(--sc-header-h, 68px));
    display: flex; flex-direction: column; justify-content: center;
    padding: clamp(28px, 4vw, 56px) clamp(18px, 4vw, 48px) clamp(40px, 5vw, 72px);
    background:
      radial-gradient(1100px 700px at 82% -14%, rgba(139, 118, 242, .26), transparent 62%),
      radial-gradient(860px 620px at -8% 40%, rgba(85, 70, 214, .1), transparent 55%);
  }
  :global([data-theme='dark']) .app {
    background:
      radial-gradient(1100px 700px at 82% -14%, rgba(139, 118, 242, .18), transparent 62%),
      linear-gradient(180deg, #221c3a 0%, var(--sc-paper) 70%);
  }
  .screen { inline-size: 100%; max-inline-size: 1240px; margin-inline: auto; }

  /* [hidden] חייב לנצח · כל display מפורש (כמו .mailbox{display:flex}) גובר
     על display:none של הדפדפן, וכרטיס "נשלח קישור" הופיע למרות hidden.
     נתפס בצילום מסך, לא בקוד. */
  [hidden] { display: none !important; }
  .nobr { white-space: nowrap; }
  .grad-word {
    background: var(--sc-grad); -webkit-background-clip: text; background-clip: text;
    color: transparent; -webkit-text-fill-color: transparent;
  }

  /* ═══ מסך 1 · הפיץ' מול הטופס, פרוס על הרוחב ═══ */
  .s1-grid {
    display: grid; grid-template-columns: minmax(0, 1.05fr) minmax(380px, .95fr);
    gap: clamp(32px, 5vw, 72px); align-items: center;
  }
  @media (max-width: 940px) { .s1-grid { grid-template-columns: 1fr; gap: 32px; } }

  .s1-pitch h1 {
    font-size: clamp(32px, 3.9vw, 54px); font-weight: 900;
    letter-spacing: -.025em; line-height: 1.08; color: var(--sc-ink);
  }
  .s1-pitch .lede { max-inline-size: 46ch; margin-block-start: 20px; }
  .s1-pitch .lede strong { color: var(--sc-ink); font-weight: 700; }

  .journey { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 9px; margin-block-start: 28px; }
  .journey li {
    display: inline-flex; align-items: center; gap: 11px; align-self: flex-start;
    background: var(--sc-card); border: 1px solid var(--sc-hair);
    border-radius: var(--sc-r-pill); padding: 9px 20px 9px 10px;
    font-size: 14px; font-weight: 600; color: var(--sc-ink); box-shadow: var(--sc-sh-subtle);
  }
  .j-n {
    display: grid; place-items: center; inline-size: 24px; block-size: 24px; border-radius: 999px;
    background: var(--sc-wash); border: 1px solid var(--sc-soft);
    color: var(--sc-accent-text); font-size: 12px; font-weight: 800; flex: none;
  }

  .s1-form {
    padding: clamp(28px, 3vw, 40px);
    display: flex; flex-direction: column; gap: 20px;
    box-shadow: var(--sc-sh-deep);
  }

  /* ═══ שדות ═══ */
  .f { display: flex; flex-direction: column; gap: 8px; }
  .f > label { font-size: 14.5px; font-weight: 700; color: var(--sc-ink); display: flex; gap: 7px; align-items: baseline; }
  .req { color: var(--sc-accent-text); font-size: 12px; font-weight: 700; }
  .hint { font-size: 13px; font-weight: 500; color: var(--sc-muted); }
  .f input {
    font-family: inherit; font-size: 16px; font-weight: 500;
    color: var(--sc-ink); background: var(--sc-card);
    border: 1px solid var(--sc-hair); border-radius: var(--sc-r-chip);
    padding: 14px 16px; inline-size: 100%;
    transition: border-color var(--sc-fast) var(--sc-ease), box-shadow var(--sc-fast) var(--sc-ease);
  }
  .f input:focus-visible { outline: none; border-color: var(--sc-accent); box-shadow: 0 0 0 3px var(--sc-wash); }
  .f input::placeholder { color: var(--sc-disabled); }
  .f.bad input { border-color: var(--sc-red); }
  .err { font-size: 13px; font-weight: 600; color: var(--sc-red-text); }
  .err.summary { background: var(--sc-red-bg); border: 1px solid var(--sc-red-bd); border-radius: var(--sc-r-chip); padding: 11px 15px; text-align: center; }
  .fine { font-size: 12.5px; color: var(--sc-muted); text-align: center; }
  .hp { position: absolute; inline-size: 1px; block-size: 1px; overflow: hidden; clip-path: inset(50%); white-space: nowrap; }
  .ts-slot { display: flex; justify-content: center; min-block-size: 65px; margin-block-start: -4px; }
  .ts-slot :global(iframe), .ts-slot :global(> div) { border-radius: var(--sc-r-chip); overflow: hidden; }
  button[aria-busy='true'] { opacity: .7; pointer-events: none; }

  /* ═══ מסך 2 · הכל מוערם · הירוק ראשון ═══ */
  #screen-run { display: flex; flex-direction: column; gap: 16px; }

  /* הירוק · בולט. אנחנו צריכים מיילים, זו לא הערת שוליים. */
  .mailbox {
    padding: clamp(24px, 3vw, 34px);
    background: var(--sc-gold-bg); border: 2px solid var(--accent-gold);
    box-shadow: 0 14px 40px -18px rgba(36, 200, 140, .55);
    display: grid; grid-template-columns: minmax(0, 1fr) minmax(360px, .85fr);
    gap: clamp(18px, 3vw, 40px); align-items: center;
  }
  @media (max-width: 860px) { .mailbox { grid-template-columns: 1fr; } }
  .mail-copy h2 { font-size: clamp(19px, 2.1vw, 25px); font-weight: 800; letter-spacing: -.015em; color: var(--sc-ink); }
  .mail-copy p { font-size: 14.5px; line-height: 1.65; color: var(--sc-mv); margin-block-start: 8px; }
  .mail-fields { display: grid; grid-template-columns: 1fr 1.3fr; gap: 12px; align-items: end; }
  @media (max-width: 620px) { .mail-fields { grid-template-columns: 1fr; } }
  .mail-fields .btn { grid-column: 1 / -1; }
  .mailbox .err.summary { grid-column: 1 / -1; }
  .mailbox.saved {
    display: flex; flex-direction: row; align-items: center; gap: 14px;
    border-width: 1px; border-color: var(--sc-gold-bd); box-shadow: var(--sc-sh-subtle);
  }
  .mailbox.saved p { font-size: 14.5px; line-height: 1.6; color: var(--sc-ink); }
  .mk-ok {
    flex: none; inline-size: 28px; block-size: 28px; border-radius: 999px;
    display: grid; place-items: center; font-size: 14px; font-weight: 800;
    background: var(--sc-card); color: var(--sc-gold-text); border: 1px solid var(--sc-gold-bd);
  }

  .run-main { padding: clamp(28px, 3vw, 40px); }
  .run-top {
    display: flex; align-items: center; gap: 18px;
    padding-block-end: 24px; margin-block-end: 26px;
    border-block-end: 1px solid var(--sc-div);
  }
  .run-id { flex: 1; min-inline-size: 0; }
  .run-id h2 { font-size: clamp(17px, 1.7vw, 21px); font-weight: 800; letter-spacing: -.01em; color: var(--sc-ink); }
  .run-id h2 b { color: var(--sc-accent-text); font-weight: 800; }
  .run-now { font-size: 13.5px; color: var(--sc-muted); font-weight: 600; margin-block-start: 5px; }
  .run-clock { text-align: center; flex: none; }
  .run-clock b { display: block; font-size: 26px; font-weight: 800; letter-spacing: -.02em; color: var(--sc-ink); line-height: 1; }
  .run-clock small { font-size: 11px; color: var(--sc-muted); font-weight: 600; }

  .orb { position: relative; inline-size: 44px; block-size: 44px; flex: none; display: grid; place-items: center; }
  .orb i {
    position: absolute; inline-size: 100%; block-size: 100%; border-radius: 999px;
    border: 2px solid var(--accent-gold); opacity: 0;
    animation: ping 2.4s var(--sc-ease) infinite;
  }
  .orb i:nth-child(2) { animation-delay: .8s; }
  .orb i:nth-child(3) { animation-delay: 1.6s; }
  .orb::after {
    content: ''; inline-size: 12px; block-size: 12px; border-radius: 999px;
    background: var(--accent-gold); box-shadow: 0 0 14px 2px rgba(36, 200, 140, .5);
  }
  @keyframes ping { 0% { transform: scale(.35); opacity: .9; } 100% { transform: scale(1); opacity: 0; } }

  /* הלוג · כל השלבים מההתחלה, הטיק יורד אחד־אחד.
     :global חובה · השורות נוצרות ב-JS ואין להן data-astro-cid. */
  .log { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 13px; }
  .log :global(li) {
    display: flex; gap: 13px; align-items: flex-start;
    font-size: 14.5px; line-height: 1.55; color: var(--sc-ink);
  }
  .log :global(li[data-state='pending']) { color: var(--sc-disabled); }
  .log :global(li[data-state='running']) { color: var(--sc-ink); font-weight: 700; }
  .log :global(li[data-state='done']), .log :global(li[data-state='skipped']) { color: var(--sc-muted); }
  .log :global(.li-ic) {
    flex: none; inline-size: 20px; block-size: 20px; border-radius: 999px;
    display: grid; place-items: center; font-size: 11px; font-weight: 800;
    margin-block-start: 1px; font-style: normal; border: 1px solid var(--sc-hair);
    transition: all var(--sc-fast) var(--sc-ease);
  }
  .log :global(li[data-state='done'] .li-ic) {
    background: var(--sc-gold-bg); color: var(--sc-gold-text); border-color: var(--sc-gold-bd);
  }
  .log :global(li[data-state='running'] .li-ic) {
    background: var(--sc-wash); color: var(--sc-accent-text); border-color: var(--sc-accent);
    animation: beat 1.4s var(--sc-ease) infinite;
  }
  @keyframes beat {
    0%, 100% { box-shadow: 0 0 0 0 rgba(85, 70, 214, .45); }
    70% { box-shadow: 0 0 0 7px rgba(85, 70, 214, 0); }
  }
  .log :global(li[data-state='skipped'] .li-ic) { border-style: dashed; color: var(--sc-disabled); }
  @media (prefers-reduced-motion: reduce) {
    .orb i, .log :global(li[data-state='running'] .li-ic) { animation: none; }
  }

  .score-mini { padding: clamp(22px, 2.5vw, 30px); animation: logIn 400ms var(--sc-ease) both; }
  @keyframes logIn { from { opacity: 0; transform: translateY(6px); } }
  .mini-row { display: flex; align-items: center; gap: 20px; margin-block-start: 14px; flex-wrap: wrap; }
  .mini-txt { min-inline-size: 0; }
  .mini-sub { font-size: 13.5px; color: var(--sc-muted); margin-block-start: 8px; line-height: 1.5; }

  /* ═══ המחוון ═══ */
  .dm-gauge { position: relative; inline-size: 118px; block-size: 118px; flex: none; }
  .score-full .dm-gauge { inline-size: 152px; block-size: 152px; }
  .dm-gauge svg { inline-size: 100%; block-size: 100%; display: block; }
  .dm-arc { transition: stroke-dashoffset 1300ms var(--sc-ease); }
  @media (prefers-reduced-motion: reduce) { .dm-arc { transition: none; } }
  .dm-gauge-c { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .dm-gauge-c b { font-weight: 800; font-size: 29px; line-height: 1; letter-spacing: -.02em; color: var(--sc-ink); }
  .score-full .dm-gauge-c b { font-size: 37px; }
  .dm-gauge-c b i { font-style: normal; }
  .dm-gauge-c b em { font-style: normal; font-size: 15px; font-weight: 700; color: var(--sc-accent-text); }
  .dm-gauge-c small { font-size: 10px; color: var(--sc-muted); margin-block-start: 4px; font-weight: 500; }
  .band {
    display: inline-flex; border-radius: var(--sc-r-pill); padding: 6px 14px;
    font-size: 13px; font-weight: 800;
    background: var(--sc-wash); color: var(--sc-accent-text); border: 1px solid var(--sc-soft);
  }
  .band[data-band='lead'] { background: var(--sc-gold-bg); color: var(--sc-gold-text); border-color: var(--sc-gold-bd); }
  .band[data-band='gap'] { background: var(--sc-red-bg); color: var(--sc-red-text); border-color: var(--sc-red-bd); }

  /* ═══ מסך 3 · תוצאות ═══ */
  #screen-done { display: flex; flex-direction: column; gap: 18px; }
  .done-head { text-align: center; margin-block-end: 8px; }
  .done-head h2 { font-size: clamp(24px, 2.9vw, 36px); font-weight: 900; letter-spacing: -.02em; color: var(--sc-ink); }
  .verdict {
    font-size: clamp(15px, 1.7vw, 18px); line-height: 1.65; font-weight: 600;
    color: var(--sc-mv); max-inline-size: 64ch; margin: 16px auto 0;
  }
  .sec-t {
    font-size: clamp(17px, 1.9vw, 22px); font-weight: 800; letter-spacing: -.015em;
    color: var(--sc-ink); margin-block-start: 14px;
  }
  .score-full { padding: clamp(26px, 3vw, 38px); display: flex; flex-direction: column; gap: 20px; }
  .score-row { display: flex; align-items: center; gap: 28px; flex-wrap: wrap; }
  .score-txt { min-inline-size: 0; flex: 1; }
  .score-line { font-size: clamp(18px, 2.1vw, 23px); font-weight: 700; color: var(--sc-ink); margin-block-end: 10px; }
  .score-line b { color: var(--sc-accent-text); font-weight: 900; }
  .score-sub { font-size: 14px; color: var(--sc-muted); margin-block-start: 12px; font-weight: 500; line-height: 1.6; }
  .method {
    font-size: 12.5px; line-height: 1.7; color: var(--sc-mv); font-weight: 500;
    border-block-start: 1px solid var(--sc-div); padding-block-start: 16px;
  }
  .method b { color: var(--sc-ink); font-weight: 700; }

  /* השאלות · ריבועים. הלקוח רואה את העבודה בלי לגלול קילומטר. */
  .q-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
  .q-grid :global(.q-card) {
    background: var(--sc-card); border: 1px solid var(--sc-hair);
    border-radius: var(--sc-r-card); padding: 18px 20px;
    display: flex; flex-direction: column; gap: 12px; justify-content: space-between;
    box-shadow: var(--sc-sh-subtle);
  }
  .q-grid :global(.q-card.hit) { border-color: var(--sc-gold-bd); background: var(--sc-gold-bg); }
  .q-grid :global(.q-q) { font-size: 14px; font-weight: 700; line-height: 1.55; color: var(--sc-ink); }
  .q-grid :global(.q-tag) {
    align-self: flex-start; border-radius: var(--sc-r-pill); padding: 5px 12px;
    font-size: 12px; font-weight: 800;
    background: var(--sc-red-bg); color: var(--sc-red-text); border: 1px solid var(--sc-red-bd);
  }
  .q-grid :global(.q-card.hit .q-tag) { background: var(--sc-card); color: var(--sc-gold-text); border-color: var(--sc-gold-bd); }

  /* המאמרים · זה לצד זה, שורה אחת, כפתור לקורא המלא */
  .art-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(330px, 1fr)); gap: 18px; }
  .art-grid :global(.art) {
    background: var(--sc-card); border: 1px solid var(--sc-hair);
    border-radius: var(--sc-r-hero); padding: clamp(24px, 2.6vw, 32px);
    display: flex; flex-direction: column; gap: 12px; box-shadow: var(--sc-sh-lift);
  }
  .art-grid :global(.art-t) { font-size: clamp(18px, 1.9vw, 22px); font-weight: 800; letter-spacing: -.015em; line-height: 1.35; color: var(--sc-ink); }
  .art-grid :global(.art-meta) { font-size: 12.5px; color: var(--sc-muted); font-weight: 600; }
  .art-grid :global(.art-ex) {
    font-size: 14px; line-height: 1.75; color: var(--sc-mv);
    display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
  }
  .art-grid :global(.art-flag) {
    font-size: 12.5px; font-weight: 600; color: var(--sc-ink);
    background: var(--sc-gold-bg); border: 1px solid var(--sc-gold-bd);
    border-radius: var(--sc-r-chip); padding: 9px 12px;
  }
  .art-grid :global(.art-go) { margin-block-start: auto; align-self: flex-start; }

  /* הקורא · שכבה מלאה במקום לנווט החוצה */
  .reader {
    position: fixed; inset: 0; z-index: 60; background: var(--sc-paper);
    overflow-y: auto; animation: fadeIn 220ms var(--sc-ease) both;
  }
  @keyframes fadeIn { from { opacity: 0; } }
  .reader-bar {
    position: sticky; top: 0; z-index: 2;
    display: flex; align-items: center; gap: 14px;
    padding: 14px clamp(18px, 4vw, 40px);
    background: color-mix(in srgb, var(--sc-paper) 88%, transparent);
    backdrop-filter: blur(14px); border-block-end: 1px solid var(--sc-hair);
  }
  .reader-x {
    inline-size: 36px; block-size: 36px; border-radius: 999px; flex: none;
    border: 1px solid var(--sc-hair); background: var(--sc-card);
    color: var(--sc-ink); font-size: 15px; cursor: pointer;
  }
  .reader-x:hover { border-color: var(--sc-accent); color: var(--sc-accent-text); }
  .reader-meta { font-size: 13px; color: var(--sc-muted); font-weight: 600; }
  .reader-body { max-inline-size: 760px; margin-inline: auto; padding: clamp(28px, 4vw, 52px) clamp(18px, 4vw, 40px) 80px; }
  .reader-body h1 { font-size: clamp(26px, 3.4vw, 40px); font-weight: 900; letter-spacing: -.025em; line-height: 1.2; color: var(--sc-ink); margin-block-end: 26px; }
  .reader :global(.prose h3) { font-size: 21px; font-weight: 800; letter-spacing: -.01em; margin-block: 32px 12px; color: var(--sc-ink); }
  .reader :global(.prose h4) { font-size: 17px; font-weight: 800; margin-block: 22px 8px; color: var(--sc-ink); }
  .reader :global(.prose p) { margin-block-end: 17px; font-size: 16.5px; line-height: 1.9; color: var(--sc-ink); unicode-bidi: isolate; }
  .reader :global(.prose strong) { font-weight: 700; }
  .reader :global(.prose ul) { padding-inline-start: 24px; margin-block-end: 17px; display: grid; gap: 8px; }
  .reader :global(.prose li) { font-size: 16px; line-height: 1.8; color: var(--sc-ink); unicode-bidi: isolate; }
  .reader :global(.prose code) {
    font-size: 14px; background: var(--sc-wash); border: 1px solid var(--sc-soft);
    border-radius: 5px; padding: 1px 5px; direction: ltr; unicode-bidi: isolate; display: inline-block;
  }
  /* טבלה · גלילה אופקית במובייל, בלי לשבור את הדף */
  .reader :global(.tbl-wrap) { overflow-x: auto; margin-block: 22px; border: 1px solid var(--sc-hair); border-radius: var(--sc-r-chip); }
  .reader :global(table) { inline-size: 100%; border-collapse: collapse; font-size: 14.5px; }
  .reader :global(th) { background: var(--sc-wash); text-align: start; padding: 12px 14px; font-weight: 800; color: var(--sc-ink); border-block-end: 1px solid var(--sc-hair); }
  .reader :global(td) { padding: 11px 14px; color: var(--sc-ink); border-block-end: 1px solid var(--sc-div); }
  .reader :global(tr:last-child td) { border-block-end: none; }

  /* "למה כתבנו לך את זה" · תיחום צבעוני, לא טקסט גנרי */
  .reader :global(.why-box) {
    background: var(--sc-grad-soft, linear-gradient(135deg, rgba(85,70,214,.08), rgba(139,118,242,.05)));
    border: 1px solid var(--sc-soft); border-inline-start: 4px solid var(--sc-accent);
    border-radius: var(--sc-r-hero); padding: 20px 24px; margin-block-end: 28px;
  }
  .reader :global(.why-t) { font-size: 12px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; color: var(--sc-accent-text); margin-block-end: 8px; }
  .reader :global(.why-box p:last-child) { font-size: 15.5px; line-height: 1.7; color: var(--sc-ink); font-weight: 500; }

  /* "בקצרה" · takeaways בראש המאמר */
  .reader :global(.tldr) { background: var(--sc-wash); border: 1px solid var(--sc-soft); border-radius: var(--sc-r-hero); padding: 22px 26px; margin-block-end: 30px; }
  .reader :global(.tldr-t) { font-size: 12px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; color: var(--sc-accent-text); margin-block-end: 12px; }
  .reader :global(.tldr ul) { padding-inline-start: 20px; display: grid; gap: 9px; margin: 0; }
  .reader :global(.tldr li) { font-size: 15.5px; line-height: 1.6; color: var(--sc-ink); font-weight: 500; }

  /* FAQ */
  .reader :global(.faq) { margin-block-start: 40px; padding-block-start: 26px; border-block-start: 1px solid var(--sc-div); }
  .reader :global(.faq > h3) { font-size: 22px; font-weight: 800; margin-block-end: 18px; }
  .reader :global(.faq-i) { padding-block: 16px; border-block-end: 1px solid var(--sc-div); }
  .reader :global(.faq-q) { font-size: 16px; font-weight: 700; color: var(--sc-ink); margin-block-end: 7px; }
  .reader :global(.faq-a) { font-size: 15px; line-height: 1.75; color: var(--sc-mv); }

  .reader :global(.art-src) { margin-block-start: 40px; padding-block-start: 22px; border-block-start: 1px solid var(--sc-div); }
  .reader :global(.art-src-t) { font-size: 11.5px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; color: var(--sc-muted); margin-block-end: 12px; }
  .reader :global(.art-src ol) { padding-inline-start: 20px; display: grid; gap: 6px; }
  .reader :global(.art-src li) { font-size: 13.5px; color: var(--sc-muted); }
  .reader :global(.art-src a) { color: var(--sc-accent-text); text-decoration: none; direction: ltr; unicode-bidi: isolate; display: inline-block; }
  .reader :global(.art-src a:hover) { text-decoration: underline; }

  .reader :global(.art-wm) {
    margin-block-start: 40px; padding-block-start: 20px;
    border-block-start: 1px solid var(--sc-div);
    font-size: 12.5px; color: var(--sc-muted); text-align: center; font-weight: 600;
  }
  .reader :global(.art-wm strong) { color: var(--sc-accent-text); font-weight: 800; }

  /* ═══ סיום ותקלה ═══ */
  .end { padding: clamp(30px, 4vw, 48px); text-align: center; }
  .end h2 { margin-block-end: 10px; font-size: clamp(20px, 2.4vw, 28px); }
  .end p { color: var(--sc-mv); max-inline-size: 54ch; margin-inline: auto; font-size: 15px; line-height: 1.7; }
  .cta-end { margin-block-start: 18px; }
  .cta-end .btn { margin-block-start: 24px; }
  .end-ic { display: grid; place-items: center; inline-size: 52px; block-size: 52px; border-radius: 999px; margin: 0 auto 16px; }
  .end-ic.bad { background: var(--sc-red-bg); border: 1px solid var(--sc-red-bd); color: var(--sc-red-text); }
  .back {
    margin-block-start: 18px; background: none; border: none; cursor: pointer;
    font-family: inherit; font-size: 13.5px; font-weight: 600; color: var(--sc-muted);
    text-decoration: underline; text-underline-offset: 3px;
  }
  .back:hover { color: var(--sc-accent-text); }
</style>

<script>
  // ── /scan · ממשק של שלושה מסכים. phase מהשרת הוא מקור האמת היחיד. ──
  const $ = (id: string) => document.getElementById(id);
  const show = (el: HTMLElement | null) => el?.removeAttribute('hidden');
  const hide = (el: HTMLElement | null) => el?.setAttribute('hidden', '');

  const SCREENS = ['screen-idle', 'screen-run', 'screen-done', 'screen-error'];
  const screen = (id: string) => {
    SCREENS.forEach((s) => (s === id ? show($(s)) : hide($(s))));
    window.scrollTo({ top: 0 });
  };

  const okEmail = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v.trim());
  const cleanHost = (v: string) =>
    v.trim().replace(/^https?:\/\//i, '').replace(/^www\./i, '').replace(/\/.*$/, '').toLowerCase();
  const okHost = (v: string) => /^[a-z0-9]([a-z0-9-]*[a-z0-9])?(\.[a-z0-9-]+)+$/.test(cleanHost(v));

  const setErr = (k: string, msg: string) => {
    const el = $('e-' + k); el?.closest('.f')?.classList.add('bad');
    if (el) { el.textContent = msg; el.removeAttribute('hidden'); }
  };
  const clearErr = (k: string) => {
    const el = $('e-' + k); el?.closest('.f')?.classList.remove('bad');
    if (el) { el.setAttribute('hidden', ''); el.textContent = ''; }
  };
  const mmss = (ms: number) => {
    const s = Math.max(0, Math.floor(ms / 1000));
    return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
  };

  const ICON: Record<string, string> = { done: '✓', running: '', pending: '', skipped: '–' };
  const renderLog = (steps: { label: string; state: string }[]) => {
    const el = $('run-log');
    // תגובת status בלי steps לא מוחקת לוג שכבר צויר
    if (!el || !steps?.length) return;
    el.innerHTML = '';
    for (const s of steps) {
      const li = document.createElement('li');
      li.dataset.state = s.state;
      li.innerHTML = `<i class="li-ic" aria-hidden="true">${ICON[s.state] ?? ''}</i><span></span>`;
      (li.querySelector('span') as HTMLElement).textContent = s.label;
      el.appendChild(li);
    }
    const now = steps.find((s) => s.state === 'running');
    const nowEl = $('run-now');
    if (nowEl) nowEl.textContent = now ? now.label : 'מסיימים';
  };

  const CIRC = 2 * Math.PI * 84;
  const paintGauge = (arcId: string, numId: string, wrapId: string, pct: number) => {
    const arc = $(arcId) as unknown as SVGCircleElement | null;
    if (arc) arc.style.strokeDashoffset = String(CIRC * (1 - pct / 100));
    const n = $(numId);
    // הערך האמיתי נכתב מיד · הספירה היא קישוט. אם rAF נחנק, המספר עדיין נכון.
    if (n) n.textContent = String(pct);
    $(wrapId)?.setAttribute('aria-label', `נראות ב-AI: ${pct}%`);
    if (!n || matchMedia('(prefers-reduced-motion: reduce)').matches || pct <= 0) return;
    const t0 = performance.now();
    const tick = (t: number) => {
      const p = Math.min(1, (t - t0) / 1300);
      n.textContent = String(Math.round(pct * (1 - Math.pow(1 - p, 3))));
      if (p < 1) requestAnimationFrame(tick); else n.textContent = String(pct);
    };
    requestAnimationFrame(tick);
  };

  const bandOf = (pct: number) => (pct >= 50 ? 'lead' : pct >= 20 ? 'grow' : 'gap');
  const bandTxt = (b: string) =>
    b === 'lead' ? 'אתם מובילים בתשובות' : b === 'grow' ? 'יש לכם לאן לצמוח' : 'פער נראות גדול';

  let scorePainted = false;
  const paintScore = (s: any) => {
    // רק פעם אחת · paintScore נקרא בכל poll, וכל קריאה איתחלה מחדש את
    // ספירת-העלייה. האחוזים "קפצו מ-0" כל כמה שניות.
    if (scorePainted) return;
    scorePainted = true;
    const pct = Math.max(0, Math.min(100, Math.round(s.pct)));
    const b = bandOf(pct);
    paintGauge('gauge-arc', 'gauge-num', 'gauge', pct);
    paintGauge('gauge-arc2', 'gauge-num2', 'gauge2', pct);
    for (const id of ['score-band', 'score-band2']) {
      const el = $(id);
      if (el) { el.dataset.band = b; el.textContent = bandTxt(b); }
    }
    const pctEl = $('score-pct'); if (pctEl) pctEl.textContent = pct + '%';
    const qt = $('q-total'); if (qt) qt.textContent = String(s.queriesAsked ?? 0);
    const qh = $('q-hit'); if (qh) qh.textContent = String(s.queriesMentioned ?? 0);
    const ms = $('mini-sub');
    if (ms) ms.textContent = `הופעתם ב-${s.queriesMentioned} מתוך ${s.queriesAsked} תשובות`;
    const v = $('verdict');
    if (v) { if (s.verdict) { v.textContent = s.verdict; v.removeAttribute('hidden'); } else v.setAttribute('hidden', ''); }
    show($('score-mini'));
  };

  const renderAnswers = (answers: any[]) => {
    const wrap = $('answers');
    if (!wrap) return;
    wrap.innerHTML = '';
    for (const a of answers || []) {
      const c = document.createElement('div');
      c.className = 'q-card' + (a.mentioned ? ' hit' : '');
      const q = document.createElement('p'); q.className = 'q-q'; q.textContent = a.q;
      const tag = document.createElement('span'); tag.className = 'q-tag';
      tag.textContent = a.mentioned ? '✓ הופעתם בתשובה' : '✕ לא הופעתם';
      c.append(q, tag);
      wrap.appendChild(c);
    }
  };

  // ── Markdown → HTML · התוכן מגיע ממודל, אז מבריחים כל תו לפני עיצוב ──
  const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  const inline = (s: string) =>
    esc(s).replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/`([^`]+)`/g, '<code>$1</code>');
  const cells = (line: string) => line.replace(/^\||\|$/g, '').split('|').map((c) => c.trim());
  const mdToHtml = (md: string) => {
    const lines = (md || '').split('\n');
    const out: string[] = [];
    let list: string[] = [];
    const flush = () => { if (list.length) { out.push('<ul>' + list.join('') + '</ul>'); list = []; } };
    for (let i = 0; i < lines.length; i++) {
      const line = lines[i].trimEnd();
      // טבלה · | a | b | ואחריה | --- | --- |
      if (/^\s*\|.*\|/.test(line) && /^\s*\|[\s:|-]+\|/.test(lines[i + 1] || '')) {
        flush();
        const head = cells(line);
        let body = '';
        i += 2;
        while (i < lines.length && /^\s*\|.*\|/.test(lines[i])) {
          body += '<tr>' + cells(lines[i]).map((c) => `<td>${inline(c)}</td>`).join('') + '</tr>';
          i++;
        }
        i--;
        out.push('<div class="tbl-wrap"><table><thead><tr>' + head.map((c) => `<th>${inline(c)}</th>`).join('') + '</tr></thead><tbody>' + body + '</tbody></table></div>');
        continue;
      }
      if (/^#{3}\s+/.test(line)) { flush(); out.push('<h4>' + inline(line.replace(/^#{3}\s+/, '')) + '</h4>'); }
      else if (/^#{2}\s+/.test(line)) { flush(); out.push('<h3>' + inline(line.replace(/^#{2}\s+/, '')) + '</h3>'); }
      else if (/^[*-]\s+/.test(line)) list.push('<li>' + inline(line.replace(/^[*-]\s+/, '')) + '</li>');
      else if (/^\d+\.\s+/.test(line)) list.push('<li>' + inline(line.replace(/^\d+\.\s+/, '')) + '</li>');
      else if (!line.trim()) flush();
      else { flush(); out.push('<p>' + inline(line) + '</p>'); }
    }
    flush();
    return out.join('');
  };

  // החנות שנסרקה · לשימוש בסימן המים של המאמר. נלכד מ-status.host.
  let scanHost = '';

  /** פותח את המאמר המלא בשכבה · נעים יותר מלנווט החוצה ולאבד את העמוד. */
  const openReader = (a: any) => {
    const t = $('reader-t'); if (t) t.textContent = a.title || 'מאמר';
    const m = $('reader-meta');
    if (m) m.textContent = `${(a.md || '').split(/\s+/).filter(Boolean).length} מילים · ${(a.sources || []).length} מקורות`;
    const b = $('reader-md');
    if (b) {
      // "למה כתבנו לך את זה" · תיחום צבעוני בראש המאמר, מסביר איזו שאלת קונה הוא מכסה
      const wh = a.why
        ? `<div class="why-box"><p class="why-t">למה כתבנו לכם את המאמר הזה</p><p>${esc(a.why)}</p></div>`
        : '';
      // "בקצרה ל-AI" · takeaways
      const tk = (a.takeaways || []).length
        ? '<div class="tldr"><p class="tldr-t">בקצרה</p><ul>' + a.takeaways.map((x: string) => `<li>${esc(x)}</li>`).join('') + '</ul></div>'
        : '';
      // FAQ · שאלות ותשובות בסוף
      const fq = (a.faq || []).length
        ? '<div class="faq"><h3>שאלות ותשובות</h3>' + a.faq.map((f: any) => `<div class="faq-i"><p class="faq-q">${esc(f.q)}</p><p class="faq-a">${esc(f.a)}</p></div>`).join('') + '</div>'
        : '';
      // סימן מים · ייחוס עדין. לא חוסם את המתנה, אבל כל דליפה נושאת את המותג.
      const wm = `<p class="art-wm">מאמר שנכתב על ידי <strong>Scayla</strong>${scanHost ? ` עבור ${esc(scanHost)}` : ''} · scayla.co.il</p>`;
      b.innerHTML = wh + tk + mdToHtml(a.md || '') + fq + wm;
    }
    const s = $('reader-src');
    if (s) {
      s.innerHTML = (a.sources || []).length
        ? '<div class="art-src"><p class="art-src-t">מקורות</p><ol>' +
          a.sources.map((x: any) => `<li><a href="${esc(x.uri || '#')}" target="_blank" rel="noopener nofollow">${esc(x.domain || '')}</a></li>`).join('') +
          '</ol></div>'
        : '';
    }
    show($('reader'));
    document.body.style.overflow = 'hidden';
    $('reader')?.scrollTo({ top: 0 });
  };
  const closeReader = () => { hide($('reader')); document.body.style.overflow = ''; };
  $('reader-close')?.addEventListener('click', closeReader);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeReader(); });

  // מיתוג-העתקה · לא חוסם (המאמר הוא מתנה מלאה), אבל כל טקסט שמעתיקים
  // מהמאמר נושא ייחוס ל-Scayla · דליפה הופכת לפרסומת שמובילה חזרה אלינו.
  $('reader-md')?.addEventListener('copy', (e: any) => {
    const sel = String(document.getSelection() || '');
    if (sel.length < 40 || !e.clipboardData) return;
    e.clipboardData.setData('text/plain', `${sel}\n\n— מאמר מאת Scayla · scayla.co.il`);
    e.preventDefault();
  });

  const renderArts = (arts: any[]) => {
    const wrap = $('arts');
    if (!wrap) return;
    wrap.innerHTML = '';
    (arts || []).forEach((a, i) => {
      const card = document.createElement('article');
      card.className = 'art';

      const h = document.createElement('h3'); h.className = 'art-t'; h.textContent = a.title || 'מאמר';
      const meta = document.createElement('p'); meta.className = 'art-meta';
      meta.innerHTML = `<span class="num">${(a.md || '').split(/\s+/).filter(Boolean).length}</span> מילים · <span class="num">${(a.sources || []).length}</span> מקורות`;
      card.append(h, meta);

      if (a.shelved) {
        const n = document.createElement('p'); n.className = 'art-flag';
        n.textContent = 'הבקרה שלנו סימנה כאן דברים לשיפור · המאמר מוצג כמו שהוא, בלי לייפות.';
        card.appendChild(n);
      }

      // תקציר · "למה כתבנו לך את זה", מדליק, לא הפסקה הראשונה של הגוף
      const ex = document.createElement('p'); ex.className = 'art-ex';
      ex.textContent = a.why || (a.md || '').split('\n').find((l: string) => l.trim() && !l.startsWith('#'))?.replace(/[*_`#]/g, '').slice(0, 300) || '';
      card.appendChild(ex);

      const go = document.createElement('button');
      go.className = 'btn btn-gold art-go'; go.type = 'button';
      go.textContent = 'לקריאת המאמר המלא';
      go.addEventListener('click', () => openReader(a));
      card.appendChild(go);

      wrap.appendChild(card);
    });
  };

  // ── מצב ──
  let jobId: string | null = null;
  let startedAt = 0;
  let timer: any = null;
  const startClock = () => {
    clearInterval(timer);
    const t = $('run-elapsed');
    const tick = () => { if (t) t.textContent = mmss(Date.now() - startedAt); };
    tick();
    timer = setInterval(tick, 1000);
  };
  const fail = (t: string, p: string) => {
    clearInterval(timer);
    const a = $('err-t'), b = $('err-p');
    if (a) a.textContent = t;
    if (b) b.textContent = p;
    screen('screen-error');
  };

  const apply = (st: any) => {
    if (st.startedAt) startedAt = st.startedAt;
    if (st.host || st.store?.host) scanHost = st.host || st.store.host;
    if (st.score) { paintScore(st.score); renderAnswers(st.score.answers || []); }
    switch (st.phase) {
      case 'scanning':
      case 'score':
      case 'generating':
        renderLog([...(st.scan?.steps || []), ...(st.gen?.steps || [])]);
        screen('screen-run'); startClock(); break;
      case 'done':
        clearInterval(timer);
        renderArts(st.articles || []);
        screen('screen-done'); break;
      case 'error':
        fail(st.error?.title || 'משהו לא עבד', st.error?.message || 'נסו שוב בעוד כמה דקות.'); break;
    }
  };

  let delay = 2000;
  const poll = async () => {
    if (!jobId) return;
    try {
      const r = await fetch(`/api/scan/status?job=${encodeURIComponent(jobId)}`);
      if (!r.ok) throw new Error(String(r.status));
      const st = await r.json();
      apply(st);
      if (['done', 'error'].includes(st.phase)) return;
      delay = Math.min(10000, delay * 1.3);
      setTimeout(poll, delay);
    } catch { setTimeout(poll, 5000); }
  };

  // ── מסך 1 → 2 ──
  ($('form-idle') as HTMLFormElement | null)?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErr('store'); hide($('e-summary'));
    const store = ($('store') as HTMLInputElement).value;
    if (!store.trim()) { setErr('store', 'כתבו את כתובת החנות · לדוגמה example.co.il'); return; }
    if (!okHost(store)) { setErr('store', 'הכתובת לא נראית תקינה · לדוגמה example.co.il'); return; }

    const btn = $('go') as HTMLButtonElement;
    btn.setAttribute('aria-busy', 'true'); btn.textContent = 'מתחילים...';
    const h = $('run-host'); if (h) h.textContent = cleanHost(store);
    try {
      const ts = (document.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement)?.value || '';
      const r = await fetch('/api/scan', {
        method: 'POST', headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          store: cleanHost(store), blog: ($('blog') as HTMLInputElement).value.trim(),
          company_website: ($('company-website') as HTMLInputElement).value, cf_turnstile_response: ts,
        }),
      });
      const j = await r.json();
      if (!r.ok) {
        btn.removeAttribute('aria-busy'); btn.textContent = 'קדימה, בואו נראה';
        const m: Record<string, string> = {
          bad_url: 'הכתובת לא נראית תקינה · בדקו ונסו שוב.',
          turnstile: 'אימות האבטחה לא עבר · רעננו את העמוד ונסו שוב.',
          scan_cap: 'הגענו לתקרת הבדיקות להיום · נסו שוב מחר.',
          ip_cap: 'ביצעתם כמה בדיקות היום · נסו שוב מחר, או דברו איתנו לבדיקה של עוד חנויות.',
        };
        const el = $('e-summary');
        if (el) { el.textContent = m[j.error] || 'הבדיקה לא זמינה כרגע · נסו שוב בעוד כמה דקות.'; show(el); }
        return;
      }
      jobId = j.jobId;
      try { sessionStorage.setItem('scaylaScanJob', jobId!); } catch {}
      history.replaceState(null, '', `/scan/${jobId}`);
      // השעון מתחיל רק כאן · לא הצגנו "0:00 רץ כבר" לפני שהייתה פעולה
      startedAt = Date.now();
      apply({ phase: 'scanning', scan: j.scan });
      poll();
    } catch {
      btn.removeAttribute('aria-busy'); btn.textContent = 'קדימה, בואו נראה';
      const el = $('e-summary');
      if (el) { el.textContent = 'לא הצלחנו להתחיל · בדקו את החיבור ונסו שוב.'; show(el); }
    }
  });

  // ── מייל · רישום, לא שער ──
  ($('form-mail') as HTMLFormElement | null)?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErr('email'); hide($('e-mail'));
    const email = ($('email') as HTMLInputElement).value;
    if (!okEmail(email)) { setErr('email', 'כתבו כתובת מייל תקינה כדי שנוכל לעדכן אתכם.'); return; }
    const btn = $('go-mail') as HTMLButtonElement;
    btn.setAttribute('aria-busy', 'true'); btn.textContent = 'שומרים...';
    try {
      const r = await fetch('/api/scan/email', {
        method: 'POST', headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ jobId, name: ($('gname') as HTMLInputElement).value.trim(), email: email.trim() }),
      });
      btn.removeAttribute('aria-busy'); btn.textContent = 'עדכנו אותי במייל';
      if (!r.ok) { const el = $('e-mail'); if (el) { el.textContent = 'לא הצלחנו לשמור · נסו שוב.'; show(el); } return; }
      const ms = $('mail-shown'); if (ms) ms.textContent = email.trim();
      hide($('form-mail')); show($('mail-ok'));
    } catch {
      btn.removeAttribute('aria-busy'); btn.textContent = 'עדכנו אותי במייל';
      const el = $('e-mail'); if (el) { el.textContent = 'לא הצלחנו לשמור · בדקו את החיבור ונסו שוב.'; show(el); }
    }
  });

  $('err-back')?.addEventListener('click', () => {
    history.replaceState(null, '', '/scan');
    try { sessionStorage.removeItem('scaylaScanJob'); } catch {}
    const btn = $('go') as HTMLButtonElement;
    btn.removeAttribute('aria-busy'); btn.textContent = 'קדימה, בואו נראה';
    screen('screen-idle');
  });

  // ── חזרה לריצה קיימת · /scan/<id> ──
  const fromPath = (location.pathname.match(/^\/scan\/([a-z0-9-]{6,60})\/?$/) || [])[1] || null;
  const resume = fromPath || (() => { try { return sessionStorage.getItem('scaylaScanJob'); } catch { return null; } })();
  if (resume) { jobId = resume; startedAt = Date.now(); poll(); }

  // ── Turnstile ──
  const slot = $('ts-slot');
  if (slot) {
    const s = document.createElement('script');
    s.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
    s.async = true; s.defer = true;
    document.head.appendChild(s);
    slot.classList.add('cf-turnstile');
    slot.setAttribute('data-theme', 'auto');
    slot.setAttribute('data-language', 'he');
  }
</script>
