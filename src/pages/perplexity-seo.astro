---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import InstallCtaPair from '../components/InstallCtaPair.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import AnswerViewer from '../components/AnswerViewer.astro';

const title = 'איך להופיע ב-Perplexity · Scayla';
const description =
  'איך להופיע ב-Perplexity עם חנות שופיפיי: המנוע מצרף לכל תשובה מקורות עם קישור · ציטוט שם מביא לכם תנועה אמיתית, לא רק אזכור.';

const canonicalPath = '/perplexity-seo';
const authorName = 'נוי קייטל';
const authorUrl = 'https://scayla.co.il/experts/noy-keitel';
const datePublished = '2026-06-15';
const dateModified = '2026-07-17';
const updatedLabel = 'עודכן 17 ביולי 2026';

const faq = [
  {
    q: 'מה מיוחד ב-Perplexity לעומת ChatGPT?',
    a: 'Perplexity מצרף לכל תשובה רשימת מקורות עם קישור ומספר הערה. אזכור שם הוא לא רק קרדיט · הוא קליק אפשרי לחנות. ב-ChatGPT קונה קורא את התשובה ולפעמים מחפש אתכם אחר כך; ב-Perplexity הוא לוחץ על ההערה ומגיע ישר אליכם.',
  },
  {
    q: 'איך נכנסים לרשימת המקורות של Perplexity?',
    a: 'Perplexity שולף מקורות שנחשבים אמינים ורלוונטיים לשאלה: עמודים שעונים ישירות, מצוטטים במקומות אחרים ובנויים היטב. Scayla בונה בדיוק את התוכן הזה · מאמרים עם נתונים, FAQ וסכמות · ובודקת אם אתם מופיעים כמקור ובאיזה מיקום.',
  },
  {
    q: 'האם תנועה מ-Perplexity נמדדת?',
    a: 'כן. קליק ממקור ב-Perplexity מגיע לחנות כמו כל מבקר, ונרשם ב-GA4 שאליו Scayla מחוברת. אז מלבד ציון הנראות אתם רואים גם אם הציטוט הפך לביקורים אמיתיים · לא רק אזכור על המסך.',
  },
  {
    q: 'כמה קונים בישראל משתמשים ב-Perplexity?',
    a: 'פחות מ-ChatGPT, אבל מי שכן משתמש נמצא בדרך כלל בשלב מחקר עמוק · משווה, בודק מקורות, קרוב להחלטה. פחות תנועה, כוונה גבוהה יותר. לכן זה מנוע ששווה להיות בו מקור, גם אם הוא לא הראשון שתקדמו בו.',
  },
  {
    q: 'האם צריך תוכן שונה ל-Perplexity מאשר ל-ChatGPT?',
    a: 'הבסיס זהה: תשובה ישירה, מבנה ברור וסכמות. ההבדל הוא בדגש. Perplexity מתגמל עמודים עם נתונים מדויקים שאפשר לצטט מהם עובדה בודדת, ומעדיף מקור שמכסה נושא לעומק על פני פסקה קצרה. אותו עמוד טוב עובד בשני המנועים, אבל ב-Perplexity שווה להוסיף מספרים אמיתיים שאפשר להצביע עליהם.',
  },
  {
    q: 'האם אפשר לשלם כדי להיכנס לתשובה של Perplexity?',
    a: 'לא. אין מיקום ממומן שמכניס חנות לרשימת המקורות. Perplexity בוחר מקורות לפי רלוונטיות, בהירות ואמינות של התוכן עצמו. לכן נראות שם נבנית עם עמודים טובים ולא עם תקציב פרסום.',
  },
];

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'איך להופיע ב-Perplexity · קידום חנות שופיפיי',
  description,
  inLanguage: 'he',
  mainEntityOfPage: `https://scayla.co.il${canonicalPath}`,
  image: 'https://scayla.co.il/og.png',
  datePublished,
  dateModified,
  author: { '@type': 'Person', name: authorName, url: authorUrl },
  publisher: {
    '@type': 'Organization',
    name: 'Scayla',
    url: 'https://scayla.co.il/',
    logo: { '@type': 'ImageObject', url: 'https://scayla.co.il/favicon-32.png' },
  },
  about: ['Perplexity', 'נראות במנועי AI', 'GEO', 'ציטוט מקורות', 'קידום אורגני', 'שופיפיי'],
};

const howToLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'איך הופכים למקור מצוטט ב-Perplexity',
  description: 'ארבעה צעדים שהופכים חנות שופיפיי למקור עם קישור בתשובות של Perplexity.',
  inLanguage: 'he',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'עונים על שאלה שלמה בעמוד אחד', text: 'Perplexity מעדיף עמוד שמכסה נושא לעומק ולא פסקה קצרה. מדריך קנייה מלא בעברית הופך אתכם למקור טבעי לצטט.' },
    { '@type': 'HowToStep', position: 2, name: 'משלבים נתונים ומספרים אמיתיים', text: 'המנוע מעדיף מקור שאפשר לצטט ממנו עובדה מדויקת · טווח מחירים, כמות, זמן משלוח · על פני טקסט שיווקי כללי.' },
    { '@type': 'HowToStep', position: 3, name: 'מוודאים שהעמוד נטען ונסרק', text: 'מקור שלא נטען מהר או חסום מסריקה לא ייכנס לרשימה. תיקונים טכניים וסכמות עושים את ההבדל בין להיות מקור לבין להיות בלתי נראה.' },
    { '@type': 'HowToStep', position: 4, name: 'עוקבים אחרי הקליקים ולא רק האזכור', text: 'הופעה כמקור שווה רק אם היא מביאה ביקורים. בודקים ב-GA4 אם התנועה מ-Perplexity עולה · שם ההוכחה שהמנוע מחזיר תנועה.' },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={[{ name: 'הופעה ב-Perplexity', path: canonicalPath }]}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(howToLd)} slot="head" />

  <section class="svc-hero">
    <div class="wrap center">
      <span class="eyebrow">קידום ל-Perplexity</span>
      <h1>איך להופיע ב-Perplexity · המנוע שבו ציטוט הופך לקליק</h1>
      <p class="byline">מאת <a href={authorUrl}>{authorName}</a> · {updatedLabel}</p>
      <p class="lede">
        Perplexity שונה משאר המנועים: לכל תשובה הוא מצרף מקורות עם קישור. כשאתם מופיעים שם,
        הקונה לא רק קורא את השם שלכם · הוא לוחץ ומגיע לחנות. Scayla בודקת אם אתם ברשימת
        המקורות ובונה את התוכן שמכניס אתכם אליה.
      </p>
      <InstallCtaPair center variant="hero" />
      <p class="cta-note">אבחון נראות ב-Perplexity חינם · תוך דקות מההתקנה</p>
    </div>
  </section>

  <section class="svc-tldr">
    <div class="narrow">
      <div class="tldr card">
        <span class="tldr-tag">בקצרה</span>
        <p>
          הופעה ב-Perplexity פירושה להיכנס לרשימת המקורות המצוטטים שהמנוע מצרף לכל תשובה, כי
          שם כל אזכור הוא קישור לחיץ שמביא קליק ישיר לחנות. אי אפשר לשלם על מיקום: המנוע בוחר
          מקורות ברורים, מבוססי נתונים ונסרקים. משפרים נראות עם עמודים שעונים לעומק, ומודדים
          את הקליקים ב-GA4. Scayla עושה את שני החלקים מתוך החנות.
        </p>
      </div>
    </div>
  </section>

  <section class="svc-body alt-bg">
    <div class="narrow">
      <div class="sh">
        <span class="eyebrow">הבסיס</span>
        <h2>מה מייחד את Perplexity ולמה הוא שווה מקום?</h2>
      </div>
      <div class="prose">
        <p>
          Perplexity הוא מנוע תשובות (answer engine) שבנוי סביב עיקרון אחד שמבדיל אותו מ-ChatGPT
          ומ-Gemini: הוא כמעט אף פעם לא עונה בלי לצטט. ליד כל טענה בתשובה הוא שם מספר הערה, ובצד
          מופיעה רשימת מקורות עם קישור לחיץ. בפועל זה אומר שהתשובה עצמה היא מפת דרכים · הקונה
          קורא את ההמלצה, ואם הוא רוצה לבדוק לעומק הוא לוחץ על המקור ומגיע ישירות לעמוד שלכם.
        </p>
        <p>
          ההבדל הזה הוא לא ניואנס. ב-ChatGPT, גם כשהחנות שלכם מוזכרת, הקונה צריך לזכור את השם,
          לפתוח כרטיסייה חדשה ולחפש אתכם בגוגל · שלב שרבים לא עושים. ב-Perplexity אזכור כמקור הוא
          כפתור: הדרך הקצרה ביותר ממנוע AI אל דף מוצר בחנות. לכן, גם אם נפח השאלות ב-Perplexity
          קטן יותר, כל הופעה כמקור שווה יותר, כי היא מתורגמת ישירות לתנועה מדידה ולא רק להיכרות.
        </p>
      </div>
    </div>
  </section>

  <section class="svc-body">
    <div class="narrow">
      <div class="sh">
        <span class="eyebrow">ההבדל שחשוב להבין</span>
        <h2>אזכור ב-ChatGPT מול מקור מצוטט ב-Perplexity</h2>
        <p>אותו קונה, שתי דרכים שונות שבהן הוא פוגש אתכם. ככה זה נראה זה מול זה:</p>
      </div>
      <div class="tbl-wrap">
        <table class="cmp">
          <thead>
            <tr><th></th><th>אזכור ב-ChatGPT</th><th>מקור מצוטט ב-Perplexity</th></tr>
          </thead>
          <tbody>
            <tr><th>איך אתם מופיעים</th><td>שם בתוך פסקת תשובה</td><td>שם עם הערת מקור וקישור לחיץ</td></tr>
            <tr><th>מה הקונה עושה כדי להגיע</th><td>זוכר את השם ומחפש בנפרד</td><td>לוחץ על המקור ומגיע ישר לחנות</td></tr>
            <tr><th>נפח שאלות בישראל</th><td>הגדול ביותר</td><td>קטן יותר, אבל בכוונת קנייה גבוהה</td></tr>
            <tr><th>מה המנוע אוהב לצטט</th><td>תשובה ישירה וברורה</td><td>עמוד לעומק עם נתונים שאפשר לצטט</td></tr>
            <tr><th>איך מודדים הצלחה</th><td>אחוז הופעה במדגם שאילתות</td><td>הופעה כמקור · ואז קליקים ב-GA4</td></tr>
          </tbody>
        </table>
      </div>
      <p class="svc-note center">
        השורה התחתונה · ב-ChatGPT נלחמים על אזכור, וב-Perplexity על מקור עם קישור שמחזיר תנועה.
      </p>
    </div>
  </section>

  <section class="svc-body alt-bg">
    <div class="narrow">
      <div class="sh">
        <span class="eyebrow">המנגנון</span>
        <h2>איך Perplexity בוחר את מי לשים ברשימת המקורות?</h2>
      </div>
      <div class="prose">
        <p>
          Perplexity לא "מדרג" עמודים כמו גוגל. כשמישהו שואל שאלה, הוא מריץ חיפוש, בורר קומץ
          מקורות שהוא סומך עליהם, ומרכיב מהם תשובה עם ציטוטים. ההבדל בין להיות אחד המקורות לבין
          להיות שקוף לגמרי מוכרע בשלושה דברים · והם גם אלה שתוכלו להשפיע עליהם.
        </p>
      </div>
      <div class="bgrid three">
        <div class="b card fade-up">
          <h3>עמוד שעונה לעומק</h3>
          <p>המנוע מעדיף מקור שמכסה נושא שלם ואפשר לשאוב ממנו כמה עובדות · מדריך קנייה מלא, לא פסקת תדמית קצרה. ככל שהעמוד ממצה, כך גדל הסיכוי שייבחר.</p>
        </div>
        <div class="b card fade-up">
          <h3>נתונים שאפשר לצטט</h3>
          <p>Perplexity אוהב עובדות מדויקות שאפשר להצביע עליהן · טווח מחירים, זמני משלוח, כמויות, מפרט. מספר קונקרטי בעמוד קל יותר לציטוט מטקסט שיווקי כללי.</p>
        </div>
        <div class="b card fade-up">
          <h3>אמון ונגישות טכנית</h3>
          <p>מקור צריך להיטען מהר, להיות פתוח לסריקה ולהיות מוזכר גם במקומות אחרים. סכמות תקינות ומבנה ברור אומרים למנוע שהעמוד אמין ומובן.</p>
        </div>
      </div>
      <p class="svc-note center">
        המכניקה הזו חופפת לשאר המנועים · לכן משתלם לבנות אותה פעם אחת נכון. העיקרון המלא בעמוד
        <a href="/geo">אופטימיזציה למנועי AI · GEO</a>.
      </p>
    </div>
  </section>

  <section class="svc-demo">
    <div class="wrap">
      <div class="sh">
        <span class="eyebrow">ככה זה נראה</span>
        <h2>שאלה עם מקורות · אתם ברשימה או מחוצה לה</h2>
        <p>Scayla מציגה את תשובת Perplexity על הקטגוריה שלכם, עם השם שלכם כמקור · או חסר.</p>
      </div>
      <div class="engines">
        <div class="engine-panel card fade-up">
          <AnswerViewer
            question="מה החנויות המומלצות לציוד קמפינג בישראל?"
            engine="Perplexity"
            gapText="<b>לא ברשימת המקורות.</b> אין קישור אליכם · Scayla בונה את התוכן שנכנס אליה."
          >
            לציוד קמפינג בולטות <span class="hl-red">אוטדור זון</span> ו
            <span class="hl-red">טרק שופ</span>, לפי מדריכי ציוד וביקורות משתמשים.
          </AnswerViewer>
        </div>
        <div class="engine-panel card fade-up">
          <AnswerViewer
            question="מה החנויות המומלצות לציוד קמפינג בישראל?"
            engine="Perplexity"
            presentText="<b>אתם מקור עם קישור.</b> הערת המקור הפכה לכפתור לחיץ לחנות."
          >
            בין המומלצות: <span class="hl-grn">החנות שלכם</span> עם מדריך ציוד מפורט
            ואחריות שטח, וגם <span class="hl-red">אוטדור זון</span>.
          </AnswerViewer>
        </div>
      </div>
      <p class="svc-note center">
        התשובות כאן להמחשה. באפליקציה תראו אם אתם מקור על השאלות של הקטגוריה · והעיקרון
        המלא ב<a href="/geo">אופטימיזציה למנועי AI · GEO</a>.
      </p>
    </div>
  </section>

  <section class="svc-guide alt-bg">
    <div class="narrow">
      <div class="sh">
        <span class="eyebrow">מדריך מהיר</span>
        <h2>איך הופכים למקור מצוטט ב-Perplexity · ארבעה צעדים</h2>
      </div>
      <ol class="guide">
        <li class="card fade-up">
          <span class="gn num">1</span>
          <div>
            <h3>ענו על שאלה שלמה בעמוד אחד</h3>
            <p>Perplexity אוהב עמוד שמכסה נושא לעומק · לא פסקה קצרה. מדריך קנייה מלא הופך אתכם למקור טבעי לצטט.</p>
          </div>
        </li>
        <li class="card fade-up">
          <span class="gn num">2</span>
          <div>
            <h3>שימו נתונים ומספרים אמיתיים</h3>
            <p>המנוע מעדיף מקור שאפשר לצטט ממנו עובדה מדויקת · טווח מחירים, כמות, זמן משלוח · על פני טקסט שיווקי כללי.</p>
          </div>
        </li>
        <li class="card fade-up">
          <span class="gn num">3</span>
          <div>
            <h3>ודאו שהעמוד נטען ונסרק</h3>
            <p>מקור שלא נטען מהר או חסום מסריקה לא ייכנס לרשימה. תיקונים טכניים וסכמות עושים את ההבדל בין להיות מקור לבין להיות בלתי נראה.</p>
          </div>
        </li>
        <li class="card fade-up">
          <span class="gn num">4</span>
          <div>
            <h3>עקבו אחרי הקליקים, לא רק האזכור</h3>
            <p>ההופעה כמקור שווה רק אם היא מביאה ביקורים. בדקו ב-GA4 אם התנועה מ-Perplexity עולה · ושם ההוכחה.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <section class="svc-body">
    <div class="narrow">
      <div class="sh">
        <span class="eyebrow">מהאזכור לתנועה</span>
        <h2>למה הופעה ב-Perplexity שווה למדוד עד הקליק?</h2>
      </div>
      <div class="prose">
        <p>
          במנועים אחרים ההצלחה נמדדת באחוז ההופעה: באיזה חלק מהתשובות אתם מוזכרים. זו מדידה חשובה,
          אבל היא נעצרת על המסך. ב-Perplexity אפשר להמשיך צעד אחד קדימה, כי כל מקור הוא קישור. קליק
          על ההערה מגיע לחנות כמו כל מבקר אחר, ונרשם ב-GA4 שאליו Scayla מחוברת. מכאן אתם רואים לא רק
          שהמנוע ציטט אתכם, אלא שהציטוט הפך לביקור אמיתי · ובהמשך גם לפעולה בחנות.
        </p>
        <p>
