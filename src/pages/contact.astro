---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'צרו קשר · Scayla';
const description =
  'קבעו דמו, שאלו שאלה או דברו איתנו על החנות שלכם · צוות Scayla עונה מהר, בעברית.';
---

<BaseLayout title={title} description={description}>
  <section class="contact-hero">
    <div class="narrow center">
      <span class="eyebrow">צרו קשר</span>
      <h1>דברו איתנו · בני אדם, לא בוט</h1>
      <p class="lede">
        שאלה על המוצר, על תמחור, או סתם רוצים לוודא שזה מתאים לחנות שלכם? כתבו לנו ונחזור אליכם מהר.
      </p>
    </div>
  </section>

  <section class="contact-body">
    <div class="wrap grid">
      <div id="demo" class="demo card fade-up">
        <h2>קבעו דמו</h2>
        <p>
          15 דקות, אחד על אחד: נריץ אבחון חי על החנות שלכם, נראה לכם בדיוק איפה אתם
          מופיעים (ואיפה לא) בתשובות ה-AI, ונענה על כל שאלה.
        </p>
        <p>
          מלאו את הטופס עם כתובת החנות וכתבו "דמו" בהודעה · נחזור אליכם לתיאום.
        </p>
        <a class="btn btn-solid" href="#contact-form">לטופס ←</a>
      </div>

      <form id="contact-form" class="form card fade-up" method="post" action="/api/contact">
        <h2>שלחו הודעה</h2>
        <p class="form-note">נענה מהר, בעברית · בדרך כלל תוך יום עסקים.</p>
        {/* honeypot · בוטים ממלאים, בני אדם לא רואים */}
        <input type="text" name="company" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <div class="field">
          <label for="cf-name">שם מלא</label>
          <input id="cf-name" name="name" type="text" autocomplete="name" required />
        </div>
        <div class="field">
          <label for="cf-email">אימייל</label>
          <input id="cf-email" name="email" type="email" autocomplete="email" dir="ltr" required />
        </div>
        <div class="field">
          <label for="cf-store">כתובת החנות <span class="opt">(לא חובה)</span></label>
          <input id="cf-store" name="store" type="url" placeholder="https://" dir="ltr" />
        </div>
        <div class="field">
          <label for="cf-msg">איך נוכל לעזור?</label>
          <textarea id="cf-msg" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-solid">שליחה</button>
        <p id="form-status" class="form-status" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero { padding-block-end: 8px; }
  .grid {
    display: grid; grid-template-columns: 1fr 1.2fr; gap: 18px; align-items: start;
  }
  @media (max-width: 820px) { .grid { grid-template-columns: 1fr; } }
  .demo, .form { padding: 28px; border-radius: 18px; }
  .demo h2, .form h2 { font-size: 22px; margin-block-end: 10px; }
  .demo p { font-size: 14.5px; margin-block-end: 18px; }
  .demo .placeholder-box { margin-block-end: 18px; }
  .form-note { font-size: 12.5px; color: var(--sc-disabled); margin-block-end: 18px; }
  .field { display: grid; gap: 6px; margin-block-end: 16px; }
  label { font-size: 13.5px; font-weight: 700; color: var(--sc-ink); }
  .opt { font-weight: 500; color: var(--sc-disabled); }
  input, textarea {
    font-family: var(--sc-font);
    font-size: 14.5px;
    color: var(--sc-ink);
    background: var(--sc-paper);
    border: 1px solid var(--sc-hair);
    border-radius: 10px;
    padding: 11px 14px;
    inline-size: 100%;
    transition: border-color var(--sc-fast);
  }
  input:focus-visible, textarea:focus-visible {
    outline: 2px solid var(--sc-accent-text);
    outline-offset: 1px;
    border-color: var(--sc-accent-text);
  }
  textarea { resize: vertical; }
  /* honeypot · off-screen, never shown to humans */
  .hp { position: absolute; inset-inline-start: -9999px; inline-size: 1px; block-size: 1px; overflow: hidden; opacity: 0; }
  .form-status { font-size: 14px; font-weight: 700; margin-block-start: 14px; min-block-size: 20px; }
  .form-status.ok { color: var(--sc-pos); }
  .form-status.err { color: #d3455b; }
  button[disabled] { opacity: .6; cursor: progress; }
</style>

<script>
  // Progressive enhancement · POST the form as JSON to the CF Pages Function,
  // show inline success/error. Native POST to /api/contact is the no-JS fallback.
  const form = document.getElementById('contact-form');
  const statusEl = document.getElementById('form-status');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    const data = Object.fromEntries(new FormData(form));
    statusEl.className = 'form-status';
    statusEl.textContent = '';
    const label = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'שולח…';
    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(data),
      });
      const j = await res.json().catch(() => ({}));
      if (res.ok && j.ok) {
        form.reset();
        statusEl.textContent = 'תודה! ההודעה נשלחה · נחזור אליכם מהר.';
        statusEl.classList.add('ok');
      } else {
        statusEl.textContent = j.error || 'משהו השתבש · נסו שוב או כתבו ל-lior@mrmake.co.il';
        statusEl.classList.add('err');
      }
    } catch {
      statusEl.textContent = 'אין חיבור · נסו שוב או כתבו ישירות ל-lior@mrmake.co.il';
      statusEl.classList.add('err');
    } finally {
      btn.disabled = false;
      btn.textContent = label;
    }
  });
</script>
