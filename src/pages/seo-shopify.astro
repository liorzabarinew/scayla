---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import InstallCtaPair from '../components/InstallCtaPair.astro';
import FaqAccordion from '../components/FaqAccordion.astro';

const title = 'קידום אורגני לשופיפיי (Shopify) · מדריך SEO לחנות · Scayla';
const description =
  'קידום אורגני לחנות שופיפיי: איך עובד SEO ב-Shopify · קולקציות מול עמודי מוצר, URL כפולים וקנוניקל, מטאדאטה, סכמות ו-sitemap. מדריך + מכונה שמתקנת אוטומטית, מ-$39 לחודש.';

const canonicalPath = '/seo-shopify';
const authorName = 'נוי קייטל';
const authorUrl = 'https://scayla.co.il/experts/noy-keitel';
const datePublished = '2026-06-15';
const dateModified = '2026-07-17';
const updatedLabel = 'עודכן 17 ביולי 2026';

const faq = [
  {
    q: 'איך עושים קידום אורגני לחנות שופיפיי בלי לדעת SEO?',
    a: 'עם Scayla אתם לא צריכים לדעת SEO. המכונה סורקת את החנות, מזהה מה חוסם אתכם בגוגל · כותרות חלשות, תיאורים חסרים, סכמות Product, URL כפולים ועמודי 404 · ומכינה את התיקונים. אתם מאשרים בקליק, והכל הפיך.',
  },
  {
    q: 'כמה עולה קידום חנות שופיפיי?',
    a: 'סוכנות SEO גובה בדרך כלל אלפי שקלים בחודש. Scayla מתחילה ב-$39 לחודש, בחיוב דרך Shopify, עם 14 יום ניסיון חינם · והיא היחידה שמקדמת אתכם גם במנועי ה-AI, לא רק בגוגל.',
  },
  {
    q: 'מה ההבדל בין Scayla לאפליקציות SEO אחרות ל-Shopify?',
    a: 'רוב האפליקציות עוצרות בגוגל: מטא, מילות מפתח, sitemap. Scayla עושה את כל זה · ובנוסף מודדת ומנצחת את הנראות שלכם בתשובות של ChatGPT ו-Gemini, ששם הקונים כבר נמצאים.',
  },
  {
    q: 'האם Shopify מוגבל בקידום אורגני?',
    a: 'לא באמת. Shopify מייצר sitemap.xml אוטומטי, robots.txt סביר וסכמת מוצר בסיסית בערכות רבות. המגבלות האמיתיות הן במבנה ה-URL הקבוע (‎/products/‎ ו-‎/collections/‎), ב-URL כפולים של אותו מוצר תחת כמה קטגוריות, ובמטאדאטה שנשארת כברירת מחדל. את אלה פותרים עם קנוניקל, מטאפילדס ומטאדאטה מכוונת.',
  },
  {
    q: 'למה יש לי כמה כתובות לאותו מוצר בשופיפיי?',
    a: 'כשמוצר משויך לכמה קולקציות, Shopify יכול להגיש אותו גם תחת ‎/collections/שם/products/שם‎ וגם תחת ‎/products/שם‎. זה יוצר תוכן כפול שמפצל אותות דירוג. הפתרון הוא תג canonical שמצביע תמיד על כתובת ‎/products/‎ הנקייה, וזה בדיוק מה שמנוע התיקונים בודק.',
  },
  {
    q: 'תוך כמה זמן רואים תוצאות מקידום אורגני בשופיפיי?',
    a: 'תיקונים טכניים · קנוניקל, סכמות, מטאדאטה · נסרקים תוך ימים. שיפור אמיתי בדירוג של קטגוריה או מוצר מצטבר לאורך שבועות, אחרי שגוגל סרק את התוכן החדש והתחיל לתת בו אמון. מדידה שבועית מראה אם הכיוון נכון בלי לנחש.',
  },
];

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'קידום אורגני לשופיפיי · מדריך SEO לחנות Shopify',
  description,
  inLanguage: 'he',
  mainEntityOfPage: `https://scayla.co.il${canonicalPath}`,
  image: 'https://scayla.co.il/og.png',
  datePublished,
  dateModified,
  author: { '@type': 'Person', name: authorName, url: authorUrl },
  publisher: {
    '@type': 'Organization',
    name: 'Scayla',
    url: 'https://scayla.co.il/',
    logo: { '@type': 'ImageObject', url: 'https://scayla.co.il/favicon-32.png' },
  },
  about: ['קידום אורגני לשופיפיי', 'SEO', 'Shopify', 'קנוניקל', 'מטאפילדס', 'sitemap.xml', 'סכמת Product', 'GEO'],
};

const appLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Scayla · קידום אורגני לשופיפיי',
  description,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Shopify',
  inLanguage: 'he',
  url: `https://scayla.co.il${canonicalPath}`,
  image: 'https://scayla.co.il/og.png',
  publisher: { '@type': 'Organization', name: 'Scayla', url: 'https://scayla.co.il/' },
  offers: {
    '@type': 'Offer',
    price: '49',
    priceCurrency: 'USD',
    url: 'https://scayla.co.il/pricing',
    availability: 'https://schema.org/InStock',
  },
};

const howToLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'איך עושים קידום אורגני לחנות שופיפיי',
  description: 'חמישה צעדים שהופכים חנות Shopify לחנות שגוגל ומנועי AI מבינים ומדרגים.',
  inLanguage: 'he',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'מפים מילות מפתח לקטגוריות ולמוצרים', text: 'מרכיבים את השאילתות שקונה באמת מקליד: קטגוריות רחבות לעמודי /collections/, ומונחי מוצר מדויקים לעמודי /products/. כל כתובת מקבלת מטרה אחת.' },
    { '@type': 'HowToStep', position: 2, name: 'מתקנים את מבנה ה-URL והקנוניקל', text: 'מוודאים שכל מוצר מוגש מכתובת /products/ נקייה אחת, עם תג canonical שמצביע עליה, כדי שגרסאות /collections/…/products/ לא יפצלו את אותות הדירוג.' },
    { '@type': 'HowToStep', position: 3, name: 'כותבים מטאדאטה, כותרות ותיאורים', text: 'לכל עמוד קטגוריה ומוצר: כותרת H1 ברורה, title ו-meta description ייחודיים במקום ברירת המחדל, וטקסט תיאור שמכיל את מילת המפתח בצורה טבעית.' },
    { '@type': 'HowToStep', position: 4, name: 'מוסיפים סכמות וממלאים מטאפילדס', text: 'סכמת Product עם מחיר וזמינות, סכמת FAQPage בעמודי מידע, ומטאפילדס למאפייני מוצר שערכות ה-theme מציגות · כדי שגוגל ומנועי AI יבינו מה נמכר.' },
    { '@type': 'HowToStep', position: 5, name: 'מפרסמים sitemap, מודדים ומצטברים', text: 'מוודאים ש-sitemap.xml נשלח ל-Search Console ושה-robots.txt לא חוסם עמודים חשובים, ואז מודדים דירוגים ונראות מדי שבוע ומתקנים לפי הנתונים.' },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={[{ name: 'קידום אורגני לשופיפיי', path: canonicalPath }]}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(appLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(howToLd)} slot="head" />

  <section class="svc-hero">
    <div class="wrap center">
      <span class="eyebrow">קידום אורגני לשופיפיי</span>
      <h1>קידום אורגני לחנות שופיפיי · בלי סוכנות, בלי כאב ראש</h1>
      <p class="byline">מאת <a href={authorUrl}>{authorName}</a> · {updatedLabel}</p>
      <p class="lede">
        Scayla היא מכונת קידום אורגני שעובדת בתוך חנות ה-Shopify שלכם: מחקר מילות מפתח בעברית,
        מאמרים מבוססי מחקר, SEO למוצרים ולקטגוריות, קנוניקל, סכמות ותיקוני 404 · הכל באישור שלכם,
        הכל הפיך, מ-<span class="num">$39</span> לחודש.
      </p>
      <InstallCtaPair center variant="hero" />
      <p class="cta-note">אבחון חינם · חיוב דרך Shopify · ביטול בכל עת</p>
    </div>
  </section>

  <section class="svc-tldr">
    <div class="narrow">
      <div class="tldr card">
        <span class="tldr-tag">בקצרה</span>
        <p>
          קידום אורגני לשופיפיי הוא התאמת חנות Shopify כך שגוגל ומנועי AI ימצאו אותה, יבינו אותה
          וידרגו אותה גבוה. עושים זאת עם מבנה URL נקי וקנוניקל, מטאדאטה וכותרות ייחודיות לכל
          קטגוריה ומוצר, סכמות Product ו-FAQ, מטאפילדס ו-sitemap תקין · ואז מודדים מדי שבוע. Scayla
          מזהה את החוסמים ומכינה את התיקונים לאישור בקליק, מתוך החנות.
        </p>
      </div>
    </div>
  </section>

  <section class="svc-body alt-bg">
    <div class="narrow">
      <div class="sh">
        <span class="eyebrow">הבסיס</span>
        <h2>מה זה קידום אורגני לשופיפיי?</h2>
      </div>
      <div class="prose">
        <p>
          קידום אורגני לשופיפיי (SEO ל-Shopify) הוא סדרת פעולות שגורמות לחנות שלכם להופיע גבוה
          בתוצאות החיפוש של גוגל · ולאחרונה גם בתשובות של מנועי AI · על שאילתות שקונים באמת
          מקלידים. בניגוד לפרסום ממומן, תנועה אורגנית לא נעצרת ברגע שמפסיקים לשלם: עמוד קטגוריה
          שמדורג טוב ממשיך להביא קונים חודש אחרי חודש, וזו הסיבה שקידום אורגני הוא הנכס השיווקי
          הזול ביותר לטווח ארוך של חנות.
        </p>
        <p>
          Shopify עצמו נותן בסיס SEO סביר · הוא מייצר <b>sitemap.xml</b> אוטומטי, <b>robots.txt</b>
          תקין, ומבנה URL קבוע. אבל הבסיס הזה הוא המכנה המשותף של כל חנות Shopify בעולם, ולכן הוא
          לא מבדל אתכם. ההבדל בין חנות שמדורגת לחנות שקופה נמצא בשכבה שמעליו: איך אתם מנהלים כתובות
          כפולות, מטאדאטה, סכמות ומטאפילדס. את השכבה הזו נפרק כאן צעד-צעד.
        </p>
      </div>
    </div>
  </section>

  <section class="svc-body">
    <div class="narrow">
      <div class="sh">
        <span class="eyebrow">המנגנון של Shopify</span>
        <h2>איך עובד SEO בתוך Shopify?</h2>
        <p>Shopify מכתיב מבנה קבוע. מי שמכיר אותו, מנצל אותו במקום להיאבק בו:</p>
      </div>
      <div class="prose">
        <p>
          <b>קולקציות מול עמודי מוצר.</b> Shopify מפריד בין שני סוגי עמודים: קטגוריות תחת
          <code>/collections/</code> ומוצרים תחת <code>/products/</code>. הכלל הפשוט הוא שקטגוריות
          נלחמות על מילות מפתח רחבות ("נעלי ריצה לנשים") ומוצרים על מונחים מדויקים (שם דגם, מק"ט).
          חנויות רבות מפספסות דירוגים כי עמוד הקטגוריה שלהן ריק מטקסט · רק רשת מוצרים · בזמן שגוגל
          מחפש שם הסבר על הקטגוריה.
        </p>
        <p>
          <b>URL כפולים וקנוניקל.</b> זה החור הנפוץ ביותר בחנויות Shopify. כשמוצר משויך לכמה
          קולקציות, אותו מוצר נגיש גם דרך <code>/collections/שם/products/שם</code> וגם דרך
          <code>/products/שם</code>. גוגל רואה תוכן כפול ומפצל בין הכתובות את אותות הדירוג. הפתרון
          הוא תג <code>&lt;link rel="canonical"&gt;</code> שמצביע תמיד על כתובת <code>/products/</code>
          הנקייה. Shopify מוסיף אותו בברירת מחדל, אך ערכות ותוספים יכולים לשבור אותו · לכן צריך לבדוק.
        </p>
        <p>
          <b>מטאדאטה, כותרות ותיאורים.</b> ה-<code>title</code>, ה-<code>meta description</code>
          וכותרת ה-<code>H1</code> הם מה שגוגל מציג ומדרג. ברירת המחדל של Shopify ממחזרת את שם המוצר
          פעמיים, מה שמבזבז את השטח היקר בעמוד התוצאות. כל עמוד קטגוריה ומוצר צריך כותרת ותיאור
          ייחודיים, עם מילת המפתח בהתחלה ובניסוח שמזמין קליק.
        </p>
        <p>
          <b>מטאפילדס וה-theme.</b> Shopify שומר מאפייני מוצר נוספים · חומר, מידות, תאימות · ב-
          <b>metafields</b>. ערכת ה-theme (שכתובה ב-Liquid) מציגה אותם בעמוד, וגם מזינה מהם סכמת
          Product עשירה יותר. מטאפילדס מלאים פירושם עמוד מוצר שגוגל ומנועי AI מבינים לעומק, ולא רק
          כותרת ומחיר.
        </p>
        <p>
          <b>נתונים מובנים (סכמות).</b> סכמת <b>Product</b> עם מחיר וזמינות מזכה בכוכבי דירוג ומחיר
          ישירות בעמוד התוצאות, וסכמת <b>FAQPage</b> בעמודי מידע פותחת מקום נוסף. את הסכמות מזריקים
          ל-Liquid של ה-theme או דרך אפליקציה, ותמיד מוודאים שהן תקינות ב-Rich Results Test של גוגל.
        </p>
      </div>
    </div>
  </section>

  <section class="svc-body alt-bg">
    <div class="narrow">
      <div class="sh">
        <span class="eyebrow">ההבדל שחשוב להבין</span>
        <h2>Scayla מול סוכנות SEO מול אפליקציית SEO גנרית</h2>
        <p>שלוש דרכים לקדם חנות Shopify · ככה הן נראות זו מול זו:</p>
      </div>
      <div class="tbl-wrap">
        <table class="cmp">
          <thead>
            <tr><th></th><th>סוכנות SEO</th><th>אפליקציית SEO גנרית</th><th>Scayla</th></tr>
          </thead>
          <tbody>
            <tr><th>עלות חודשית</th><td>אלפי שקלים</td><td>נמוכה עד בינונית</td><td>מ-$39, חיוב דרך Shopify</td></tr>
            <tr><th>מי עושה את העבודה</th><td>אנשי צוות</td><td>אתם, ידנית</td><td>מכונה, לאישורכם</td></tr>
            <tr><th>מחקר מילים בעברית</th><td>לרוב כן</td><td>חלקי</td><td>כן, מובנה</td></tr>
            <tr><th>כתיבת תוכן ומאמרים</th><td>כן, לאט</td><td>לא</td><td>כן, מבוסס מחקר</td></tr>
            <tr><th>תיקוני קנוניקל ו-404</th><td>תלוי בסקופ</td><td>חלקי</td><td>כן, בקליק והפיך</td></tr>
            <tr><th>נראות במנועי AI</th><td>נדיר</td><td>לא</td><td>כן, מדידה מול ChatGPT ו-Gemini</td></tr>
          </tbody>
        </table>
      </div>
      <p class="svc-note center">
        הטבלה מתארת מודל עבודה טיפוסי · לא נתוני מחיר של ספק ספציפי. השוו תמיד לסקופ שהוצע לכם.
      </p>
    </div>
  </section>

  <section class="svc-body">
    <div class="narrow">
      <div class="sh">
        <span class="eyebrow">מה תקבלו</span>
        <h2>מה מכונת הקידום עושה לחנות שלכם?</h2>
      </div>
      <div class="bgrid two">
        <div class="b card fade-up">
          <span class="b-ic" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 3a8 8 0 1 0 0 16 8 8 0 0 0 0-16z"/><path d="M21 21l-4.3-4.3"/></svg>
          </span>
          <h3>מחקר מילות מפתח בעברית</h3>
          <p>המכונה מוצאת את השאילתות ששוות לכם הכי הרבה · כולל מילים שאתם צעד אחד מעמוד 1 בהן · וממפה כל אחת לעמוד קולקציה או מוצר.</p>
        </div>
        <div class="b card fade-up">
          <span class="b-ic" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.6 13.4 12 22l-9-9V4h9l8.6 8.6a1 1 0 0 1 0 1.4z"/><circle cx="7.5" cy="7.5" r="1.5"/></svg>
          </span>
          <h3>SEO למוצרים ולקטגוריות</h3>
          <p>כותרות, title ותיאורים ייחודיים במקום ברירת המחדל של Shopify, עם לפני/אחרי ליד כל הצעה. קידום חנות שופיפיי בקליק אחד.</p>
        </div>
        <div class="b card fade-up">
          <span class="b-ic" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5V6a2 2 0 0 1 2-2h11l3 3v12.5a1.5 1.5 0 0 1-1.5 1.5H5.5A1.5 1.5 0 0 1 4 19.5z"/><path d="M8 10h8M8 14h5"/></svg>
          </span>
          <h3>תוכן שמביא תנועה</h3>
          <p>מאמרים מבוססי מחקר בעברית תקנית, מכוונים למילות המפתח שלכם · מתפרסמים כבלוג Shopify רק באישורכם.</p>
        </div>
