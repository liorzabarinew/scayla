---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ExitIntent from '../components/ExitIntent.astro';
import StickyCheck from '../components/StickyCheck.astro';

interface Crumb {
  name: string;
  path: string;
}

interface Props {
  title: string;
  description: string;
  /** Optional path override for canonical (defaults to current URL) */
  ogType?: string;
  noIndex?: boolean;
  /** Per-page social share image · path or absolute URL. Defaults to the branded /og.png */
  ogImage?: string;
  /** Alt text for the social share image */
  ogImageAlt?: string;
  /** Social share image pixel dimensions · default to the branded /og.png (1200×630) */
  ogImageWidth?: number;
  ogImageHeight?: number;
  /** Breadcrumb trail after Home · defaults to one crumb derived from the title */
  breadcrumbs?: Crumb[];
}

const {
  title,
  description,
  ogType = 'website',
  noIndex = false,
  ogImage = '/og.png',
  ogImageAlt = 'קידום אורגני בגוגל ובמנועי AI לחנויות · Scayla',
  ogImageWidth = 1200,
  ogImageHeight = 630,
  breadcrumbs,
} = Astro.props;

// ── Share card (Lior, 2026-07-13): SITE-WIDE fixed share copy + cover. Every page —
//    home, features, magazine, legal — shares with the SAME branded card. Per-page
//    ogImage props are intentionally ignored; the <title> tag stays per-page for SEO. ──
const SHARE_TITLE = 'קידום אורגני בגוגל ובמנועי AI לחנויות · Scayla';
const SHARE_DESCRIPTION = 'קידום אורגני אוטומטי בגוגל ובמנועי AI · נבנה ע״י אנשי שיווק עם 15 שנות ניסיון באיקומרס. 14 יום ניסיון בלי להכניס כרטיס אשראי.';
// Absolute URL for the social share image (og:image requires an absolute URL)
const ogImageUrl = new URL('/og.png', Astro.site).href;

// Clean URL · Vercel cleanUrls serves /about (no .html), so the canonical must
// match the served URL. build.format:'file' gives us pathnames like /about.html;
// strip the .html suffix (home "/" stays "/").
const cleanPathname = Astro.url.pathname.replace(/\.html$/, '');
const canonical = new URL(cleanPathname, Astro.site);

// BreadcrumbList JSON-LD · sitewide (Noy · question 9)
const path = cleanPathname.replace(/\/$/, '') || '/';
const trail: Crumb[] =
  breadcrumbs ??
  (path === '/' ? [] : [{ name: title.split('·')[0].trim(), path }]);
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'בית', item: 'https://scayla.co.il/' },
    ...trail.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: c.name,
      item: new URL(c.path, Astro.site).href,
    })),
  ],
};
---

<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {/* hreflang scaffold (Noy · question 10): Hebrew only today. When the English
        locale launches, add: <link rel="alternate" hreflang="en" href=".../en/..." />
        and hreflang="x-default" pointing at the primary version. */}
    <link rel="alternate" hreflang="he" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={SHARE_TITLE} />
    <meta property="og:description" content={SHARE_DESCRIPTION} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="he_IL" />
    <meta property="og:site_name" content="Scayla" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="preload" href="/fonts/heebo-hebrew.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/heebo-latin.woff2" as="font" type="font/woff2" crossorigin />
    <meta name="theme-color" content="#f6f4fb" />
    <script is:inline>
      // Theme boot · runs before paint. Dark Mode is DISABLED (Lior, 2026-07-18):
      // the site is always light. The [data-theme='dark'] CSS stays in the codebase
      // but is never triggered, so re-enabling later is a one-line change here.
      (function () {
        document.documentElement.classList.add('js');
        document.documentElement.setAttribute('data-theme', 'light');
        try { localStorage.removeItem('sc-theme'); } catch (e) {}
      })();
    </script>
    <slot name="head" />
    <link rel="stylesheet" href="https://assets.calendly.com/assets/external/widget.css" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9DLVZ5M4B8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9DLVZ5M4B8');
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">דילוג לתוכן הראשי</a>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
    <ExitIntent />
    {/* כפתור בדיקה-חינם סטיקי · בכל האתר חוץ מ-/scan עצמו */}
    {!cleanPathname.startsWith('/scan') && <StickyCheck />}
    <script>
      // Fade-up reveal · animates on scroll, but content must NEVER stay invisible
      // (fast scroll or an observer hiccup could otherwise strand a section at opacity:0).
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const els = [...document.querySelectorAll('.fade-up')];
      const reveal = (el) => el.classList.add('in');
      if (reduce || !('IntersectionObserver' in window)) {
        els.forEach(reveal);
      } else {
        // Anything already in/above the viewport at load shows immediately (no flash).
        let pending = els.filter((el) => {
          if (el.getBoundingClientRect().top < window.innerHeight) { reveal(el); return false; }
          return true;
        });
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) { reveal(e.target); io.unobserve(e.target); }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        pending.forEach((el) => io.observe(el));
        // Fallback: fast scroll can outrun the observer · reveal anything that entered view.
        const sweep = () => {
          pending = pending.filter((el) => {
            if (el.getBoundingClientRect().top < window.innerHeight) { reveal(el); io.unobserve(el); return false; }
            return true;
          });
          if (!pending.length) window.removeEventListener('scroll', sweep);
        };
        window.addEventListener('scroll', sweep, { passive: true });
      }
    </script>

    <!-- Calendly · demo popup. Any "קבעו דמו" link (href → calendly.com, from
         DEMO_URL) opens the popup instead of navigating. If the widget hasn't
         loaded, the link still works as a normal navigation (graceful fallback). -->
    <script src="https://assets.calendly.com/assets/external/widget.js" async></script>
    <script>
      document.addEventListener('click', (e) => {
        const a = e.target.closest('a[href*="calendly.com"]');
        if (!a) return;
        if (window.Calendly && typeof window.Calendly.initPopupWidget === 'function') {
          e.preventDefault();
          window.Calendly.initPopupWidget({ url: a.href });
        }
      });
    </script>
  </body>
</html>
