---
/**
 * Pricing cards · 3 tiers from src/data/pricing.ts.
 * Used on the home page and on /pricing.
 * Monthly ⇄ annual toggle: annual bills at ANNUAL_DISCOUNT off (currently 20%).
 * The toggle flips data-billing on the wrapper; CSS swaps the price + savings line.
 */
import {
  tiers, SHOPIFY_APP_URL,
  ANNUAL_DISCOUNT_PCT, annualPerMonth, annualTotal,
} from '../data/pricing';
---

<div class="pricing" data-billing="monthly">
  <div class="billing-toggle" role="tablist" aria-label="מחזור חיוב">
    <button type="button" role="tab" data-bill="monthly" class="on" aria-selected="true">חודשי</button>
    <button type="button" role="tab" data-bill="annual" aria-selected="false">
      שנתי <span class="pct">חסכו {ANNUAL_DISCOUNT_PCT}%</span>
    </button>
  </div>

  <div class="pgrid">
    {tiers.map((t) => (
      <article class:list={['pl', { pop: t.popular }]}>
        {t.popular && <span class="tag">הכי פופולרי</span>}
        <h3>{t.name}</h3>

        <p class="pr">
          <span class="bill-monthly"><span class="num">${t.price}</span><small>/חודש</small></span>
          <span class="bill-annual"><span class="num">${annualPerMonth(t.price)}</span><small>/חודש</small></span>
        </p>
        <p class="sub-price bill-annual">
          <s class="num">${t.price}</s> · בחיוב שנתי <span class="num">${annualTotal(t.price)}</span>/שנה
        </p>
        <p class="sub-price bill-monthly">חיוב חודשי · ביטול בכל עת</p>

        <p class="desc">{t.tagline}</p>
        <div class="axes">
          {t.axes.map((a) => (
            <div class="ax">
              <span class="ax-l">{a.label}</span>
              <b class:list={['ax-v', { num: a.num }]}>{a.value}</b>
            </div>
          ))}
        </div>
        <ul>
          {t.features.map((f) => <li>{f}</li>)}
        </ul>
        <a href={SHOPIFY_APP_URL} class:list={['btn', t.popular ? 'btn-white' : 'btn-ghost']}>
          התחילו ב-Shopify
        </a>
      </article>
    ))}
  </div>
</div>

<style>
  /* ── Monthly / annual toggle ── */
  .billing-toggle {
    display: flex; inline-size: fit-content; gap: 4px; margin: 0 auto 26px; padding: 4px;
    background: var(--sc-wash); border: 1px solid var(--sc-soft);
    border-radius: var(--sc-r-pill);
  }
  .billing-toggle button {
    display: inline-flex; align-items: center; gap: 8px;
    font: inherit; font-size: 14px; font-weight: 700; color: var(--sc-mv);
    background: transparent; border: none; cursor: pointer;
    padding: 9px 20px; border-radius: var(--sc-r-pill);
    transition: background .18s var(--sc-ease), color .18s var(--sc-ease), box-shadow .18s var(--sc-ease);
  }
  .billing-toggle button:hover { color: var(--sc-accent-text); }
  .billing-toggle button.on {
    background: var(--sc-paper); color: var(--sc-accent-text);
    box-shadow: 0 1px 3px rgba(20, 16, 50, .12);
  }
  .billing-toggle button:focus-visible { outline: 2px solid var(--sc-accent); outline-offset: 2px; }
  .pct {
    font-size: 11px; font-weight: 800; letter-spacing: .01em;
    background: var(--sc-pos); color: #fff;
    padding: 2px 8px; border-radius: var(--sc-r-pill); white-space: nowrap;
  }

  /* ── Price swap · data-billing on .pricing is always set, so exactly one
     of these hides the inactive period; the active one keeps natural display. ── */
  .pricing[data-billing="monthly"] .bill-annual { display: none; }
  .pricing[data-billing="annual"] .bill-monthly { display: none; }

  .sub-price {
    font-size: 13px; color: var(--sc-muted); font-weight: 600;
    margin-block: -2px 4px; min-block-size: 18px;
  }
  .sub-price s { color: var(--sc-disabled); text-decoration-thickness: 1px; margin-inline-end: 2px; }
  .pl.pop .sub-price { color: rgba(255, 255, 255, .82); }
  .pl.pop .sub-price s { color: rgba(255, 255, 255, .55); }

  .pgrid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    align-items: stretch;
  }
  @media (max-width: 820px) { .pgrid { grid-template-columns: 1fr; max-inline-size: 460px; margin-inline: auto; } }
  .pl {
    border: 1px solid var(--sc-hair);
    border-radius: var(--sc-r-hero);
    padding: 28px;
    background: var(--sc-paper);
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .pl.pop {
    background: var(--sc-grad-rich);
    color: #fff;
    border: none;
    box-shadow: 0 20px 44px -18px rgba(85, 70, 214, .6);
  }
  .tag {
    position: absolute;
    inset-block-start: 16px;
    inset-inline-start: 24px;
    background: #fff;
    color: var(--sc-accent);
    font-size: 11px;
    font-weight: 800;
    padding: 4px 11px;
    border-radius: var(--sc-r-pill);
  }
  h3 { font-size: 20px; margin-block-end: 4px; margin-block-start: 8px; }
  .pr {
    font-size: 44px; font-weight: 800; letter-spacing: -.02em;
    margin-block: 8px 2px; color: inherit;
  }
  .pr small { font-size: 15px; font-weight: 600; color: var(--sc-muted); }
  .pl.pop .pr small { color: rgba(255, 255, 255, .8); }
  .desc { font-size: 14px; margin-block-end: 6px; margin-block-start: 6px; }
  .pl.pop .desc { color: rgba(255, 255, 255, .88); }
  /* the 4 quantity axes · identical labels + order on every card,
     so the difference between tiers is obvious at a glance */
  .axes {
    display: flex; flex-direction: column;
    background: var(--sc-wash); border: 1px solid var(--sc-soft);
    border-radius: 12px; padding: 4px 14px; margin-block: 10px 18px;
  }
  .ax {
    display: flex; align-items: baseline; justify-content: space-between; gap: 10px;
    padding-block: 8px;
  }
  .ax + .ax { border-block-start: 1px solid var(--sc-soft); }
  .ax-l { font-size: 12.5px; font-weight: 600; color: var(--sc-mv); }
  .ax-v { font-size: 14px; font-weight: 800; color: var(--sc-accent-text); }
  .pl.pop .axes { background: rgba(255, 255, 255, .12); border-color: rgba(255, 255, 255, .24); }
  .pl.pop .ax + .ax { border-block-start-color: rgba(255, 255, 255, .18); }
  .pl.pop .ax-l { color: rgba(255, 255, 255, .78); }
  .pl.pop .ax-v { color: #fff; }
  ul {
    list-style: none; margin: 0 0 22px; padding: 0;
    display: flex; flex-direction: column; gap: 10px;
  }
  li { font-size: 14px; display: flex; gap: 9px; align-items: flex-start; color: var(--sc-ink); }
  .pl.pop li { color: #fff; }
  li::before { content: '✓'; color: var(--sc-pos); font-weight: 800; flex: none; }
  .pl.pop li::before { color: #c9ffdc; }
  .btn { margin-block-start: auto; }
  .pnote {
    text-align: center; font-size: 13.5px; color: var(--sc-muted);
    margin-block-start: 22px;
  }
</style>

<script>
  // Toggle billing period · flips data-billing on the nearest .pricing wrapper.
  document.querySelectorAll('.pricing').forEach((root) => {
    const btns = root.querySelectorAll('.billing-toggle button');
    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        root.setAttribute('data-billing', btn.dataset.bill);
        btns.forEach((b) => {
          const on = b === btn;
          b.classList.toggle('on', on);
          b.setAttribute('aria-selected', on ? 'true' : 'false');
        });
      });
    });
  });
</script>
