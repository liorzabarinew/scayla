---
/**
 * DashboardMock · a faithful, scaled-down replica of the REAL Scayla dashboard
 * (source: Scayla-Design-System/design-handoff/dashboard.dc.html).
 * Rendered as live HTML (not a screenshot) so it stays crisp, theme-aware and RTL-true.
 * Values match the handoff: gauge 34% · ▲+6 · 1,240 כניסות · +18% · 72% analysis.
 * The gauge + progress animate once when scrolled into view (motion-safe, handled
 * by the page script via [data-dm-gauge] hooks).
 *
 * Interactive-looking elements are intentionally <span>s · this is a product
 * portrait, not a form.
 */
interface Props {
  /** hide the momentum + action zones for a shorter crop */
  compact?: boolean;
}
const { compact = false } = Astro.props;
const C = (2 * Math.PI * 84).toFixed(1); // gauge circumference
---

<figure class="dm" aria-label="הדשבורד של Scayla · ציון נראות ב-AI, תנועה מגוגל והמכונה בפעולה">
  <!-- browser chrome -->
  <div class="dm-chrome" aria-hidden="true">
    <span class="dm-dots"><i></i><i></i><i></i></span>
    <span class="dm-url num">app.scayla.co.il</span>
  </div>

  <div class="dm-body">
    <!-- header -->
    <div class="dm-head">
      <span class="dm-h1">הסקירה שלכם</span>
      <span class="dm-upd">עודכן לפני דקה</span>
    </div>

    <!-- live analysis banner -->
    <div class="dm-live">
      <span class="dm-live-ic" aria-hidden="true">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8V5.5A1.5 1.5 0 0 1 5.5 4H8"/><path d="M20 8V5.5A1.5 1.5 0 0 0 18.5 4H16"/><path d="M4 16v2.5A1.5 1.5 0 0 0 5.5 20H8"/><path d="M20 16v2.5A1.5 1.5 0 0 1 18.5 20H16"/><path d="M4 12h16"/></svg>
      </span>
      <span class="dm-live-t">
        <span class="dm-live-row"><b>ניתוח עומק רץ עכשיו</b><i class="num"><em data-dm-count data-to="72">72</em>%</i></span>
        <span class="dm-prog"><i data-dm-prog style="--p:72%"></i></span>
      </span>
    </div>

    <!-- truth strip · gauge + google -->
    <div class="dm-truth">
      <div class="dm-truth-main">
        <div class="dm-eyebrow">הנראות שלך ב-AI</div>
        <div class="dm-truth-row">
          <div class="dm-gauge" data-dm-gauge data-target="34">
            <svg viewBox="0 0 200 200" aria-hidden="true">
              <defs>
                <linearGradient id="dmGrad" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0" stop-color="#5546d6"/><stop offset="1" stop-color="#8b76f2"/>
                </linearGradient>
              </defs>
              <circle cx="100" cy="100" r="84" fill="none" stroke="var(--sc-div)" stroke-width="15"/>
              <circle class="dm-arc" cx="100" cy="100" r="84" fill="none" stroke="url(#dmGrad)" stroke-width="15"
                stroke-linecap="round" stroke-dasharray={C} stroke-dashoffset={C} transform="rotate(-90 100 100)"/>
            </svg>
            <span class="dm-gauge-c">
              <b class="num"><i data-dm-gauge-num>34</i><em class="pct">%</em></b>
              <small>נראות ב-AI</small>
            </span>
          </div>
          <div class="dm-truth-txt">
            <p>אתם מופיעים ב-<b class="num">34%</b> מהתשובות</p>
            <span class="dm-trend"><b class="num">▲ +<em data-dm-count data-to="6">6</em></b> מהשבוע שעבר</span>
          </div>
        </div>
      </div>
      <div class="dm-truth-side">
        <div class="dm-eyebrow">ומה בגוגל</div>
        <div class="dm-big num" data-dm-count data-to="1240" data-group>1,240</div>
        <div class="dm-side-lbl">כניסות · 30 ימים</div>
        <div class="dm-side-delta">מול התקופה הקודמת · <b class="num">+<em data-dm-count data-to="18">18</em>%</b></div>
      </div>
    </div>

    {!compact && (
      <>
        <!-- momentum ribbon -->
        <div class="dm-mom">
          <span class="dm-mom-lead"><i class="dm-dot" aria-hidden="true"></i>המכונה עובדת בשבילך</span>
          <span class="dm-mom-i"><b class="num">3</b>מאמרים נכתבו השבוע</span>
          <span class="dm-mom-i"><b class="num">12</b>מוצרים שופרו</span>
          <span class="dm-mom-i"><b class="num">5</b>תשובות מוכנות</span>
        </div>

        <!-- next best action · the one loud surface -->
        <div class="dm-nba">
          <div class="dm-nba-top">
            <span class="dm-nba-ic" aria-hidden="true">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20l4.5-1L18 9.5a2.1 2.1 0 0 0-3-3L5.5 16z"/><path d="M14 6.5l3 3"/></svg>
            </span>
            <span class="dm-nba-lbl">המכונה · כותב התוכן</span>
          </div>
          <p class="dm-nba-h">מאמר חדש מוכן לאישור · 'מדריך בחירת נעלי ריצה 2026'</p>
          <p class="dm-nba-sub">מכוון ל-<span class="num">320</span> חיפושים בחודש שאתם לא מופיעים בהם היום.</p>
          <span class="dm-nba-btn">בדקו ואשרו ←</span>
        </div>
      </>
    )}
  </div>
</figure>

<style define:vars={{ circ: C }}>
  /* ~0.82 visual scale of the real dashboard, baked into the values.
     Token-based → adapts to dark mode automatically. */
  .dm {
    margin: 0;
    background: var(--sc-paper);
    border: 1px solid var(--sc-hair);
    border-radius: 18px;
    overflow: hidden;
    direction: rtl;
    text-align: start;
    font-family: var(--sc-font);
  }
  .dm-chrome {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px;
    background: var(--sc-card);
    border-block-end: 1px solid var(--sc-hair);
  }
  .dm-dots { display: flex; gap: 5px; }
  .dm-dots i { inline-size: 9px; block-size: 9px; border-radius: 50%; background: var(--sc-div); }
  .dm-url {
    margin-inline-start: auto;
    font-size: 11px; font-weight: 600; color: var(--sc-muted);
    background: var(--sc-paper); border: 1px solid var(--sc-hair);
    padding: 3px 12px; border-radius: 999px;
  }
  .dm-body { display: flex; flex-direction: column; gap: 11px; padding: 16px; }

  .dm-head { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; }
  .dm-h1 { font-size: 19px; font-weight: 800; letter-spacing: -.015em; color: var(--sc-ink); }
  .dm-upd { font-size: 10.5px; color: var(--sc-muted); font-weight: 500; }

  /* live banner */
  .dm-live {
    display: flex; align-items: center; gap: 10px;
    background: var(--sc-card); border: 1px solid var(--sc-hair);
    border-radius: 12px; padding: 9px 13px; box-shadow: var(--sc-sh-subtle);
  }
  .dm-live-ic {
    inline-size: 28px; block-size: 28px; border-radius: 8px; flex: none;
    background: var(--sc-wash); color: var(--sc-accent-text);
    display: grid; place-items: center;
  }
  .dm-live-t { flex: 1 1 auto; min-inline-size: 0; }
  .dm-live-row { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; }
  .dm-live-row b { font-size: 11.5px; font-weight: 600; color: var(--sc-ink); }
  .dm-live-row i { font-style: normal; font-weight: 700; color: var(--sc-accent-text); font-size: 11px; }
  .dm-live-row i em { font-style: normal; }
  /* count-up numbers · never italic, keep LTR tabular alignment */
  [data-dm-count] { font-style: normal; font-variant-numeric: tabular-nums; }
  .dm-trend b em, .dm-side-delta b em { font-style: normal; }
  .dm-prog { display: block; block-size: 5px; border-radius: 999px; background: var(--sc-div); margin-block-start: 5px; overflow: hidden; }
  .dm-prog i {
    display: block; block-size: 100%; border-radius: 999px; inline-size: var(--p, 72%);
    background: linear-gradient(90deg, #5546d6, #8b76f2);
  }
  html.js .dm-prog i { inline-size: 0; transition: inline-size 900ms var(--sc-ease); }
  html.js .dm.in .dm-prog i { inline-size: var(--p, 72%); }
  @media (prefers-reduced-motion: reduce) {
    html.js .dm-prog i { inline-size: var(--p, 72%); }
  }

  /* truth strip */
  .dm-truth {
    display: flex; flex-wrap: wrap; gap: 10px 22px; align-items: stretch;
    background: var(--sc-card); border: 1px solid var(--sc-hair);
    border-radius: 14px; padding: 17px 19px; box-shadow: var(--sc-sh-subtle);
  }
  .dm-truth-main { flex: 2 1 230px; min-inline-size: 0; display: flex; flex-direction: column; gap: 11px; }
  .dm-eyebrow { font-size: 10px; font-weight: 700; color: var(--sc-muted); letter-spacing: .04em; }
  .dm-truth-row { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .dm-gauge { position: relative; inline-size: 118px; block-size: 118px; flex: none; }
  .dm-gauge svg { inline-size: 100%; block-size: 100%; display: block; }
  .dm-arc { transition: stroke-dashoffset 1300ms var(--sc-ease); }
  html:not(.js) .dm-arc, .dm.in .dm-arc { stroke-dashoffset: calc(var(--circ) * .66); }
  @media (prefers-reduced-motion: reduce) { .dm-arc { stroke-dashoffset: calc(var(--circ) * .66) !important; transition: none; } }
  .dm-gauge-c {
    position: absolute; inset: 0; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
  }
  .dm-gauge-c b { font-weight: 800; font-size: 29px; line-height: 1; letter-spacing: -.02em; color: var(--sc-ink); }
  .dm-gauge-c b i { font-style: normal; }
  .dm-gauge-c b em { font-style: normal; font-size: 14px; font-weight: 700; color: var(--sc-accent-text); }
  .dm-gauge-c small { font-size: 9px; color: var(--sc-muted); margin-block-start: 3px; font-weight: 500; }
  .dm-truth-txt { flex: 1 1 120px; min-inline-size: 0; display: flex; flex-direction: column; gap: 9px; }
  .dm-truth-txt p { font-size: 14.5px; font-weight: 500; line-height: 1.35; color: var(--sc-ink); }
  .dm-truth-txt p b { font-weight: 800; font-size: 19px; color: var(--sc-accent-text); }
  .dm-trend {
    display: inline-flex; align-self: flex-start; align-items: center; gap: 5px;
    background: var(--sc-pos-bg); color: var(--sc-pos-deep); border: 1px solid var(--sc-pos-bd);
    border-radius: 999px; padding: 4px 10px; font-size: 10.5px; font-weight: 500;
  }
  .dm-trend b { font-weight: 700; }
  .dm-truth-side {
    flex: 1 1 130px; min-inline-size: 0; display: flex; flex-direction: column;
    justify-content: center; gap: 5px;
    border-inline-start: 1px solid var(--sc-hair); padding-inline-start: 22px;
  }
  .dm-big { font-weight: 800; font-size: 29px; letter-spacing: -.02em; line-height: 1.05; color: var(--sc-ink); }
  .dm-side-lbl { font-size: 10.5px; color: var(--sc-muted); font-weight: 500; }
  .dm-side-delta { font-size: 10.5px; color: var(--sc-pos-deep); font-weight: 600; margin-block-start: 2px; }
  .dm-side-delta b { font-weight: 800; }

  /* momentum ribbon */
  .dm-mom {
    display: flex; align-items: center; flex-wrap: wrap; gap: 8px 16px;
    background: var(--sc-wash); border: 1px solid var(--sc-soft);
    border-radius: 12px; padding: 10px 15px;
  }
  .dm-mom-lead { display: flex; align-items: center; gap: 7px; font-weight: 700; font-size: 10.5px; color: var(--sc-accent-text); flex: none; }
  .dm-dot {
    inline-size: 7px; block-size: 7px; border-radius: 999px; background: var(--sc-dot);
    animation: dmPulse 1.8s ease-in-out infinite;
  }
  @keyframes dmPulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: .3; transform: scale(.6); } }
  @media (prefers-reduced-motion: reduce) { .dm-dot { animation: none; } }
  .dm-mom-i { display: flex; align-items: baseline; gap: 5px; font-size: 10px; color: var(--sc-mv); font-weight: 500; }
  .dm-mom-i b { font-weight: 800; font-size: 15px; color: var(--sc-accent-text); }

  /* next best action */
  .dm-nba {
    border-radius: 15px; padding: 17px 19px; color: #fff;
    box-shadow: var(--sc-sh-hero);
    background:
      radial-gradient(110% 130% at 92% -25%, rgba(167, 139, 250, .55), transparent 60%),
      linear-gradient(135deg, #211c86, #5546d6, #8b76f2);
  }
  .dm-nba-top { display: flex; align-items: center; gap: 9px; }
  .dm-nba-ic {
    inline-size: 32px; block-size: 32px; border-radius: 10px; flex: none;
    background: rgba(255, 255, 255, .16); border: 1px solid rgba(255, 255, 255, .28);
    display: grid; place-items: center;
  }
  .dm-nba-lbl { font-size: 9.5px; font-weight: 700; letter-spacing: .03em; color: rgba(255, 255, 255, .85); }
  .dm-nba-h { font-size: 15.5px; font-weight: 800; letter-spacing: -.015em; line-height: 1.3; margin-block-start: 10px; color: #fff; }
  .dm-nba-sub { font-size: 11px; color: rgba(255, 255, 255, .88); margin-block-start: 5px; line-height: 1.5; }
  .dm-nba-btn {
    display: inline-block; margin-block-start: 13px;
    background: #fff; color: #5546d6; border-radius: 999px;
    padding: 8px 17px; font-size: 11.5px; font-weight: 700;
    box-shadow: 0 8px 20px -8px rgba(0, 0, 0, .32);
  }
</style>
