---
// Site footer · nav, legal links, contact.
import { DEMO_URL } from '../data/pricing';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap">
    <div class="cols">
      <div class="brand-col">
        <a class="logo" href="/" aria-label="Scayla · לעמוד הבית">
          <span class="mk" aria-hidden="true">S</span> Scayla
        </a>
        <p>נראות ב-Google וב-AI · אוטומטית, מהיום.<br />האפליקציה הישראלית שמכניסה את החנות שלכם לתשובות של מחר.</p>
      </div>
      <nav aria-label="קישורי אתר">
        <h3>האתר</h3>
        <ul>
          <li><a href="/#how">איך זה עובד</a></li>
          <li><a href="/check">בדיקה חינם</a></li>
          <li><a href="/#features">פיצרים</a></li>
          <li><a href="/pricing">מחירון</a></li>
          <li><a href="/magazine">בלוג</a></li>
          <li><a href="/about">מי אנחנו</a></li>
          <li><a href="/experts">המומחים</a></li>
        </ul>
      </nav>
      <nav aria-label="פתרונות">
        <h3>פתרונות</h3>
        <ul>
          <li><a href="/seo-shopify">קידום אורגני ל-Shopify</a></li>
          <li><a href="/geo">אופטימיזציה למנועי AI · GEO</a></li>
          <li><a href="/ai-visibility">הופעה ב-ChatGPT וב-Gemini</a></li>
          <li><a href="/chatgpt-seo">קידום ל-ChatGPT</a></li>
          <li><a href="/gemini-seo">הופעה ב-Gemini</a></li>
          <li><a href="/perplexity-seo">הופעה ב-Perplexity</a></li>
          <li><a href="/claude-seo">הופעה ב-Claude</a></li>
        </ul>
      </nav>
      <nav aria-label="עזרה ותמיכה">
        <h3>עזרה</h3>
        <ul>
          <li><a href="/faq">שאלות נפוצות</a></li>
          <li><a href="/contact">צרו קשר</a></li>
          <li><a href={DEMO_URL} target="_blank" rel="noopener">קבעו דמו</a></li>
        </ul>
      </nav>
      <nav aria-label="מידע משפטי">
        <h3>משפטי</h3>
        <ul>
          <li><a href="/privacy">מדיניות פרטיות</a></li>
          <li><a href="/terms">תנאי שימוש</a></li>
          <li><a href="/accessibility">הצהרת נגישות</a></li>
        </ul>
      </nav>
    </div>
    <div class="bottom">
      <p class="credit">
        נבנה באהבה <span aria-hidden="true">💜</span> עבור עסקים בישראל ע״י
        <a href="https://busymom.co.il/" target="_blank" rel="noopener">נוי קייטל</a>
        <span aria-hidden="true">&amp;</span>
        <a href="https://mrmake.co.il/" target="_blank" rel="noopener">ליאור צברי</a>
      </p>
      <p class="copy">© <span class="num">{year}</span> Scayla · כל הזכויות שמורות</p>
      <a class="domain num" href="https://scayla.co.il">scayla.co.il</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-block-start: 1px solid var(--sc-hair);
    background: var(--sc-card);
    padding-block: clamp(36px, 5vw, 56px) 28px;
    margin-block-start: 40px;
  }
  .cols {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1.2fr 1fr 1fr;
    gap: 28px;
  }
  @media (max-width: 820px) { .cols { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .cols { grid-template-columns: 1fr; } }
  .logo {
    display: inline-flex; align-items: center; gap: 9px;
    font-weight: 800; font-size: 19px; letter-spacing: -.02em; color: var(--sc-ink);
  }
  .mk {
    inline-size: 28px; block-size: 28px; border-radius: 8px;
    background: var(--sc-grad); color: #fff; font-weight: 800; font-size: 15px;
    display: grid; place-items: center;
  }
  .brand-col p { font-size: 13.5px; margin-block-start: 12px; max-inline-size: 34ch; }
  h3 {
    font-size: 13px; font-weight: 700; letter-spacing: .04em;
    color: var(--sc-muted); margin-block-end: 12px;
  }
  ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 9px; }
  ul a { font-size: 14px; color: var(--sc-ink); font-weight: 500; }
  ul a:hover { color: var(--sc-accent-text); }
  /* one balanced row · credit (start) · copyright (center) · domain (end).
     Wraps gracefully to a centered stack on mobile. */
  .bottom {
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px 24px; flex-wrap: wrap;
    margin-block-start: 36px; padding-block-start: 20px;
    border-block-start: 1px solid var(--sc-div);
    font-size: 13px; color: var(--sc-disabled);
  }
  .credit {
    margin: 0; font-size: 13px; color: var(--sc-muted);
    flex: 1 1 auto; min-inline-size: 0;
  }
  .credit a { color: var(--sc-accent-text); font-weight: 600; }
  .credit a:hover { text-decoration: underline; }
  .copy { margin: 0; font-size: 13px; color: var(--sc-disabled); flex: 0 1 auto; text-align: center; }
  .domain { font-size: 13px; font-weight: 600; color: var(--sc-muted); flex: 0 0 auto; }
  .domain:hover { color: var(--sc-accent-text); }
  @media (max-width: 640px) {
    .bottom { flex-direction: column; text-align: center; gap: 10px; }
    .credit { flex: none; text-align: center; }
  }
</style>
